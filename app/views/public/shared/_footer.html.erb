<footer class="public-site-footer mt-5">
  <div class="container py-5">
    <div class="row g-4">
      
      <!-- Logo et Informations -->
      <div class="col-12 col-md-4 mb-4 mb-md-0">
        <%= link_to home_path, class: "d-inline-block mb-3" do %>
          <%= image_tag('/images/a1soirlogo2.png', class: 'mb-0', width: "200", alt: "Autour d'un Soir") %>
        <% end %>
        
        <% if @footer_texte_adresse.present? %>
          <div class="mb-3 d-flex align-items-start text-light">
            <i class="bi bi-geo-alt-fill me-2 small" style="flex-shrink: 0; margin-top: 2px;"></i>
            <%= link_to "https://www.google.com/maps/search/?api=1&query=#{CGI.escape('autour d\'un soir 06400 cannes')}", target: "_blank", rel: "noopener noreferrer", class: "text-light text-decoration-none hover-link d-flex align-items-start" do %>
              <p class="small mb-0 fw-bold" style="line-height: 1.6;">
                <%= @footer_texte_adresse %>
              </p>
              <i class="bi bi-box-arrow-up-right ms-2 opacity-75" style="font-size: 0.75rem; margin-top: 2px; flex-shrink: 0;"></i>
            <% end %>
          </div>
        <% end %>
        
        <% if @footer_texte_horaire.present? %>
          <div class="mb-3 d-flex align-items-start text-light">
            <i class="bi bi-clock-fill me-2 small" style="flex-shrink: 0; margin-top: 2px;"></i>
            <p class="small mb-0 fw-bold" style="line-height: 1.6;">
              <%= @footer_texte_horaire %>
            </p>
          </div>
        <% end %>

        <% if @footer_texte_contact.present? %>
          <div class="mb-3 d-flex align-items-start text-light">
            <i class="bi bi-telephone-fill me-2 small" style="flex-shrink: 0; margin-top: 2px;"></i>
            <p class="small mb-0 fw-bold" style="line-height: 1.6;">
              <%= @footer_texte_contact %>
            </p>
          </div>
        <% end %>
      </div>
      
      <!-- Navigation -->
      <div class="col-6 col-md-2">
        <h6 class="text-uppercase mb-4 text-light"><%= t("public.footer.navigation") %></h6>
        <ul class="list-unstyled">
          <li class="mb-2"><%= link_to t("public.footer.home"), home_path, class: "text-light text-decoration-none hover-link" %></li>
          <li class="mb-2"><%= link_to t("public.footer.shop"), la_boutique_url, class: "text-light text-decoration-none hover-link" %></li>
          <li class="mb-2"><%= link_to t("public.footer.collections"), nos_collections_url, class: "text-light text-decoration-none hover-link" %></li>
          <li class="mb-2"><%= link_to t("public.footer.concept"), le_concept_url, class: "text-light text-decoration-none hover-link" %></li>
          <li class="mb-2"><%= link_to t("public.footer.other_activities"), nos_autres_activites_url, class: "text-light text-decoration-none hover-link" %></li>
        </ul>
      </div>

      <!-- Services -->
      <div class="col-6 col-md-2">
        <h6 class="text-uppercase mb-4 text-light"><%= t("public.footer.services") %></h6>
        <ul class="list-unstyled">
          <li class="mb-2"><%= link_to t("public.footer.products"), produits_index_url, class: "text-light text-decoration-none hover-link" %></li>
          <li class="mb-2"><%= link_to t("public.footer.appointment"), rdv_url, class: "text-light text-decoration-none hover-link" %></li>
          <li class="mb-2"><%= link_to t("public.footer.contact"), contact_url, class: "text-light text-decoration-none hover-link" %></li>
          <li class="mb-2"><%= link_to "FAQ", faq_url, class: "text-light text-decoration-none hover-link" %></li>
        </ul>
      </div>

      <!-- Suivez-nous -->
      <div class="col-6 col-md-2">
        <h6 class="text-uppercase mb-4 text-light"><%= t("public.footer.follow_us") %></h6>
        <div class="d-flex flex-column gap-2">
          <%= link_to "https://www.instagram.com/autourdunsoir/", class: "text-light text-decoration-none hover-link d-flex align-items-center gap-2", target: "_blank", rel: "noopener noreferrer" do %>
            <i class="bi bi-instagram fs-5"></i>
            <span>Instagram</span>
          <% end %>
          <%= link_to "https://www.facebook.com/autourdunsoir/", class: "text-light text-decoration-none hover-link d-flex align-items-center gap-2", target: "_blank", rel: "noopener noreferrer" do %>
            <i class="bi bi-facebook fs-5"></i>
            <span>Facebook</span>
          <% end %>
          <%= link_to "https://www.tiktok.com/@autourd1soir", class: "text-light text-decoration-none hover-link d-flex align-items-center gap-2", target: "_blank", rel: "noopener noreferrer" do %>
            <i class="bi bi-tiktok fs-5"></i>
            <span>TikTok</span>
          <% end %>
        </div>
      </div>

      <!-- Légal -->
      <div class="col-6 col-md-2">
        <h6 class="text-uppercase mb-4 text-light"><%= t("public.footer.legal") %></h6>
        <ul class="list-unstyled">
          <li class="mb-2"><%= link_to t("public.footer.legal_mentions"), legal_url, class: "text-light text-decoration-none hover-link" %></li>
          <li class="mb-2">
            <button
              type="button"
              class="btn btn-link p-0 text-light text-decoration-none hover-link small"
              data-action="click->cookie-consent#reset"
            >
              <%= t("public.footer.manage_cookies") %>
            </button>
          </li>
        </ul>
      </div>

    </div>
  </div>

  <!-- Copyright -->
  <div class="py-3">
    <div class="container">
      <div class="row">
        <div class="col-12 text-center">
          <div class="d-flex justify-content-center align-items-center gap-2 mb-2">
            <%= link_to url_for(locale: :fr), class: "btn btn-sm public-btn-border-radius d-inline-flex align-items-center gap-2 #{I18n.locale == :fr ? 'btn-light text-dark' : 'btn-outline-light'}" do %>
              <%= image_tag("/images/fr.webp", alt: "", width: 16, height: 16, class: "rounded-circle", style: "object-fit: cover;") %>
              FR
            <% end %>
            <%= link_to url_for(locale: :en), class: "btn btn-sm public-btn-border-radius d-inline-flex align-items-center gap-2 #{I18n.locale == :en ? 'btn-light text-dark' : 'btn-outline-light'}" do %>
              <%= image_tag("/images/uk.webp", alt: "", width: 16, height: 16, class: "rounded-circle", style: "object-fit: cover;") %>
              EN
            <% end %>
          </div>
          <p class="text-light small mb-0 opacity-75">
            <%= t("public.footer.copyright", year: Time.current.year) %>
          </p>
        </div>
      </div>
    </div>
  </div>
</footer>