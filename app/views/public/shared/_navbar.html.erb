<nav class="navbar navbar-expand-xxl bg-black shadow-sm py-2">
  <div class="container-fluid ps-2 pe-3 d-flex align-items-center justify-content-between">
    <div class="d-flex align-items-center">
      <%= link_to home_path do %>
        <%= image_tag('/images/a1soirlogo2.png', class: 'navbar-logo mb-0 px-2 me-2', alt: "Autour d'un Soir") %>
      <% end %>

      <%= link_to "#{rdv_url}#rdv-form",
          class: "btn btn-sm btn-light px-3 ms-4 me-2 d-none d-xxl-flex align-items-center btn-rdv-hover public-btn-border-radius" do %>
        <i class="bi bi-calendar-check me-2"></i>
        <span class="fw-bold text-uppercase small"><%= t("public.navbar.book_appointment") %></span>
      <% end %>
    </div>

    <div class="d-flex align-items-center order-xl-2 ms-auto">
      <div class="dropdown d-none d-xxl-block me-3">
        <button class="btn btn-sm text-light dropdown-toggle public-btn-border-radius d-inline-flex align-items-center gap-2" type="button" data-bs-toggle="dropdown" aria-expanded="false">
          <%= image_tag(I18n.locale == :fr ? "/images/fr.webp" : "/images/uk.webp", alt: "", width: 18, height: 18, class: "rounded-circle", style: "object-fit: cover;") %>
          <%= I18n.locale == :fr ? "FR" : "EN" %>
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
          <li>
            <%= link_to url_for(locale: :fr), class: "dropdown-item text-dark d-flex align-items-center gap-2 #{'fw-semibold' if I18n.locale == :fr}" do %>
              <%= image_tag("/images/fr.webp", alt: "", width: 18, height: 18, class: "rounded-circle", style: "object-fit: cover;") %>
              Francais
            <% end %>
          </li>
          <li>
            <%= link_to url_for(locale: :en), class: "dropdown-item text-dark d-flex align-items-center gap-2 #{'fw-semibold' if I18n.locale == :en}" do %>
              <%= image_tag("/images/uk.webp", alt: "", width: 18, height: 18, class: "rounded-circle", style: "object-fit: cover;") %>
              English
            <% end %>
          </li>
        </ul>
      </div>
      <button class="navbar-toggler border-0 p-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbar" aria-controls="navbar" aria-expanded="false" aria-label="Toggle navigation">
        <i class="bi bi-list text-light" style="font-size: 1.75rem;"></i>
