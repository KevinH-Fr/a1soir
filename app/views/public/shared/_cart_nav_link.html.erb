<% if OnlineSales.available? %>
  <% classes = ["nav-item text-center mx-3 my-1"] %>
  <% is_active = controller_name == "pages" && action_name == "cart" %>
  <% classes << "active" if is_active %>
  <li class="<%= classes.join(" ") %>" id="cart_badge">
    <%= link_to cart_path,
        class: "text-decoration-none nav-link-public #{is_active ? "nav-link-active" : ""} position-relative d-inline-flex align-items-center justify-content-center",
        title: t("public.navbar.cart"),
        "aria-label": t("public.navbar.cart") do %>
      <span class="text-light fw-bold d-inline-flex align-items-center lh-1">
        <i class="bi bi-bag fs-4" aria-hidden="true"></i>
      </span>
      <% if @cart.present? && @cart.size.positive? %>
        <span class="position-absolute top-0 start-100 translate-middle badge rounded-circle bg-light text-dark fw-bold navbar-badge"
              aria-hidden="true">
          <%= @cart.size %>
          <span class="visually-hidden"><%= t("public.pages.cart.items_count", count: @cart.size) %></span>
        </span>
      <% end %>
    <% end %>
  </li>
<% end %>
