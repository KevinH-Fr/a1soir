<div class="row g-0">
  
  <div class="col-12 col-md-6 col-lg-6" data-scroll-reveal>
    <%= collection_card(
      title: t("public.pages.home.categories.wedding_dresses.title"),
      items: ["Courtes", "Longues"],
      url: produits_filter_url(category_names: ["robes de mariée courtes", "robes de mariée longues"]),
      image: "/images/cat_robes_mariees.webp",
      subtitle: t("public.pages.home.categories.wedding_dresses.subtitle"),
      image_position: "center 25%"
    ) %>
  </div>

  <div class="col-12 col-md-6 col-lg-6" data-scroll-reveal>
    <%= collection_card(
      title: t("public.pages.home.categories.evening_wear.title"),
      items: ["Longues", "Courtes", "Ensembles pantalon", "Combinaisons"],
      url: produits_filter_url(category_names: ["robes courtes", "robes longues", "ensembles pantalons"]),
      image: "/images/cat_tenues_soiree.webp",
      subtitle: t("public.pages.home.categories.evening_wear.subtitle"),
      image_position: "center"
    ) %>
  </div>

  <div class="col-12 col-md-6 col-lg-6" data-scroll-reveal>
    <%= collection_card(
      title: t("public.pages.home.categories.suits.title"),
      items: ["Smokings", "Cérémonies", "Enfant"],
      url: produits_filter_url(category_names: "costume"),
      image: "/images/cat_costume.webp",
      subtitle: t("public.pages.home.categories.suits.subtitle"),
      image_position: "top"
    ) %>
  </div>

  <div class="col-12 col-md-6 col-lg-6" data-scroll-reveal>
    <%= collection_card(
      title: t("public.pages.home.categories.accessories.title"),
      items: ["Chaussures Homme", "Chaussures Femmes", "Accessoires Hommes", "Accessoires Femmes"],
      url: produits_filter_url(category_names: ["chaussures", "accessoires", "accessoires femmes"]), 
      image: "/images/cat_accessoires.webp",
      subtitle: t("public.pages.home.categories.accessories.subtitle"),
      image_position: "center"
    ) %>
  </div>

</div>