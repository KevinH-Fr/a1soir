<% if @mode_periode_speciale && @encart_periode_speciale.present? %>
  <%
    variant    = local_assigns.fetch(:variant, :dark)
    bg_class   = variant == :light ? "bg-white border-bottom" : "bg-black"
    text_class = variant == :light ? "text-dark"              : "text-white"
  %>
  <div class="<%= bg_class %> <%= text_class %> overflow-hidden py-2" style="white-space: nowrap;">
    <span class="fw-semibold ticker-band">
      <i class="bi bi-info-circle me-2"></i><%= @encart_periode_speciale %>
    </span>
  </div>
  <style>
    @keyframes ticker-scroll {
      from { transform: translateX(100vw); }
      to   { transform: translateX(-100%); }
    }
    .ticker-band {
      display: inline-block;
      font-size: 1rem;
      animation: ticker-scroll 22s linear infinite;
    }
    @media (max-width: 767px) {
      .ticker-band { animation-duration: 10s; }
    }
    @media (prefers-reduced-motion: reduce) {
      .ticker-band {
        animation: none;
        display: block;
        text-align: center;
        white-space: normal;
      }
    }
  </style>
<% end %>
