<% if @mode_periode_speciale && @encart_periode_speciale.present? %>
  <%
    variant     = local_assigns.fetch(:variant, :dark)
    theme_class = variant == :light ? "floating-banner-light" : "floating-banner-dark"
  %>
  <div class="floating-banner <%= theme_class %> text-center">
    <span class="fw-bold floating-banner-text">
      <i class="bi bi-info-circle me-2 floating-banner-icon text-warning" aria-hidden="true"></i><%= @encart_periode_speciale %>
    </span>
  </div>
  <style>
    .floating-banner {
      padding: 1rem 1rem;
      overflow: hidden;
    }
    .floating-banner-dark {
      background: #000000;
      color: #ffffff;
    }
    .floating-banner-dark .floating-banner-text {
      color: #ffffff;
      text-shadow: 0 2px 10px rgba(0, 0, 0, 0.28);
    }
    .floating-banner-light {
      background: #ffffff;
      color: #141414;
    }
    .floating-banner-light .floating-banner-text {
      color: #141414;
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    }
    .floating-banner-text {
      display: inline-block;
      font-size: 1.45rem;
      line-height: 1.35;
      letter-spacing: 0.012em;
      animation: bannerFloat 2.2s ease-in-out infinite, bannerPulse 2.8s ease-in-out infinite;
    }
    .floating-banner-icon {
      font-size: 1.2em;
      vertical-align: -0.08em;
    }
    @keyframes bannerFloat {
      0%, 100% { transform: translateY(0); }
      50%      { transform: translateY(-5px); }
    }
    @keyframes bannerPulse {
      0%, 100% { opacity: 0.9; }
      50%      { opacity: 1; }
    }
    @media (max-width: 767px) {
      .floating-banner {
        padding: 0.85rem 0.75rem;
      }
      .floating-banner-text {
        font-size: 1.2rem;
        line-height: 1.3;
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .floating-banner-text {
        animation: none;
      }
    }
  </style>
<% end %>
