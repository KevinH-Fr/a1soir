<div class="floating-contact-icons">
  <%= link_to "#{rdv_url}#rdv-form",
              class: "floating-icon-btn",
              title: t("public.floating_contact_icons.book_appointment_title"),
              aria: { label: t("public.floating_contact_icons.book_appointment_aria") } do %>
    <i class="bi bi-calendar-check"></i>
  <% end %>
  
  <% if current_page?(contact_path) %>
    <%= link_to "#message-form",
                class: "floating-icon-btn",
                title: t("public.floating_contact_icons.write_title"),
                aria: { label: t("public.floating_contact_icons.write_aria") },
                data: { turbo: false },
                onclick: "document.getElementById('message-form').scrollIntoView({ behavior: 'smooth', block: 'start' })" do %>
      <i class="bi bi-envelope"></i>
    <% end %>
  <% else %>
    <%= link_to "#{contact_path}#message-form",
                class: "floating-icon-btn",
                title: t("public.floating_contact_icons.write_title"),
                aria: { label: t("public.floating_contact_icons.write_aria") },
                data: { turbo: false } do %>
      <i class="bi bi-envelope"></i>
    <% end %>
  <% end %>
  
  <%= link_to "tel:+33493451717",
              class: "floating-icon-btn",
              title: t("public.floating_contact_icons.call_title"),
              aria: { label: t("public.floating_contact_icons.call_aria") } do %>
    <i class="bi bi-telephone"></i>
    <span class="floating-phone-tooltip">+33 4 93 45 17 17</span>
  <% end %>

  <% if Chatbot.enabled? %>
    <div class="floating-chatbot-slot">
      <%= render "public/chat/conversation" %>
    </div>
  <% end %>
</div>
