<div class="floating-contact-icons">
  <%= link_to "#{rdv_url}#rdv-form",
              class: "floating-icon-btn",
              title: "Prendre rendez-vous",
              aria: { label: "Prendre rendez-vous en boutique" } do %>
    <i class="bi bi-calendar-check"></i>
  <% end %>
  
  <% if current_page?(contact_path) %>
    <%= link_to "#message-form",
                class: "floating-icon-btn",
                title: "Nous écrire",
                aria: { label: "Nous écrire via le formulaire de contact" },
                data: { turbo: false },
                onclick: "document.getElementById('message-form').scrollIntoView({ behavior: 'smooth', block: 'start' })" do %>
      <i class="bi bi-envelope"></i>
    <% end %>
  <% else %>
    <%= link_to "#{contact_path}#message-form",
                class: "floating-icon-btn",
                title: "Nous écrire",
                aria: { label: "Nous écrire via le formulaire de contact" } do %>
      <i class="bi bi-envelope"></i>
    <% end %>
  <% end %>
  
  <%= link_to "tel:+33493451717",
              class: "floating-icon-btn",
              title: "Nous appeler",
              aria: { label: "Nous appeler au +33 4 93 45 17 17" } do %>
    <i class="bi bi-telephone"></i>
    <span class="floating-phone-tooltip">+33 4 93 45 17 17</span>
  <% end %>
</div>
