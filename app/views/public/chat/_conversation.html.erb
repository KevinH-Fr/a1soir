<div
  class="floating-chatbot"
  data-controller="chat"
  data-chat-user-label-value="<%= t("public.chat.role_user") %>"
  data-chat-assistant-label-value="<%= t("public.chat.role_assistant") %>"
  data-chat-reset-success-value="<%= t("public.chat.reset_success") %>"
>
  <div id="chatbot-toggle-wrapper">
    <button
      id="chatbot-toggle"
      type="button"
      class="floating-icon-btn floating-icon-btn--chatbot"
      data-action="click->chat#toggle"
      title="<%= t("public.floating_contact_icons.chatbot_title") %>"
      aria-label="<%= t("public.floating_contact_icons.chatbot_aria") %>"
    >
      <i class="bi bi-chat-dots-fill" aria-hidden="true"></i>
      <span class="floating-chatbot-tooltip"><%= t("public.floating_contact_icons.chatbot_hover_label") %></span>
    </button>
  </div>

  <div
    id="chatBox"
    class="chatbox chatbox--floating chatbox-panel d-flex flex-column"
    data-chat-target="box"
    role="region"
    aria-label="<%= t("public.floating_contact_icons.chatbot_title") %>"
  >
    <header class="chatbox-header">
      <div class="chatbox-header__brand">
        <%= image_tag("/images/logo_courant_public.png", class: "chatbox-header__logo", alt: "") %>
      </div>
      <p class="chatbox-header__tagline"><%= t("public.chat.tagline") %></p>
      <div class="chatbox-header__actions">
        <a
          href="/fr/contact#message-form"
          class="chatbox-header__action-btn"
          target="_blank"
          rel="noopener noreferrer"
        >
          <i class="bi bi-envelope-at" aria-hidden="true"></i>
          <span><%= t("public.chat.contact_team") %></span>
        </a>
        <button
          type="button"
          class="chatbox-header__action-btn chatbox-header__action-btn--ghost"
          data-action="click->chat#resetConversation"
        >
          <i class="bi bi-arrow-clockwise" aria-hidden="true"></i>
          <span><%= t("public.chat.reset_label") %></span>
        </button>
      </div>
    </header>

    <div
      class="chatbox-messages"
      data-chat-target="messages"
      role="log"
      aria-live="polite"
    ></div>

    <footer class="chatbox-footer">
      <form class="chatbox-form" data-action="submit->chat#send">
        <div class="chatbox-form__row">
          <label class="visually-hidden" for="chatbot-message-input"><%= t("public.chat.input_placeholder") %></label>
          <input
            id="chatbot-message-input"
            type="text"
            autocomplete="off"
            data-chat-target="input"
            class="form-control chatbox-input"
            placeholder="<%= t("public.chat.input_placeholder") %>"
          />
          <button type="submit" class="btn chatbox-send" aria-label="<%= t("public.chat.send_aria") %>">
            <i class="bi bi-send-fill" aria-hidden="true"></i>
          </button>
        </div>
      </form>
    </footer>
  </div>
</div>
