<% content_for :structured_data do %>
  <script type="application/ld+json">
    <%= webpage_schema(
          name: meta_title,
          description: meta_description,
          url: public_page_url
        ).to_json.html_safe %>
  </script>
<% end %>

<div class="public-main-content seo-guides-hub">
  <header class="text-center my-5 px-3" data-scroll-reveal>
    <div class="section-title-wrapper mb-4">
      <h1 class="text-light section-title mb-0" style="font-family: 'Playfair Display', serif; font-size: clamp(2rem, 4vw, 2.75rem);">
        <%= t("public.seo_pages.hub.title") %>
        <span class="section-title-underline" style="background: rgba(255, 248, 220, 0.85);"></span>
      </h1>
    </div>
    <p class="text-light opacity-75 mx-auto mb-0 seo-guides-hub-intro">
      <%= t("public.seo_pages.hub.intro") %>
    </p>
  </header>

  <% seo_hub_groups_sorted(@pages_by_group).each do |group, pages| %>
    <section id="<%= group %>" class="container seo-guides-hub-section py-4 py-md-5" data-scroll-reveal>
      <div class="seo-hub-section-header mb-4 mb-md-5">
        <span class="seo-hub-section-icon" aria-hidden="true">
          <i class="bi bi-<%= seo_hub_group_icon(group) %>"></i>
        </span>
        <h2 class="seo-hub-section-title mb-0"><%= t("public.seo_pages.hub.groups.#{group}") %></h2>
      </div>

      <div class="row g-4">
        <% pages.each do |page| %>
          <div class="col-12 col-md-6 col-xl-4">
            <%= render "public/seo_pages/hub_card", page: page, group: group %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
