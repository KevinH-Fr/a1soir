<% content_for :structured_data do %>
  <script type="application/ld+json">
    <%= webpage_schema(
          name: meta_title,
          description: meta_description,
          url: request.original_url
        ).to_json.html_safe %>
  </script>
<% end %>

<%= page_header(t("public.pages.faq.header_title"), t("public.pages.faq.header_subtitle"),
image1: "https://res.cloudinary.com/dukne3lhz/image/upload/q_auto,f_auto,w_1920/faq1_fp6utw",
image2: "https://res.cloudinary.com/dukne3lhz/image/upload/q_auto,f_auto,w_1920/faq2_yarmzv") %>

<div class="public-main-content">
  <div class="container-fluid">
    <div class="row justify-content-center">
      <div class="col-lg-10">
        <!-- Introduction -->
        <div class="text-center my-5 px-3" data-scroll-reveal>
          <p class="lead text-light opacity-75">
            <%= t("public.pages.faq.intro") %>
          </p>
        </div>

        <!-- Navigation rapide -->
        <%= quick_nav_links(links: [
          { url: "#general", text: t("public.pages.faq.nav.general") },
          { url: "#location", text: t("public.pages.faq.nav.location") },
          { url: "#vente", text: t("public.pages.faq.nav.sale") },
          { url: "#retouches", text: t("public.pages.faq.nav.alterations") },
          { url: "#livraison", text: t("public.pages.faq.nav.delivery") },
          { url: "#paiement", text: t("public.pages.faq.nav.payment") }
        ]) %>

        <!-- Questions Générales -->
        <%= content_section(id: "general", icon: "question-circle", title: t("public.pages.faq.sections.general.title"), accordion_id: "accordionGeneral") do %>
          <%= collapsible_item(id: "general1", parent_id: "accordionGeneral", title: t("public.pages.faq.sections.general.q1.question"), expanded: true) do %>
            <%= t("public.pages.faq.sections.general.q1.answer_html", contact_link: link_to(t("public.pages.faq.sections.general.q1.contact_form"), "#{contact_path}#message-form"), address: @texteAdresse, hours: @texteHoraire, phone: @texteContact).html_safe %>
          <% end %>

          <%= collapsible_item(id: "general2", parent_id: "accordionGeneral", title: t("public.pages.faq.sections.general.q2.question")) do %>
            <%= t("public.pages.faq.sections.general.q2.answer_html").html_safe %>
          <% end %>

          <%= collapsible_item(id: "general3", parent_id: "accordionGeneral", title: t("public.pages.faq.sections.general.q3.question")) do %>
            <%= t("public.pages.faq.sections.general.q3.answer_html").html_safe %>
          <% end %>

          <%= collapsible_item(id: "general4", parent_id: "accordionGeneral", title: t("public.pages.faq.sections.general.q4.question")) do %>
            <%= t("public.pages.faq.sections.general.q4.answer_html").html_safe %>
          <% end %>

          <%= collapsible_item(id: "general5", parent_id: "accordionGeneral", title: t("public.pages.faq.sections.general.q5.question")) do %>
            <%= t("public.pages.faq.sections.general.q5.answer_html").html_safe %>
          <% end %>
        <% end %>

        <!-- Questions sur la Location -->
        <%= content_section(id: "location", icon: "calendar-check", title: t("public.pages.faq.sections.location.title"), accordion_id: "accordionLocation") do %>
          <%= collapsible_item(id: "location1", parent_id: "accordionLocation", title: t("public.pages.faq.sections.location.q1.question"), expanded: true) do %>
            <%= t("public.pages.faq.sections.location.q1.answer_html").html_safe %>
          <% end %>

          <%= collapsible_item(id: "location2", parent_id: "accordionLocation", title: t("public.pages.faq.sections.location.q2.question")) do %>
            <%= t("public.pages.faq.sections.location.q2.answer_html").html_safe %>
          <% end %>

          <%= collapsible_item(id: "location3", parent_id: "accordionLocation", title: t("public.pages.faq.sections.location.q3.question")) do %>
            <%= t("public.pages.faq.sections.location.q3.answer_html").html_safe %>
          <% end %>

          <%= collapsible_item(id: "location4", parent_id: "accordionLocation", title: t("public.pages.faq.sections.location.q4.question")) do %>
            <%= t("public.pages.faq.sections.location.q4.answer_html").html_safe %>
          <% end %>

          <%= collapsible_item(id: "location5", parent_id: "accordionLocation", title: t("public.pages.faq.sections.location.q5.question")) do %>
            <%= t("public.pages.faq.sections.location.q5.answer_html").html_safe %>
          <% end %>

          <%= collapsible_item(id: "location6", parent_id: "accordionLocation", title: t("public.pages.faq.sections.location.q6.question")) do %>
            <%= t("public.pages.faq.sections.location.q6.answer_html").html_safe %>
          <% end %>

          <%= collapsible_item(id: "location7", parent_id: "accordionLocation", title: t("public.pages.faq.sections.location.q7.question")) do %>
            <%= t("public.pages.faq.sections.location.q7.answer_html").html_safe %>
          <% end %>



        <% end %>

        <!-- Questions sur la Vente -->
        <%= content_section(id: "vente", icon: "bag-check", title: t("public.pages.faq.sections.sale.title"), accordion_id: "accordionVente") do %>
          <%= collapsible_item(id: "vente1", parent_id: "accordionVente", title: t("public.pages.faq.sections.sale.q1.question"), expanded: true) do %>
            <%= t("public.pages.faq.sections.sale.q1.answer_html").html_safe %>
          <% end %>

          <%= collapsible_item(id: "vente2", parent_id: "accordionVente", title: t("public.pages.faq.sections.sale.q2.question")) do %>
            <%= t("public.pages.faq.sections.sale.q2.answer_html").html_safe %>
          <% end %>

          <%= collapsible_item(id: "vente3", parent_id: "accordionVente", title: t("public.pages.faq.sections.sale.q3.question")) do %>
            <%= t("public.pages.faq.sections.sale.q3.answer_html").html_safe %>
          <% end %>
        <% end %>

        <!-- Questions sur les Retouches -->
        <%= content_section(id: "retouches", icon: "scissors", title: t("public.pages.faq.sections.alterations.title"), accordion_id: "accordionRetouches") do %>
          <%= collapsible_item(id: "retouches1", parent_id: "accordionRetouches", title: t("public.pages.faq.sections.alterations.q1.question"), expanded: true) do %>
            <%= t("public.pages.faq.sections.alterations.q1.answer_html").html_safe %>
          <% end %>

          <%= collapsible_item(id: "retouches-incluses-vente", parent_id: "accordionRetouches", title: t("public.pages.faq.sections.alterations.q2.question")) do %>
            <%= t("public.pages.faq.sections.alterations.q2.answer_html").html_safe %>
          <% end %>


          <%= collapsible_item(id: "retouches2", parent_id: "accordionRetouches", title: t("public.pages.faq.sections.alterations.q3.question")) do %>
            <%= t("public.pages.faq.sections.alterations.q3.answer_html").html_safe %>
          <% end %>

          <%= collapsible_item(id: "retouches3", parent_id: "accordionRetouches", title: t("public.pages.faq.sections.alterations.q4.question")) do %>
            <%= t("public.pages.faq.sections.alterations.q4.answer_html").html_safe %>
          <% end %>

          <%= collapsible_item(id: "retouches-autres-produits", parent_id: "accordionRetouches", title: t("public.pages.faq.sections.alterations.q5.question")) do %>
            <%= t("public.pages.faq.sections.alterations.q5.answer_html").html_safe %>
          <% end %>
        <% end %>

        <!-- Questions sur la Livraison -->
        <%= content_section(id: "livraison", icon: "truck", title: t("public.pages.faq.sections.delivery.title"), accordion_id: "accordionLivraison") do %>
          <%= collapsible_item(id: "livraison1", parent_id: "accordionLivraison", title: t("public.pages.faq.sections.delivery.q1.question"), expanded: true) do %>
            <%= t("public.pages.faq.sections.delivery.q1.answer_html").html_safe %>
          <% end %>

          <%= collapsible_item(id: "livraison2", parent_id: "accordionLivraison", title: t("public.pages.faq.sections.delivery.q2.question")) do %>
            <%= t("public.pages.faq.sections.delivery.q2.answer_html").html_safe %>
          <% end %>
        <% end %>

        <!-- Questions sur le Paiement -->
        <%= content_section(id: "paiement", icon: "credit-card", title: t("public.pages.faq.sections.payment.title"), accordion_id: "accordionPaiement") do %>
          <%= collapsible_item(id: "paiement1", parent_id: "accordionPaiement", title: t("public.pages.faq.sections.payment.q1.question"), expanded: true) do %>
            <%= t("public.pages.faq.sections.payment.q1.answer_html").html_safe %>
          <% end %>

          <%= collapsible_item(id: "paiement2", parent_id: "accordionPaiement", title: t("public.pages.faq.sections.payment.q2.question")) do %>
            <%= t("public.pages.faq.sections.payment.q2.answer_html").html_safe %>
          <% end %>

          <%= collapsible_item(id: "paiement3", parent_id: "accordionPaiement", title: t("public.pages.faq.sections.payment.q3.question")) do %>
            <%= t("public.pages.faq.sections.payment.q3.answer_html").html_safe %>
          <% end %>
        <% end %>


        <!-- CTA Contact -->
        <div class="my-5 py-5" data-scroll-reveal>
          <div class="concept-card text-center text-light">
            <i class="bi bi-chat-dots fs-1 mb-3 d-block"></i>
            <h3 class="mb-3"><%= t("public.pages.faq.cta.title") %></h3>
            <p class="lead mb-4 opacity-75">
              <%= t("public.pages.faq.cta.description") %>
            </p>
            <div class="d-flex gap-3 justify-content-center flex-wrap">
            <%= link_to "#{contact_path}#message-form", class: "btn btn-light btn-lg px-4 public-btn-border-radius" do %>
                <i class="bi bi-envelope me-2"></i><%= t("public.pages.faq.cta.contact_button") %>
              <% end %>
              <a href="tel:+493451717" class="btn btn-outline-light btn-lg px-5 public-btn-border-radius" title="<%= t("public.pages.faq.cta.call_button") %>">
                <i class="bi bi-telephone me-2"></i><%= t("public.pages.faq.cta.call_button") %>
              </a>
            </div>
          </div>
        </div>

        <!-- Retour en haut -->
        <div class="text-center my-4">
          <a href="#top" class="btn btn-outline-light">
            <i class="bi bi-arrow-up me-2"></i><%= t("public.pages.faq.back_to_top") %>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
