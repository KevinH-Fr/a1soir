<div class="col" style="width: 22rem;">
  <div class="card rounded-0 bg-dark text-light border-dark">
    <%= link_to produit_path(slug: produit.handle, id: produit.id, back_url: produits_back_url), class: "text-decoration-none position-relative", data: { turbo: false } do %>
      <% if produit.en_promotion? %>
        <span class="position-absolute top-0 start-0 m-2 rounded-0 badge bg-dark bg-opacity-75 text-light p-2 promotion-badge">
          PROMOTION
        </span>
      <% end %>
      <%= render partial: "public/pages/carousel", locals: { produit: produit, carousel_class: "card-img-top carousel-multiple" } %>
    <% end %>

    <div class="card-body">
      <%= link_to produit_path(slug: produit.handle, id: produit.id, back_url: produits_back_url), class: "text-decoration-none", data: { turbo: false } do %>
        <h3 class="h5 card-title text-light text-truncate">
          <%= produit.nom %>
        </h3>
      <% end %>

      <p class="card-text d-flex justify-content-between m-0">
        <%= badge_prix(:sale, produit.prixvente, produit) %>
        <%= badge_prix(:rental, produit.prixlocation) if produit.prixlocation.present? %>
      </p>

      <p class="card-text d-flex justify-content-between">
        <% if params[:taille].present? %>
          <%= badge_taille(produit) %>
        <% else %>
          <span></span>
        <% end %>
      </p>

      <% if session[:from_cabine] %>
        <%= render partial: "public/pages/cart_buttons/cabine_product_button", locals: { produit: produit } %>
      <% elsif OnlineSales.available? && produit.eshop? && produit.stripe_price_id.present? %>
        <%= render partial: "public/pages/cart_buttons/shop_product_button", locals: { produit: produit } %>
      <% end %>
    </div>
  </div>
</div>
