<% content_for :structured_data do %>
  <script type="application/ld+json">
    <%= webpage_schema(
          name: meta_title,
          description: meta_description,
          url: request.original_url
        ).to_json.html_safe %>
  </script>
<% end %>

<%= page_header(
    t("public.pages.rdv.header_title"),
    t("public.pages.rdv.header_subtitle"),
    image1: "https://res.cloudinary.com/dukne3lhz/image/upload/q_auto,f_auto,w_1920/rdv1_lzzo5t",
    image2: "https://res.cloudinary.com/dukne3lhz/image/upload/q_auto,f_auto,w_1920/rdv2_uoyzrm") %>



<div class="public-main-content">
  <%= render "public/shared/recaptcha_script" %>
  <div class="container-fluid">
    <div class="row g-4 my-5 bg-white">
      <!-- Process à gauche -->
      <div class="col-12 col-lg-6 d-flex align-items-center p-4" data-scroll-reveal>
        <div class="w-100">
          <div class="d-flex flex-column gap-4">
            <div class="d-flex align-items-start gap-3">
              <div class="concept-card-icon text-dark flex-shrink-0 bg-light">
                <i class="bi bi-calendar-check fs-2"></i>
              </div>
              <div>
                <h5 class="fw-bold mb-2 text-dark"><%= t("public.pages.rdv.steps.reservation.title") %></h5>
                <p class="text-dark opacity-75 small mb-0">
                  <%= t("public.pages.rdv.steps.reservation.description") %>
                </p>
              </div>
            </div>
            <div class="d-flex align-items-start gap-3">
              <div class="concept-card-icon text-dark flex-shrink-0 bg-light">
                <i class="bi bi-bell fs-2"></i>
              </div>
              <div>
                <h5 class="fw-bold mb-2 text-dark"><%= t("public.pages.rdv.steps.confirmation.title") %></h5>
                <p class="text-dark opacity-75 small mb-0">
                  <%= t("public.pages.rdv.steps.confirmation.description") %>
                </p>
              </div>
            </div>
            <div class="d-flex align-items-start gap-3">
              <div class="concept-card-icon text-dark flex-shrink-0 bg-light">
                <i class="bi bi-star-fill fs-2"></i>
              </div>
              <div>
                <h5 class="fw-bold mb-2 text-dark"><%= t("public.pages.rdv.steps.fitting.title") %></h5>
                <p class="text-dark opacity-75 small mb-0">
                  <%= t("public.pages.rdv.steps.fitting.description") %>
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Formulaire à droite -->
      <div class="col-12 col-lg-6">
        <div id="rdv-form" class="p-2 bg-white d-flex flex-column" style="min-height: 500px;">
          <div style="position: relative; z-index: 1; flex: 1; display: flex; flex-direction: column;">
            <%= render "public/demande_rdv/form", demande_rdv: @demande_rdv || DemandeRdv.new, from_cabine: false %>
          </div>
        </div>
      </div>
    </div>
  </div>
  
</div>
