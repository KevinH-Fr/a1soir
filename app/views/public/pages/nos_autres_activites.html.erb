<% content_for :structured_data do %>
  <script type="application/ld+json">
    <%= webpage_schema(
          name: meta_title,
          description: meta_description,
          url: request.original_url
        ).to_json.html_safe %>
  </script>
<% end %>

<%= page_header(
  t("public.pages.nos_autres_activites.header_title"),
  t("public.pages.nos_autres_activites.header_subtitle"),
  image1: "https://res.cloudinary.com/dukne3lhz/image/upload/q_auto,f_auto,w_1920/autres_activites1_n4ldap",
  image2: "https://res.cloudinary.com/dukne3lhz/image/upload/q_auto,f_auto,w_1920/autres_activites2_vhynvk"
) %>


<div class="public-main-content">
  <div class="container-fluid">
    <!-- Introduction -->
    <%= render partial: "public/shared/section_image_text", locals: {
      title: t("public.pages.nos_autres_activites.introduction.title"),
      image_path: "https://res.cloudinary.com/dukne3lhz/image/upload/q_auto,f_auto,w_1600/tournage_fsteud",
      description: t("public.pages.nos_autres_activites.introduction.description"),
      features: [
        t("public.pages.nos_autres_activites.introduction.features.1"),
        t("public.pages.nos_autres_activites.introduction.features.2"),
        t("public.pages.nos_autres_activites.introduction.features.3")
      ]
    } %>

    <!-- Activités principales -->
    <div class="row g-4 my-5 p-3 bg-white align-items-stretch">
      <!-- Costumes d'époque -->
      <div class="col-lg-6 d-flex" data-scroll-reveal>
        <%= public_card(
          icon: "clock-history",
          title: t("public.pages.nos_autres_activites.epoch_costumes.title"),
          description: t("public.pages.nos_autres_activites.epoch_costumes.description"),
          theme: "light",
          card_style: "activity"
        ) do %>
          <h5 class="fw-bold mb-3 mt-4 text-light"><%= t("public.pages.nos_autres_activites.epoch_costumes.periods_title") %></h5>
          <div class="row g-3">
            <div class="col-md-6">
              <ul class="list-unstyled">
                <li class="mb-2"><i class="bi bi-star-fill me-2"></i><%= t("public.pages.nos_autres_activites.epoch_costumes.periods.1") %></li>
                <li class="mb-2"><i class="bi bi-star-fill me-2"></i><%= t("public.pages.nos_autres_activites.epoch_costumes.periods.2") %></li>
                <li class="mb-2"><i class="bi bi-star-fill me-2"></i><%= t("public.pages.nos_autres_activites.epoch_costumes.periods.3") %></li>
                <li class="mb-2"><i class="bi bi-star-fill me-2"></i><%= t("public.pages.nos_autres_activites.epoch_costumes.periods.4") %></li>
              </ul>
            </div>
            <div class="col-md-6">
              <ul class="list-unstyled">
                <li class="mb-2"><i class="bi bi-star-fill me-2"></i><%= t("public.pages.nos_autres_activites.epoch_costumes.periods.5") %></li>
                <li class="mb-2"><i class="bi bi-star-fill me-2"></i><%= t("public.pages.nos_autres_activites.epoch_costumes.periods.6") %></li>
                <li class="mb-2"><i class="bi bi-star-fill me-2"></i><%= t("public.pages.nos_autres_activites.epoch_costumes.periods.7") %></li>
                <li class="mb-2"><i class="bi bi-star-fill me-2"></i><%= t("public.pages.nos_autres_activites.epoch_costumes.periods.8") %></li>
              </ul>
            </div>
          </div>

          <div class="mt-4 mb-0">
            <i class="bi bi-info-circle me-2"></i>
            <small class=""><%= t("public.pages.nos_autres_activites.epoch_costumes.ideal_for") %></small>
          </div>
        <% end %>
      </div>

      <!-- Prestations entreprises -->
      <div class="col-lg-6 d-flex" data-scroll-reveal>
        <%= public_card(
          icon: "buildings",
          title: t("public.pages.nos_autres_activites.business_services.title"),
          description: t("public.pages.nos_autres_activites.business_services.description"),
          theme: "light",
          card_style: "activity"
        ) do %>
          <h5 class="fw-bold mb-3 mt-4"><%= t("public.pages.nos_autres_activites.business_services.services_title") %></h5>
          <ul class="list-unstyled mb-4">
            <li class="mb-3">
              <div class="d-flex">
                <i class="bi bi-briefcase-fill me-3 mt-1"></i>
                <div>
                  <strong><%= t("public.pages.nos_autres_activites.business_services.items.corporate_events.title") %></strong>
                  <p class="text-light opacity-75 mb-0 small"><%= t("public.pages.nos_autres_activites.business_services.items.corporate_events.description") %></p>
                </div>
              </div>
            </li>
            <li class="mb-3">
              <div class="d-flex">
                <i class="bi bi-people-fill me-3 mt-1"></i>
                <div>
                  <strong><%= t("public.pages.nos_autres_activites.business_services.items.groups_associations.title") %></strong>
                  <p class="opacity-75 mb-0 small"><%= t("public.pages.nos_autres_activites.business_services.items.groups_associations.description") %></p>
                </div>
              </div>
            </li>
            <li class="mb-3">
              <div class="d-flex">
                <i class="bi bi-camera-reels-fill me-3 mt-1"></i>
                <div>
                  <strong><%= t("public.pages.nos_autres_activites.business_services.items.audiovisual_productions.title") %></strong>
                  <p class="opacity-75 mb-0 small"><%= t("public.pages.nos_autres_activites.business_services.items.audiovisual_productions.description") %></p>
                </div>
              </div>
            </li>
            <li class="mb-3">
              <div class="d-flex">
                <i class="bi bi-calendar-event-fill me-3 mt-1"></i>
                <div>
                  <strong><%= t("public.pages.nos_autres_activites.business_services.items.events.title") %></strong>
                  <p class="opacity-75 mb-0 small"><%= t("public.pages.nos_autres_activites.business_services.items.events.description") %></p>
                </div>
              </div>
            </li>
          </ul>

          <div class="mt-4 mb-0">
            <i class="bi bi-gift me-2"></i>
            <small class=""><%= t("public.pages.nos_autres_activites.business_services.benefits") %></small>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Nos avantages -->
    <div class="bg-black text-light my-5 py-5" data-scroll-reveal>
      <div class="container">
        <h2 class="text-center mb-5 fw-bold"><%= t("public.pages.nos_autres_activites.why_choose_us.title") %></h2>
        <div class="row g-4">
          <div class="col-md-3 text-center">
            <div class="mb-3">
              <i class="bi bi-award-fill fs-1"></i>
            </div>
            <h5 class="fw-bold mb-2"><%= t("public.pages.nos_autres_activites.why_choose_us.items.expertise.title") %></h5>
            <p class="text-light opacity-75 small"><%= t("public.pages.nos_autres_activites.why_choose_us.items.expertise.description") %></p>
          </div>
          <div class="col-md-3 text-center">
            <div class="mb-3">
              <i class="bi bi-box-seam fs-1"></i>
            </div>
            <h5 class="fw-bold mb-2"><%= t("public.pages.nos_autres_activites.why_choose_us.items.large_stock.title") %></h5>
            <p class="text-light opacity-75 small"><%= t("public.pages.nos_autres_activites.why_choose_us.items.large_stock.description") %></p>
          </div>
          <div class="col-md-3 text-center">
            <div class="mb-3">
              <i class="bi bi-lightning-charge-fill fs-1"></i>
            </div>
            <h5 class="fw-bold mb-2"><%= t("public.pages.nos_autres_activites.why_choose_us.items.reactivity.title") %></h5>
            <p class="text-light opacity-75 small"><%= t("public.pages.nos_autres_activites.why_choose_us.items.reactivity.description") %></p>
          </div>
          <div class="col-md-3 text-center">
            <div class="mb-3">
              <i class="bi bi-calculator fs-1"></i>
            </div>
            <h5 class="fw-bold mb-2"><%= t("public.pages.nos_autres_activites.why_choose_us.items.group_rates.title") %></h5>
            <p class="text-light opacity-75 small"><%= t("public.pages.nos_autres_activites.why_choose_us.items.group_rates.description") %></p>
          </div>
        </div>
      </div>
    </div>

  <%= render partial: "public/pages/nos_autres_activites/section_references" %>


    <!-- Call to action -->
    <div class="bg-white text-dark text-center my-5 py-5" data-scroll-reveal>
        <h3 class="mb-4"><%= t("public.pages.nos_autres_activites.cta.title") %></h3>
        <p class="lead mb-4 opacity-75">
          <%= t("public.pages.nos_autres_activites.cta.description") %>
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
          <%= cta_button(type: "ecrire", url: "#{contact_path}#message-form", variant: "dark") %>
          <%= cta_button(type: "appeler", url: "tel:+33 4 93 45 17 17", variant: "dark", outline: "dark") %>
        </div>
    </div>
  </div>
</div>
