<div class="table-responsive mt-4" style="max-width: 480px;">
  <table class="table table-sm table-dark mb-0" style="background: transparent; border-color: rgba(255,255,255,0.12);">
    <thead>
      <tr style="border-color: rgba(255,255,255,0.2);">
        <th class="text-white-50 fw-semibold small text-uppercase py-2" style="background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.15);">
          <%= t("public.pages.legal.shipping_table.weight_min") %>
        </th>
        <th class="text-white-50 fw-semibold small text-uppercase py-2" style="background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.15);">
          <%= t("public.pages.legal.shipping_table.weight_max") %>
        </th>
        <th class="text-white-50 fw-semibold small text-uppercase py-2" style="background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.15);">
          <%= t("public.pages.legal.shipping_table.shipping_fee") %>
        </th>
      </tr>
    </thead>
    <tbody>
      <% prev_max = 0 %>
      <% ShippingCostService::SHIPPING_TIERS.each do |max_g, cents| %>
        <tr style="border-color: rgba(255,255,255,0.07);">
          <td class="text-light py-1 small" style="background: transparent; border-color: rgba(255,255,255,0.07);">
            <%= prev_max == 0 ? "0 g" : "#{prev_max + 1} g" %>
          </td>
          <td class="text-light py-1 small" style="background: transparent; border-color: rgba(255,255,255,0.07);">
            <%= "#{max_g} g" %>
          </td>
          <td class="text-white fw-semibold py-1 small" style="background: transparent; border-color: rgba(255,255,255,0.07);">
            <%= "#{cents / 100} €" %>
          </td>
        </tr>
        <% prev_max = max_g %>
      <% end %>
    </tbody>
  </table>
</div>
