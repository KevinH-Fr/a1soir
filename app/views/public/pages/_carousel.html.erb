<% carousel_id = "carouselProduit_#{produit.id}" %>
<% container_id = "carouselContainer_#{produit.id}" %>

<div id="<%= container_id %>">
  <div id="<%= carousel_id %>" class="carousel slide" data-controller="carousel">
    <div class="carousel-inner <%= carousel_class %> rounded-0 overflow-hidden">
      <% slide_index = 0 %>
      
      <% if produit.video1.attached? %>
        <div class="carousel-item active" style="cursor: pointer;" role="button" data-bs-toggle="modal" data-bs-target="#modalProduit_<%= produit.id %>">
          <video autoplay loop muted playsinline class="d-block w-100"
          src="<%= cloudinary_video_url(produit.video1) %>">
            <track kind="captions" src="" label="Français" srclang="fr" default>
            Votre navigateur ne prend pas en charge la lecture de vidéos.
          </video>
        </div>
        <% slide_index += 1 %>
        <div class="carousel-item">
          <%= image_tag(produit.default_image_white, class: "d-block w-100 rounded-0", alt: produit.nom, loading: "lazy", width: 800, height: 600, style: "cursor: pointer;", role: "button", data: { bs_toggle: "modal", bs_target: "#modalProduit_#{produit.id}" }) %>
        </div>
        <% slide_index += 1 %>
      <% else %>
        <div class="carousel-item active">
          <%= image_tag(produit.default_image_white, class: "d-block w-100", alt: produit.nom, width: 800, height: 600, style: "cursor: pointer;", role: "button", data: { bs_toggle: "modal", bs_target: "#modalProduit_#{produit.id}" }) %>
        </div>
        <% slide_index += 1 %>
      <% end %>

      <% if produit.images %>
        <% produit.images.each_with_index do |image, img_index| %>
          <div class="carousel-item">
            <%= cloudinary_attachment_image(image, width: 800, height: 600, alt: produit.nom, loading: "lazy", class: "d-block w-100", style: "cursor: pointer;", role: "button", data: { bs_toggle: "modal", bs_target: "#modalProduit_#{produit.id}", gallery_index: img_index }) %>
          </div>
          <% slide_index += 1 %>
        <% end %>
      <% end %>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#<%= carousel_id %>" data-bs-slide="prev" style="filter: invert(1);" aria-label="Image précédente">
      <span class="carousel-control-prev-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Image précédente</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#<%= carousel_id %>" data-bs-slide="next" style="filter: invert(1);" aria-label="Image suivante">
      <span class="carousel-control-next-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Image suivante</span>
    </button>
  </div>

  <%= render partial: "carousel_thumbnails", locals: { produit: produit, carousel_id: carousel_id, total_slides: slide_index, show_thumbnails: local_assigns[:show_thumbnails] || false } %>
</div>