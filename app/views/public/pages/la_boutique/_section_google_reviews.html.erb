<% if @google_data.present? %>
  <!-- Avis Google -->
  <section class="my-5 py-5" data-scroll-reveal>
    <div class="container">

      <!-- Titre -->
      <div class="section-title-wrapper mb-5 text-center" data-aos="title-underline">
        <h2 class="section-title text-light d-inline-block" style="font-family: 'Playfair Display', serif; font-size: 2.5rem; position: relative;">
          <%= t("public.pages.la_boutique.google_reviews.title") %>
          <span class="section-title-underline" style="background: white;"></span>
        </h2>
      </div>

      <!-- Note globale -->
      <div class="text-center mb-5" data-scroll-reveal>
        <div class="d-inline-flex flex-column align-items-center gap-2 p-4 rounded-1" style="background: rgba(255,255,255,0.06);">
          <div class="d-flex align-items-baseline gap-2">
            <span class="text-light fw-bold" style="font-size: 3.5rem; line-height: 1; font-family: 'Playfair Display', serif;">
              <%= @google_data[:rating]&.to_f&.round(1) %>
            </span>
            <span class="text-light opacity-50" style="font-size: 1.1rem;">/&nbsp;5</span>
          </div>
          <div class="d-flex gap-1">
            <% rating = @google_data[:rating]&.to_f || 0 %>
            <% 5.times do |i| %>
              <% if i < rating.floor %>
                <i class="bi bi-star-fill text-warning"></i>
              <% elsif i < rating && (rating - rating.floor) >= 0.4 %>
                <i class="bi bi-star-half text-warning"></i>
              <% else %>
                <i class="bi bi-star text-warning opacity-50"></i>
              <% end %>
            <% end %>
          </div>
          <p class="text-light opacity-75 mb-0" style="font-size: 0.95rem;">
            <%= t("public.pages.la_boutique.google_reviews.based_on", count: @google_data[:user_rating_count]) %>
          </p>
          <!-- Attribution Google (obligatoire CGU) -->
          <div class="d-flex align-items-center gap-2 mt-1 opacity-75">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            <span class="text-light" style="font-size: 0.8rem;">Google</span>
          </div>
        </div>
      </div>

      <!-- Cartes d'avis -->
      <% if @google_data[:reviews].any? %>
        <div class="row g-4 justify-content-center mb-5">
          <% @google_data[:reviews].each do |review| %>
            <div class="col-12 col-md-6 col-lg-4" data-scroll-reveal>
              <div class="h-100 p-4 rounded-1 d-flex flex-column gap-3" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);">

                <!-- Auteur -->
                <div class="d-flex align-items-center gap-3">
                  <% first_letter = review[:author_name].to_s.strip.first&.upcase %>
                  <% first_letter = "?" if first_letter.blank? %>
                  <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 position-relative overflow-hidden" style="width:40px; height:40px; background: rgba(255,255,255,0.15);">
                    <% if review[:author_photo].present? %>
                      <%= image_tag(
                            review[:author_photo],
                            alt: "",
                            width: 40,
                            height: 40,
                            class: "rounded-circle position-absolute top-0 start-0 w-100 h-100",
                            style: "object-fit: cover;",
                            onerror: "this.style.display='none'; this.nextElementSibling.classList.remove('d-none');"
                          ) %>
                      <span class="text-light fw-semibold position-relative d-none" style="font-size: 0.9rem; letter-spacing: 0.01em;"><%= first_letter %></span>
                    <% else %>
                      <span class="text-light fw-semibold position-relative" style="font-size: 0.9rem; letter-spacing: 0.01em;"><%= first_letter %></span>
                    <% end %>
                  </div>
                  <div>
                    <% if review[:author_uri].present? %>
                      <%= link_to review[:author_name], review[:author_uri], target: "_blank", rel: "noopener noreferrer", class: "text-light fw-semibold text-decoration-none", style: "font-size: 0.95rem;" %>
                    <% else %>
                      <span class="text-light fw-semibold" style="font-size: 0.95rem;"><%= review[:author_name] %></span>
                    <% end %>
                    <p class="text-light opacity-50 mb-0" style="font-size: 0.8rem;"><%= review[:relative_time] %></p>
                  </div>
                </div>

                <!-- Étoiles -->
                <div class="d-flex gap-1">
                  <% (review[:rating] || 0).times do %>
                    <i class="bi bi-star-fill text-warning" style="font-size: 0.85rem;"></i>
                  <% end %>
                  <% (5 - (review[:rating] || 0)).times do %>
                    <i class="bi bi-star text-warning opacity-40" style="font-size: 0.85rem;"></i>
                  <% end %>
                </div>

                <!-- Texte de l'avis -->
                <% if review[:text].present? %>
                  <p class="text-light opacity-80 mb-0 flex-grow-1" style="font-size: 0.92rem; line-height: 1.6;">
                    <%= truncate(review[:text], length: 220, omission: "…") %>
                  </p>
                <% end %>

              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <!-- Lien vers tous les avis (obligatoire CGU Google) -->
      <div class="text-center">
        <%= link_to @google_data[:google_maps_uri], target: "_blank", rel: "noopener noreferrer", class: "btn public-btn-border-radius btn-outline-light" do %>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" class="me-2" aria-hidden="true">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          <%= t("public.pages.la_boutique.google_reviews.view_all") %>
        <% end %>
      </div>

    </div>
  </section>
<% end %>
