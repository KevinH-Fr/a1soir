<!-- Section Boutique - Présentation -->
<section class="py-5 my-4">
  <!-- Section 1: Texte + Vidéo -->
  <div class="container-fluid px-0" data-scroll-reveal>
    <div class="row g-0 align-items-stretch">
      <!-- Colonne Texte -->
      <div class="col-12 col-md-6 order-2 order-md-1 d-flex">
        <div class="p-4 p-md-5 d-flex flex-column justify-content-center bg-white w-100">
          <div class="section-title-wrapper mb-4" data-aos="title-underline">
            <h3 class="section-title" style="font-family: 'Playfair Display', serif; font-size: 2rem; position: relative; display: inline-block;"><%= t("public.pages.la_boutique.universe.title") %></h3>
            <span class="section-title-underline"></span>
          </div>
          <p>
            <%= t("public.pages.la_boutique.universe.p1") %>
          </p>
          <p>
            <%= t("public.pages.la_boutique.universe.p2") %>
          </p>
          <p>
            <%= t("public.pages.la_boutique.universe.p3") %>
          </p>
          <p>
            <%= t("public.pages.la_boutique.universe.p4") %>
          </p>
          <p>
            <%= t("public.pages.la_boutique.universe.p5") %>
          </p>
      
        </div>
      </div>
      
      <!-- Colonne Vidéo -->
      <div class="col-12 col-md-6 order-1 order-md-2 d-flex">
        <div class="w-100" style="overflow: hidden; max-height: 800px;">
          <video autoplay muted loop playsinline class="w-100 h-100" style="object-fit: cover;">
            <source src="https://res.cloudinary.com/dukne3lhz/video/upload/v1767993750/video2_rgzof7.mp4" type="video/mp4">
          </video>
        </div>
      </div>
    </div>
  </div>

  <!-- Section 2: Image + Texte (inversé) -->
  <%= image_text_section(
    image1: "https://res.cloudinary.com/dukne3lhz/image/upload/q_auto,f_auto,w_1920/equipe1_qgcprn",
    image2: "https://res.cloudinary.com/dukne3lhz/image/upload/q_auto,f_auto,w_1920/equipe2_aubkac",
    title: t("public.pages.la_boutique.team.title"),
    paragraphs: [
      t("public.pages.la_boutique.team.p1"),
      t("public.pages.la_boutique.team.p2"),
      t("public.pages.la_boutique.team.p3"),
      t("public.pages.la_boutique.team.p4"),
      t("public.pages.la_boutique.team.p5"),
      t("public.pages.la_boutique.team.p6"),
      t("public.pages.la_boutique.team.p7")
    ],
    reverse: true
  ) %>

  <!-- Carousel des métiers de la boutique -->
  <div class="container-fluid px-0 mt-5" data-scroll-reveal>
    <div id="metiersCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="5000">
      <!-- Indicateurs -->
      <div class="carousel-indicators">
        <button type="button" data-bs-target="#metiersCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
        <button type="button" data-bs-target="#metiersCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
        <button type="button" data-bs-target="#metiersCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
        <button type="button" data-bs-target="#metiersCarousel" data-bs-slide-to="3" aria-label="Slide 4"></button>
      </div>
      
      <!-- Slides -->
      <div class="carousel-inner">
        <%= simple_image_text_section(
          image_path: "https://res.cloudinary.com/dukne3lhz/image/upload/q_auto,f_auto,w_1920/cat_tenues_soiree_plqmy5",
          title: t("public.pages.la_boutique.carousel.evening_wear.title"),
          text: t("public.pages.la_boutique.carousel.evening_wear.text"),
          active: true,
          image_position: "center 35%",
          button_text: t("public.pages.home.hero.button_text"),
          button_url: produits_filter_url(category_names: ["robes courtes", "robes longues", "ensembles pantalons"])
        ) %>
        
        <%= simple_image_text_section(
          image_path: "https://res.cloudinary.com/dukne3lhz/image/upload/q_auto,f_auto,w_1920/cat_robes_mariees_cbk210",
          title: t("public.pages.la_boutique.carousel.wedding_dresses.title"),
          text: t("public.pages.la_boutique.carousel.wedding_dresses.text"),
          active: false,
          image_position: "center 25%",
          button_text: t("public.pages.home.hero.button_text"),
          button_url: produits_filter_url(category_names: ["robes de mariée courtes", "robes de mariée longues"])
        ) %>
        
        <%= simple_image_text_section(
          image_path: "https://res.cloudinary.com/dukne3lhz/image/upload/q_auto,f_auto,w_1920/cat_costume_ztlvn8",
          title: t("public.pages.la_boutique.carousel.suits.title"),
          text: t("public.pages.la_boutique.carousel.suits.text"),
          active: false,
          image_position: "center 0%",
          button_text: t("public.pages.home.hero.button_text"),
          button_url: produits_filter_url(category_names: "costume")
        ) %>
        
        <%= simple_image_text_section(
          image_path: "https://res.cloudinary.com/dukne3lhz/image/upload/q_auto,f_auto,w_1920/cat_accessoires_xud3b7",
          title: t("public.pages.la_boutique.carousel.accessories.title"),
          text: t("public.pages.la_boutique.carousel.accessories.text"),
          active: false,
          image_position: "center 40%",
          button_text: t("public.pages.home.hero.button_text"),
          button_url: produits_filter_url(category_names: ["chaussures", "accessoires"])
        ) %>
      </div>
      
      <!-- Contrôles -->
      <button class="carousel-control-prev" type="button" data-bs-target="#metiersCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Précédent</span>
      </button>
      <button class="carousel-control-next" type="button" data-bs-target="#metiersCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Suivant</span>
      </button>
    </div>
  </div>
</section>

