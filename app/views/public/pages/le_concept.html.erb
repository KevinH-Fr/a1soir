<% content_for :structured_data do %>
  <script type="application/ld+json">
    <%= webpage_schema(
          name: meta_title,
          description: meta_description,
          url: request.original_url
        ).to_json.html_safe %>
  </script>
<% end %>

<%= page_header(t("public.pages.le_concept.header_title"), t("public.pages.le_concept.header_subtitle"),
image1: "https://res.cloudinary.com/dukne3lhz/image/upload/q_auto,f_auto,w_1920/le_concept1_nz10zg", 
image2: "https://res.cloudinary.com/dukne3lhz/image/upload/q_auto,f_auto,w_1920/le_concept2_m5gxma",
image1_position: "center top",
image2_position: "center top") %>

<div class="public-main-content">
    <%= render partial: "public/pages/le_concept/section_introduction" %>
  <div class="container-fluid" data-scroll-reveal>

    <!-- Les trois piliers -->
    <div class="row g-4 my-5 py-4 bg-white">
      <!-- Location -->
      <div class="col-lg-4" data-scroll-reveal>
        <%= public_card(
          icon: "calendar-check",
          title: t("public.pages.le_concept.pillars.rental.title"),
          description: t("public.pages.le_concept.pillars.rental.description"),
          features: [
            t("public.pages.le_concept.pillars.rental.features.1"),
            t("public.pages.le_concept.pillars.rental.features.2"),
            t("public.pages.le_concept.pillars.rental.features.3"),
            t("public.pages.le_concept.pillars.rental.features.4")
            ],
          theme: "light",
          card_style: "concept"
        ) %>
      </div>

      <!-- Vente -->
      <div class="col-lg-4" data-scroll-reveal>
        <%= public_card(
          icon: "bag-check",
          title: t("public.pages.le_concept.pillars.sale.title"),
          description: t("public.pages.le_concept.pillars.sale.description"),
          features: [
            t("public.pages.le_concept.pillars.sale.features.1"),
            t("public.pages.le_concept.pillars.sale.features.2"),
            t("public.pages.le_concept.pillars.sale.features.3"),
            t("public.pages.le_concept.pillars.sale.features.4")
          ],
          theme: "light",
          card_style: "concept"
        ) %>
      </div>

      <!-- Personnalisation -->
      <div class="col-lg-4" data-scroll-reveal>
        <%= public_card(
          icon: "scissors",
          title: t("public.pages.le_concept.pillars.customization.title"),
          description: t("public.pages.le_concept.pillars.customization.description"),
          features: [
            t("public.pages.le_concept.pillars.customization.features.1"),
            t("public.pages.le_concept.pillars.customization.features.2"),
            t("public.pages.le_concept.pillars.customization.features.3"),
            t("public.pages.le_concept.pillars.customization.features.4")
          ],
          theme: "light",
          card_style: "concept"
        ) %>
      </div>
    </div>
  </div>
</div>

<!-- Section texte sticky -->
<%= render partial: "public/pages/le_concept/section_sticky_text" %>

<div class="public-main-content bg-white">
  <div class="container-fluid">
    <!-- Comment ça marche -->
    <div class="my-5 py-5" data-scroll-reveal>
      <div class="container">
        <div class="section-title-wrapper mb-5 text-center" data-aos="title-underline">
          <h2 class="section-title text-dark d-inline-block" style="font-family: 'Playfair Display', serif; font-size: 2.5rem; position: relative;">
            <%= t("public.pages.le_concept.how_it_works.title") %>
            <span class="section-title-underline"></span>
          </h2>
        </div>
        <div class="row g-4">
          <div class="col-lg-3 col-md-6 d-flex">
            <%= public_card(
              icon: "1-circle-fill",
              title: t("public.pages.le_concept.how_it_works.step1.title"),
              description: t("public.pages.le_concept.how_it_works.step1.description"),
              theme: "light",
              card_style: "concept",
              wrapper_class: ""
            ) %>
          </div>
          
          <div class="col-lg-3 col-md-6 d-flex">
            <%= public_card(
              icon: "2-circle-fill",
              title: t("public.pages.le_concept.how_it_works.step2.title"),
              description: t("public.pages.le_concept.how_it_works.step2.description"),
              theme: "light",
              card_style: "concept",
              wrapper_class: ""
            ) %>
          </div>
          
          <div class="col-lg-3 col-md-6 d-flex">
            <%= public_card(
              icon: "3-circle-fill",
              title: t("public.pages.le_concept.how_it_works.step3.title"),
              description: t("public.pages.le_concept.how_it_works.step3.description"),
              theme: "light",
              card_style: "concept",
              wrapper_class: ""
            ) %>
          </div>
          
          <div class="col-lg-3 col-md-6 d-flex">
            <%= public_card(
              icon: "4-circle-fill",
              title: t("public.pages.le_concept.how_it_works.step4.title"),
              description: t("public.pages.le_concept.how_it_works.step4.description"),
              theme: "light",
              card_style: "concept",
              wrapper_class: ""
            ) %>
          </div>
        </div>
      </div>
    </div>

    <!-- Call to action -->
    <div class="text-center my-5 py-4" data-scroll-reveal>
      <h3 class="mb-4"><%= t("public.pages.le_concept.cta_title") %></h3>
      <div class="d-flex gap-3 justify-content-center flex-wrap mb-4">
        <%= cta_button(type: "collections", url: nos_collections_path, variant: "dark", outline: true) %>
        <%= cta_button(type: "rdv", url: "#{rdv_url}#rdv-form", variant: "dark") %>
      </div>
    </div>
  </div>
</div>

