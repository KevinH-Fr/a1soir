<section data-controller="boutique-text-scroll" class="position-relative overflow-hidden" style="min-height: 100vh;">
  <!-- Image en pleine page -->
  <%= cloudinary_image(
        "dessin1_se495h",
        width: 1920,
        alt: t("public.pages.home.boutique_section.title"),
        class: "position-absolute top-0 start-0 w-100 h-100",
        style: "object-fit: cover; object-position: left center; z-index: 0;",
        height: 1080,
        loading: "lazy"
      ) %>
  
  
  <!-- Card avec texte par-dessus l'image -->
  <div class="container position-relative h-100 d-flex align-items-center" style="min-height: 100vh; z-index: 2;">
    <div class="row w-100">
      <!-- Sur mobile : card en haut, sur grand écran : card à droite -->
      <div class="col-12 col-lg-5 offset-lg-7">
        <div data-boutique-text-scroll-target="card" class="p-3 p-lg-4 my-3 my-lg-0" style="background-color: rgba(255, 255, 255, 0.6); border-radius: 1px;">
          <div class="text-end text-dark">
            <h2 data-boutique-text-scroll-target="item" class="display-5 fw-bold mb-3 text-dark">
              <%= t("public.pages.home.boutique_section.title") %>
            </h2>
            
            <div data-boutique-text-scroll-target="item" class="mb-3 p-2 p-lg-3 rounded">
              <p class="mb-0 text-dark">
                <%= t("public.pages.home.boutique_section.body") %>
              </p>
            </div>
            
            <div data-boutique-text-scroll-target="item" class="mt-3">
              <%= link_to t("public.pages.home.hero.button_text"), la_boutique_url, class: "btn btn-dark btn-lg px-4 public-btn-border-radius fw-bold" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

