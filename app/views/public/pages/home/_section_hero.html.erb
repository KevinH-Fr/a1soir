<%
  video_url  = "/images/robe_mariee_soiree_hp.webm"
  poster_url = "/images/robe_mariee_soiree_hp.webp"
  title      = t("public.pages.home.hero.title")
  subtitle   = t("public.pages.home.hero.subtitle")
  button_text = t("public.pages.home.hero.button_text")
  button_url = nos_collections_path
%>

<% content_for :hero_preload do %>
  <link rel="preload" href="<%= poster_url %>" as="image" type="image/webp" fetchpriority="high">
<% end %>

<div class="position-relative vh-100" style="height: 100vh; overflow: hidden;">
  <!-- Vidéo en pleine page -->
  <video autoplay muted loop playsinline poster="<%= poster_url %>" class="position-absolute top-0 start-0 w-100 h-100" style="object-fit: cover; z-index: 0;">
    <source src="<%= video_url %>" type="video/webm">
    <track kind="captions" src="" label="Français" srclang="fr" default>
    Votre navigateur ne prend pas en charge la lecture de vidéos.
  </video>
  
  <!-- Overlay sombre pour la lisibilité -->
  <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(to bottom, rgba(0,0,0,0.4), rgba(0,0,0,0.6)); z-index: 1; pointer-events: none;"></div>
  
  <!-- Contenu avec texte et bouton -->
  <div class="position-absolute top-0 start-0 w-100 h-100 d-flex flex-column justify-content-center align-items-start text-start text-white" style="z-index: 2; padding: 4rem; pointer-events: none;">
    <div class="container">
      <% if title.present? %>
        <h1 class="display-4 fw-bold mb-3" style="text-shadow: 0 2px 10px rgba(0,0,0,0.5);">
          <%= title %>
        </h1>
      <% end %>
      
      <% if subtitle.present? %>
        <p class="lead mb-4" style="text-shadow: 0 1px 5px rgba(0,0,0,0.5);">
          <%= subtitle %>
        </p>
      <% end %>
      
      <%
        show_primary_cta = button_text.present?
        show_festival_cta = Rails.application.config.x.festival_de_cannes_enabled
      %>
      <% if show_primary_cta || show_festival_cta %>
        <div class="d-flex flex-wrap gap-3 align-items-center" style="pointer-events: auto;">
          <% if show_primary_cta %>
            <%= link_to button_text, button_url, class: "btn btn-light btn-lg px-5 public-btn-border-radius" %>
          <% end %>
          <% if show_festival_cta %>
            <%= link_to t("public.pages.home.hero.festival_button_text"),
                        festival_de_cannes_path,
                        class: "btn btn-outline-light btn-lg px-4 px-sm-5 public-btn-border-radius" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
