<div id="filtres-type-produit">

    <div class="dropdown position-relative">
        <button class="btn btn-sm btn-outline-light dropdown-toggle" type="button" id="typeProduitDropdown" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-bookmarks"></i>
            <span class="ms-1 d-none d-md-inline">
                <%= params[:type_produit].present? ? (@types_produits.find { |tp| tp.id == params[:type_produit].to_i }&.nom || t("public.pages.produits.filters.type_produit.fallback")) : t("public.pages.produits.filters.type_produit.fallback") %>
            </span>
        </button>

        <div class="dropdown-menu overflow-y-auto" aria-labelledby="typeProduitDropdown" style="max-height: 18rem">
            <%= button_to t("public.pages.produits.filters.type_produit.all_button"),
                update_produits_filters_path(type_produit: nil),
                class: "dropdown-item text-nowrap #{'fw-bold' if params[:type_produit].blank?}" %>
            <hr class="dropdown-divider">
            <% @types_produits.each do |type_produit| %>
                <%= button_to type_produit.nom,
                    update_produits_filters_path(type_produit: type_produit.id),
                    class: "dropdown-item text-nowrap #{'fw-bold' if params[:type_produit].to_s == type_produit.id.to_s}" %>
            <% end %>
        </div>
    </div>

</div>
