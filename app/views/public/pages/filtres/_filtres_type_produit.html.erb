<div id="filtres-type-produit">
    <% col_class = dropdown_col_class(@types_produits) %>

    <div class="dropdown position-relative">
        <button class="btn btn-sm btn-outline-light dropdown-toggle" type="button" id="typeProduitDropdown" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-bookmarks"></i>
            <span class="ms-1 d-none d-md-inline">
            <%= if params[:type_produit].present?
                    @types_produits.find { |tp| tp.id == params[:type_produit].to_i }&.nom || "Type"
                else
                    "Type"
                end %>
            </span>
        </button>

        <div class="dropdown-menu p-2" aria-labelledby="typeProduitDropdown">
            <div class="mb-1 border-bottom pb-1">
                <%= button_to "Tous",
                    update_filters_path(
                        slug: params[:slug],
                        id: params[:id],
                        taille: params[:taille],
                        couleur: params[:couleur],
                        prixmax: params[:prixmax],
                        type: params[:type],
                        type_produit: nil,
                        from_cabine: params[:from_cabine]
                    ),
                    class: "dropdown-item #{'fw-bold' if params[:type_produit].blank?}" %>
            </div>

            <div class="row <%= col_class %> g-0">
                <% @types_produits.each do |type_produit| %>
                    <div class="col">
                        <%= button_to type_produit.nom,
                            update_filters_path(
                                slug: params[:slug],
                                id: params[:id],
                                taille: params[:taille],
                                couleur: params[:couleur],
                                prixmax: params[:prixmax],
                                type: params[:type],
                                type_produit: type_produit.id,
                                from_cabine: params[:from_cabine]
                            ),
                            class: "dropdown-item #{'fw-bold' if params[:type_produit].to_s == type_produit.id.to_s}" %>
                    </div>
                <% end %>
            </div>
        </div>
    </div>

</div>
