<div id="filtres-categorie">
    <%
      selected_ids = params[:id].present? ? (params[:id].is_a?(Array) ? params[:id].map(&:to_i) : [params[:id].to_i]) : []

      display_text = if selected_ids.empty?
        "Catégorie"
      elsif selected_ids.size == 1
        @toutes_categories.find { |c| c.id == selected_ids.first }&.nom || "Catégorie"
      else
        "#{selected_ids.size} catégories"
      end
    %>

    <div class="dropdown position-relative">
        <button class="btn btn-sm btn-outline-light dropdown-toggle" type="button" id="categorieDropdown" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-list-ul"></i>
            <span class="ms-1 d-none d-md-inline"><%= display_text %></span>
        </button>

        <div class="dropdown-menu overflow-y-auto" aria-labelledby="categorieDropdown" style="max-height: 18rem">
            <%= button_to "Toutes",
                update_filters_path(slug: nil, id: nil, taille: params[:taille], couleur: params[:couleur], prixmax: params[:prixmax], type: params[:type], from_cabine: params[:from_cabine], type_produit: params[:type_produit]),
                class: "dropdown-item text-nowrap #{'fw-bold' if selected_ids.empty?}" %>
            <hr class="dropdown-divider">
            <% @toutes_categories.each do |categorie| %>
                <%= button_to categorie.nom,
                    update_filters_path(slug: categorie.nom.parameterize, id: categorie.id, taille: params[:taille], couleur: params[:couleur], prixmax: params[:prixmax], type: params[:type], from_cabine: params[:from_cabine], type_produit: params[:type_produit]),
                    class: "dropdown-item text-nowrap #{'fw-bold' if selected_ids.include?(categorie.id)}" %>
            <% end %>
        </div>
    </div>

</div>
