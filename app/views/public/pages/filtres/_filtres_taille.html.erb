<div id="filtres-taille">
    <% grid = dropdown_grid(@toutes_tailles) %>

    <div class="dropdown position-relative">
        <button class="btn btn-sm btn-outline-light dropdown-toggle" type="button" id="tailleDropdown" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-rulers"></i>
            <span class="ms-1 d-none d-md-inline">
            <%= if params[:taille].present?
                    @toutes_tailles.find { |t| t.id == params[:taille].to_i }&.nom || "Taille"
                else
                    "Taille"
                end %>
            </span>
        </button>

        <div class="dropdown-menu p-2" aria-labelledby="tailleDropdown" style="<%= grid[:min_width] %>">
            <div class="mb-1 border-bottom pb-1">
                <%= button_to "Toutes",
                    update_filters_path(
                        slug: params[:slug],
                        id: params[:id],
                        taille: nil,
                        couleur: params[:couleur],
                        prixmax: params[:prixmax],
                        type: params[:type],
                        from_cabine: params[:from_cabine],
                        type_produit: params[:type_produit]
                    ),
                    class: "dropdown-item text-nowrap #{'fw-bold' if params[:taille].blank?}" %>
            </div>

            <div class="row <%= grid[:cols] %> g-0">
                <% @toutes_tailles.each do |taille| %>
                    <div class="col">
                        <%= button_to taille.nom,
                            update_filters_path(
                                slug: params[:slug],
                                id: params[:id],
                                taille: taille.id,
                                couleur: params[:couleur],
                                prixmax: params[:prixmax],
                                type: params[:type],
                                from_cabine: params[:from_cabine],
                                type_produit: params[:type_produit]
                            ),
                            class: "dropdown-item text-nowrap #{'fw-bold' if params[:taille].to_s == taille.id.to_s}" %>
                    </div>
                <% end %>
            </div>
        </div>
    </div>

</div>
