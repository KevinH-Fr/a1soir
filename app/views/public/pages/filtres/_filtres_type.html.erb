<div id="filtres-type">
    <% col_class = dropdown_col_class(@types) %>

    <div class="dropdown position-relative">
        <button class="btn btn-sm btn-outline-light dropdown-toggle" type="button" id="typeDropdown" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-tags"></i>
            <span class="ms-1 d-none d-md-inline">
            <%= params[:type].present? ? params[:type].capitalize : "Service" %>
            </span>
        </button>

        <div class="dropdown-menu p-2" aria-labelledby="typeDropdown">
            <div class="mb-1 border-bottom pb-1">
                <%= button_to "Tous",
                    update_filters_path(
                        slug: params[:slug],
                        id: params[:id],
                        taille: params[:taille],
                        couleur: params[:couleur],
                        prixmax: params[:prixmax],
                        type: nil,
                        from_cabine: params[:from_cabine],
                        type_produit: params[:type_produit]
                    ),
                    class: "dropdown-item #{'fw-bold' if params[:type].blank?}" %>
            </div>

            <div class="row <%= col_class %> g-0">
                <% @types.each do |type| %>
                    <div class="col">
                        <%= button_to type.capitalize,
                            update_filters_path(
                                slug: params[:slug],
                                id: params[:id],
                                taille: params[:taille],
                                couleur: params[:couleur],
                                prixmax: params[:prixmax],
                                type: type,
                                from_cabine: params[:from_cabine],
                                type_produit: params[:type_produit]
                            ),
                            class: "dropdown-item #{'fw-bold' if params[:type].to_s == type.to_s}" %>
                    </div>
                <% end %>
            </div>
        </div>
    </div>

</div>
