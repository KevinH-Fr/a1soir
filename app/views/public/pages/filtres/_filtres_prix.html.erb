<div id="filtres-prix">

    <div class="dropdown position-relative">
        <button class="btn btn-sm btn-outline-light dropdown-toggle" type="button" id="prixDropdown" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-currency-euro"></i>
            <span class="ms-1 d-none d-md-inline">
                <%= if ActiveModel::Type::Boolean.new.cast(params[:en_promotion])
                      t("public.pages.produits.filters.prix.promo_label")
                    elsif params[:prixmax].present?
                      "&lt; #{custom_currency_no_decimals_format(params[:prixmax])}".html_safe
                    else
                      t("public.pages.produits.filters.prix.fallback")
                    end %>
            </span>
        </button>

        <div class="dropdown-menu overflow-y-auto" aria-labelledby="prixDropdown" style="max-height: 18rem">
            <%= button_to t("public.pages.produits.filters.prix.all_button"),
                update_produits_filters_path(prixmax: nil, en_promotion: nil),
                class: "dropdown-item text-nowrap #{'fw-bold' if params[:prixmax].blank? && !ActiveModel::Type::Boolean.new.cast(params[:en_promotion])}" %>
            <%= button_to t("public.pages.produits.filters.prix.promo_button"),
                update_produits_filters_path(prixmax: nil, en_promotion: true),
                class: "dropdown-item text-nowrap #{'fw-bold' if ActiveModel::Type::Boolean.new.cast(params[:en_promotion])}" %>
            <hr class="dropdown-divider">
            <% @tranches_prix.each do |prix| %>
                <% label = "< #{custom_currency_no_decimals_format(prix)}" %>
                <%= button_to label.html_safe,
                    update_produits_filters_path(prixmax: prix, en_promotion: nil),
                    class: "dropdown-item text-nowrap #{'fw-bold' if params[:prixmax].to_s == prix.to_s}" %>
            <% end %>
        </div>
    </div>

</div>
