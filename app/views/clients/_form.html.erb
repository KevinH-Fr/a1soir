
<%= form_with(model: @client) do |f| %>
  <% if client.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(client.errors.count, "error") %> prohibited this client from being saved:</h2>

      <ul>
        <% client.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

<div class="card mb-3 text-bg-dark">
  <div class="card-body">

    <div class="mb-3">
      <%= f.label :nom, { class: "form-label"} %>
      <%= f.text_field :nom, { class: "form-control", placeholder: "Nom" } %>
    </div>

    <div class="mb-3">
      <%= f.label :mail, { class: "form-label"} %>
      <%= f.text_field :mail, { class: "form-control", placeholder: "mail" } %>
    </div>

    <div class="mb-3">
      <%= f.label :commentaires, { class: "form-label"} %>
      <%= f.text_area :commentaires, { class: "form-control", placeholder: "commentaires" } %>
    </div>

    <%= f.submit "Valider", class: "btn btn-primary" %>

  </div>
</div>
<% end %>