<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= meta_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= meta_description %>">
    <meta name="keywords" content="<%= meta_keywords %>">
    <link rel="canonical" href="<%= public_page_url %>">
    <% I18n.available_locales.each do |locale| %>
      <link rel="alternate" hreflang="<%= locale %>" href="<%= public_page_url(locale: locale) %>">
    <% end %>
    <link rel="alternate" hreflang="x-default" href="<%= public_page_url(locale: I18n.default_locale) %>">
    <%# Données structurées globales (entreprise + site) %>
    <script type="application/ld+json">
      <%= structured_data_global.to_json.html_safe %>
    </script>
    <%# Données structurées spécifiques à certaines pages (WebPage, BreadcrumbList, etc.) %>
    <%= yield :structured_data %>
    <!-- Open Graph -->
    <meta property="og:title" content="<%= meta_title %>">
    <meta property="og:description" content="<%= meta_description %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= public_page_url %>">
    <meta property="og:image" content="<%= content_for?(:og_image) ? yield(:og_image) : structured_store_logo_url %>">
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= meta_title %>">
    <meta name="twitter:description" content="<%= meta_description %>">
    <meta name="twitter:image" content="<%= content_for?(:og_image) ? yield(:og_image) : structured_store_logo_url %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Preload critique pour le LCP (défini par les partials via content_for :hero_preload) %>
    <%= yield :hero_preload %>

    <%# Bootstrap CSS — servi via Sprockets (app/assets/stylesheets/vendor/bootstrap.min.css) %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous" defer></script>

    <%# Polices auto-hébergées — 1 feuille CSS (Playfair + Cormorant + Montserrat) %>
    <link rel="preload" href="<%= public_font_asset_path('playfair-display-latin-400-normal.woff2') %>" as="font" type="font/woff2" crossorigin>
    <%= stylesheet_link_tag "fonts-public", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "vendor/bootstrap-icons.min", "data-turbo-track": "reload" %>

    <%# AOS CSS — chargement non-bloquant %>
    <link rel="preload" href="https://unpkg.com/aos@next/dist/aos.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css"></noscript>

    <%= favicon_link_tag asset_path('a1soir_favicon.png'), :rel => 'icon', :type =>  'image/png' %>

    <%= render "public/shared/gtag" %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%#= javascript_importmap_tags %>
    <%= javascript_include_tag "public", "data-turbo-track": "reload", type: "module" %>

  </head>

  <body class="bg-black d-flex flex-column vh-100 overflow-hidden" data-controller="cookie-consent">
    
    <%= render "public/shared/navbar" %>

    <div class="public-scroll flex-grow-1 overflow-auto" data-controller="scroll-reveal">
      <main class="public-content">
        <div id="flash" data-turbo-temporary>
          <%= render partial: "public/shared/flash" %>
        </div>
        <%= yield %>
      </main>

      <% if show_shop_cart_floating_footer? %>
        <%= render partial: "public/pages/floating_shop_checkout_button" %>
      <% else %>
        <%= tag.div id: "floating_shop_checkout_btn" %>
      <% end %>
      
      <%= render "public/shared/floating_contact_icons" %>

      <footer>
        <%= render "public/shared/footer" %>
      </footer>
    </div>

    <%= render "public/shared/cookie_banner" %>

    <script src="https://unpkg.com/aos@next/dist/aos.js" defer></script>
  
  </body>


</html>
