<p>Bonjour,</p>

<p>Nous avons bien enregistré votre paiement en ligne.</p>

<ul>
  <% @items.each do |item| %>
    <li><%= item.produit&.nom %> — quantité <%= item.quantity || 1 %></li>
  <% end %>
</ul>

<p>
  <strong>Montant total :</strong>
  <%= number_to_currency(@payment.amount.to_f / 100, unit: "€", format: "%n %u", delimiter: " ") %>
  (<%= @payment.currency&.upcase %>)
</p>

<p>Merci pour votre confiance.</p>
