<h5>robes de mariees</h5>

<table class="table table-light text-center">
  <% @produits.each do | produit| %> 
    <tr>
      <td> 
        <%= image_tag(produit.default_image, style: "width: 100px; display: block", 
                class: "img-fluid rounded")   %> </td>
      </td> 
      <td> <%= produit.nom %> </td>
      <td> <%= produit.description %> </td>
    




    </tr>
  <% end %>
</table> 

