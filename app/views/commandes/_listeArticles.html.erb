
<h5> Liste des articles </h5>

 <table class="table table-secondary table-striped table-bordered table-hover">
      <thead class="table-dark">
        <tr>
          <th style="text-align: center;">#</th>
          <th colspan="2">produit</th>
          <th>quantité</th>
          <th>prix</th>
          <th colspan=3> Actions</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <% @articles.each_with_index do | article, i | %>
            <td> <%= i + 1 %> </td>
            <td> 
              <%= image_tag(Produit.find(article.produit_id).default_image, style: "width: 50px; display: block", 
               class: "img-fluid rounded") %> 
            </td>
            <td> <%= Produit.find(article.produit_id).nom %> </td>
            <td> <%= article.quantite %> </td>
            <td></td>
            <td> <%= link_to '', article, class:"fa-solid fa-eye btn btn-primary btn-sm" %>  </td>
            <td> <%= button_to '', article, class:"fa-solid fa-trash-can btn btn-danger btn-sm", method: :delete, :onclick => "return confirm('Sûr ?')" %>  </td> 
            <td> <%= link_to "", edit_article_path(article, produitId: article.produit_id, commandeId: article.commande_id), class:"fa-regular fa-pen-to-square btn btn-secondary btn-sm" %> </td> 
        </tr> 
        <% end %>
      </tbody>
    </table>

           