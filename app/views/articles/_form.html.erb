<%= form_with(model: article) do |form| %>
  <% if article.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(article.errors.count, "error") %> prohibited this article from being saved:</h2>
      <ul>
        <% article.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <% form.label :commande_id, style: "display: block" %>
     <%#= form.select :commande_id, Commande.all.collect { |c| [ c.nom, c.id ] },
                     include_blank: true, selected: @commandeId %>
      <%= form.hidden_field(:commande_id, value: @commandeId) %>

  </div>

  <div>
    <% form.label :produit_id, style: "display: block" %>
    <%#= form.select :produit_id, Produit.all.collect { |p| [ p.nom, p.id ] },
                     include_blank: true, selected: @produitId %>
    <%= form.hidden_field(:produit_id, value: @produitId) %>

  </div>

 <% if @produitId.present? %> 
   <%= render "produitLie" %>
   <%= link_to 'Annuler selection', new_article_path(commandeId: @commandeId), class:"btn btn-outline-danger btn-sm" %>
 <br> <br>

<% end %>

  <div>
      <%= form.label :prix, style: "display: block" %>
      <%= form.number_field :prix %>
  </div>


 <%# bouton caché validation quantite %>
  <div data-controller="form-element">
    <%= form.button "Validate", formaction: new_article_path, formmethod: :get, data: { turbo_frame: :total_field, form_element_target: "submitbtn" } %>
    <div>
      <%= form.label :quantite, style: "display: block" %>
      <%= form.number_field :quantite, { data: { action: "change->form-element#remotesubmit"}} %>
    </div>

  <%= turbo_frame_tag :total_field do %>
      <div>
        <%= form.label :total, style: "display: block" %>
        <%= form.number_field :total %> <br> <br>

       test quantite:  <%= valQuantite = form.object.quantite %> <br>
       test prix:  <%= valPrix = form.object.prix %> <br> <br>
  
       <% if valQuantite.present? && valPrix.present? %>
        test total = <%= valQuantite * valPrix %>
       <% end %>
      

      </div>
  <% end %>

  <hr>

    <div>
    <%= form.submit "Créer", class: 'btn btn-success' %>
  </div>

  <%# liste des produits pour selection %>
  <% if @produitId.nil? %> 
    <%= render "listeSelection" %>
  <% end %>
 
<% end %>
