<%= form_with(model: article) do |form| %>
  <% if article.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(article.errors.count, "error") %> prohibited this article from being saved:</h2>
      <ul>
        <% article.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>



  <div>
    <%= form.label :commande_id, style: "display: block" %>
    <%= form.select :commande_id, Commande.all.collect { |c| [ c.nom, c.id ] },
                     include_blank: true, selected: @commande %>
  </div>

  <%# bouton caché validation produit lié %>

    <div data-controller="form-element">
    <%= form.button "Validate", formaction: new_article_path, formmethod: :get, data: { turbo_frame: :quantite_field, form_element_target: "submitbtn" } %>

  <div>
    <%= form.label :produit_id, style: "display: block" %>
    <%= form.select :produit_id, Produit.all.collect { |p| [ p.nom, p.id ] }, {include_blank: true}, { data: { action: "change->form-element#remotesubmit"}} %>
  </div>

 <%= turbo_frame_tag :quantite_field do %> 
 <% if article.produit_id.present? %> 
    <hr>
    <% articleId = article.produit_id %>
    <%= Produit.find(articleId).full_name %>
 <% end %>

 <hr>

  <div>
    <%= form.label :quantite, style: "display: block" %>
    <%= form.number_field :quantite %>
  </div>
<% end %>


<%# liste des produits pour selection %>
  <%= render "listeSelection" %>

  <hr>
 
  <div>
    <%= form.submit "Valider", class:'btn btn-sm btn-success' %>
  </div>
<% end %>
