
<br>

<strong> détails porduit sélectionné : </strong> <br>
   <div class="card mb-3 text-bg-dark" style="max-width: 540px;">
    <div class="row g-0">
      <div class="col-md-4">
        <%= image_tag(Produit.find(@produitId).default_image, class:"img-fluid rounded-start") %> 
      </div>
      <div class="col-md-8">
        <div class="card-body">
          <h5 class="card-title"> <%= Produit.find(@produitId).nom %></h5>
          <p class="card-text"> <%= Produit.find(@produitId).description %></p>
          <p class="card-text"> <%= Produit.find(@produitId).categorie %></p>
          <p class="card-text"> <%= Produit.find(@produitId).prix %></p>
        </div>
      </div>
    </div>
  </div>
