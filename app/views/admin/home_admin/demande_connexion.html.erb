
<div class="container admin-centered-page d-flex align-items-center justify-content-center py-1">
  <div class="row justify-content-center w-100">
    <div class="col-12 col-md-10 col-lg-7 col-xl-6">
      <div class="card light-beige-colored shadow-sm border-0">
        <div class="card-header bg-dark text-light py-2 px-3">
          <i class="bi bi-person-lock me-2" aria-hidden="true"></i>
          <strong>Demande de connexion</strong>
        </div>

        <div class="card-body px-3 py-5 text-center">
          <% unless current_admin_user.present? %>
            <p class="text-muted mb-3">Accès réservé à l'administration.</p>
            <div class="d-flex flex-wrap justify-content-center gap-2">
              <%= link_to new_admin_user_session_url(subdomain: "admin"), class: "btn btn-warning px-3 rounded-pill" do %>
                <i class="bi bi-person-lock me-1"></i>
                <span class="fw-bold">Connexion</span>
              <% end %>

              <%= link_to new_admin_user_registration_url(subdomain: "admin"), class: "btn btn-primary px-3 rounded-pill" do %>
                <i class="bi bi-person-add me-1"></i>
                <span class="fw-bold">Nouveau</span>
              <% end %>
            </div>
          <% end %>

          <% if admin_user_signed_in? && (current_admin_user.user? || current_admin_user.vendeur?) %>
            <div class="alert alert-warning py-2 mb-2" role="alert">
              Reconnectez-vous en tant qu'administrateur pour acceder aux informations.
            </div>

            <%= button_to destroy_admin_user_session_path, method: :delete, class: "btn btn-sm btn-danger" do %>
              <i class="fa-solid fa-right-from-bracket me-1"></i>
              Deconnexion
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
