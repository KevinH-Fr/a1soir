<div class="vstack gap-3">
  <div class="d-flex flex-column flex-sm-row align-items-stretch align-items-sm-center justify-content-between gap-2">
    <%= link_to "#collapseNewPeriodes",
          class: "btn btn-primary btn-sm d-inline-flex align-items-center justify-content-center gap-1",
          data: { bs_toggle: "collapse" },
          role: "button",
          aria: { expanded: "false", controls: "collapseNewPeriodes" } do %>
      <i class="bi bi-plus-lg" aria-hidden="true"></i>
      Nouvelle période
    <% end %>
  </div>

  <div class="collapse w-100" id="collapseNewPeriodes">
    <div id="new_periode_non_disponible" class="mb-3 w-100">
      <%= render partial: "admin/periodes_non_disponibles/form", locals: { periode_non_disponible: PeriodeNonDisponible.new } %>
    </div>
  </div>

  <div id="periodes_table_body" class="vstack gap-2">
    <% if @periodes_non_disponibles.any? %>
      <% @periodes_non_disponibles.each do |periode| %>
        <%= render "admin/periodes_non_disponibles/periode_non_disponible", periode_non_disponible: periode %>
      <% end %>
    <% else %>
      <div class="text-center text-muted py-5 px-3 rounded-3 border border-dashed border-secondary-subtle bg-body-secondary bg-opacity-10">
        <i class="bi bi-calendar-x d-block fs-2 mb-2 opacity-50" aria-hidden="true"></i>
        <p class="mb-0 small">Aucune période non disponible configurée</p>
      </div>
    <% end %>
  </div>
</div>
