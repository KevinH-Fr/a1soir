<div class="vstack gap-3">
  <% if @parametre_rdv.nil? || !@parametre_rdv.persisted? %>
    <div class="d-flex flex-column flex-sm-row align-items-stretch align-items-sm-center justify-content-between gap-2">
      <%= link_to "#collapseNew",
            class: "btn btn-primary btn-sm d-inline-flex align-items-center justify-content-center gap-1",
            data: { bs_toggle: "collapse" },
            role: "button",
            aria: { expanded: "false", controls: "collapseNew" } do %>
        <i class="bi bi-plus-lg" aria-hidden="true"></i>
        Créer une configuration
      <% end %>
    </div>
  <% end %>

  <div class="collapse" id="collapseNew">
    <div id="new" class="card border border-secondary-subtle shadow-sm rounded-3 mb-0">
      <div class="card-body p-3 p-md-4">
        <h3 class="h6 fw-semibold mb-3 d-flex align-items-center gap-2">
          <i class="bi bi-gear text-secondary" aria-hidden="true"></i>
          Nouvelle configuration
        </h3>
        <%= render "admin/parametre_rdvs/form", parametre_rdv: (@parametre_rdv || ParametreRdv.new) %>
      </div>
    </div>
  </div>

  <div id="parametres_content">
    <% if @parametre_rdv&.persisted? %>
      <%= render "admin/parametre_rdvs/parametre_rdv", parametre_rdv: @parametre_rdv %>
    <% end %>
  </div>
</div>
