<div class="vstack gap-3">
  <div class="d-flex flex-column flex-sm-row align-items-stretch align-items-sm-center justify-content-between gap-2">
    <%= link_to "#collapseNewTypes",
          class: "btn btn-primary btn-sm d-inline-flex align-items-center justify-content-center gap-1",
          data: { bs_toggle: "collapse" },
          role: "button",
          aria: { expanded: "false", controls: "collapseNewTypes" } do %>
      <i class="bi bi-plus-lg" aria-hidden="true"></i>
      Nouveau type de RDV
    <% end %>
  </div>

  <div class="collapse" id="collapseNewTypes">
    <div id="new_type_rdv" class="mb-3">
      <%= render partial: "admin/type_rdvs/form", locals: { type_rdv: TypeRdv.new } %>
    </div>
  </div>

  <div id="types_table_body" class="vstack gap-2">
    <% if @type_rdvs.any? %>
      <% @type_rdvs.each do |type_rdv| %>
        <%= render "admin/type_rdvs/type_rdv", type_rdv: type_rdv %>
      <% end %>
    <% else %>
      <div class="text-center text-muted py-5 px-3 rounded-3 border border-dashed border-secondary-subtle bg-body-secondary bg-opacity-10">
        <i class="bi bi-inbox d-block fs-2 mb-2 opacity-50" aria-hidden="true"></i>
        <p class="mb-0 small">Aucun type de RDV configuré</p>
      </div>
    <% end %>
  </div>
</div>
