<% parametre_rdv = local_assigns[:parametre_rdv] || @parametre_rdv %>
<%= form_with model: [:admin, parametre_rdv], url: parametre_rdv.persisted? ? admin_parametre_rdv_path(parametre_rdv) : admin_parametre_rdvs_path, method: parametre_rdv.persisted? ? :patch : :post, class: "" do |f| %>
  <div class="p-2">
    <% if parametre_rdv.errors.any? %>
      <div class="alert alert-danger">
        <ul class="mb-0">
          <% parametre_rdv.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-floating mb-3">
      <%= f.number_field :minutes_par_personne_supp, class: "form-control", min: 0, placeholder: "Minutes supplémentaires par personne" %>
      <%= f.label :minutes_par_personne_supp, "Minutes supplémentaires par personne" %>
    </div>

    <div class="mb-3">
      <h6 class="fw-bold mb-2">Nombre maximum de RDV simultanés par jour</h6>
      <div class="row">
        <% ParametreRdv::DAY_LABELS.each do |day_sym, day_label| %>
          <% field = :"nb_rdv_simultanes_#{day_sym}" %>
          <div class="col-md-3 mb-2">
            <div class="form-floating">
              <%= f.number_field field, class: "form-control", min: 0, placeholder: day_label %>
              <%= f.label field, day_label %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <div class="mb-3">
      <h6 class="fw-bold mb-2">Créneaux horaires par jour</h6>
      <p class="small text-muted mb-2">
        Cochez les créneaux disponibles pour chaque jour.
      </p>

      <div class="table-responsive">
        <table class="table table-sm table-bordered align-middle mb-0" style="font-size: 0.78rem;">
          <thead class="table-light">
            <tr>
              <th scope="col" class="text-nowrap" style="width: 80px;">Jour</th>
              <% ParametreRdv::DEFAULT_CRENEAUX.each do |heure| %>
                <th scope="col" class="text-center px-1"><%= heure %></th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% ParametreRdv::DAY_LABELS.each do |day_sym, day_label| %>
              <% column = :"creneaux_#{day_sym}" %>
              <% valeurs_existantes = parametre_rdv.public_send(column) %>
              <% selection =
                   if valeurs_existantes.present?
                     valeurs_existantes.to_s.tr('[]"', "").split(",").map(&:strip)
                   else
                     []
                   end %>
              <tr>
                <th scope="row" class="text-nowrap"><%= day_label %></th>
                <% ParametreRdv::DEFAULT_CRENEAUX.each do |heure| %>
                  <% field_name = :"creneaux_#{day_sym}" %>
                  <% input_id = "parametre_rdv_#{field_name}_#{heure.tr(':', '_')}" %>
                  <td class="text-center px-1">
                    <%= check_box_tag "parametre_rdv[#{field_name}][]",
                                      heure,
                                      selection.include?(heure),
                                      id: input_id,
                                      class: "form-check-input" %>
                  </td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

    </div>
  </div>

  <div class="d-flex justify-content-end">
    <%= f.submit "Enregistrer", class: "btn btn-primary" %>
  </div>
<% end %>

