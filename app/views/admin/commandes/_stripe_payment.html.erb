<% stripe_payment = @commande.stripe_payment %>
<% if stripe_payment.present? %>
  <% shipping_snapshot = stripe_payment.shipping_name.present? ||
       stripe_payment.shipping_address_line1.present? ||
       stripe_payment.shipping_address_line2.present? ||
       stripe_payment.shipping_postal_code.present? ||
       stripe_payment.shipping_city.present? ||
       stripe_payment.shipping_country.present? %>
  <% city_line = [stripe_payment.shipping_postal_code, stripe_payment.shipping_city].map(&:presence).compact.join(" ") %>
  <% collapse_id = "stripePaymentDetail#{stripe_payment.id}" %>

  <%= card_main_model("Paiement Stripe", "cart-check", nil) %>

  <div class="card mx-2 mb-3 light-beige-colored shadow-sm">
    <div class="px-3 py-2">
      <%# Résumé : montants + statut %>
      <div class="d-flex flex-wrap align-items-center gap-2 column-gap-3">
        <div class="d-flex align-items-baseline flex-wrap gap-2">
          <% if stripe_payment.frais_livraison_centimes.present? %>
            <% sous_total_cents = stripe_payment.amount.to_i - stripe_payment.frais_livraison_centimes.to_i %>
            <span class="fw-bold"><%= custom_currency_format(stripe_payment.amount.to_f / 100) %> </span>
            <span class="small text-muted">
              (<%= custom_currency_format(sous_total_cents.to_f / 100) %> + <%= custom_currency_format(stripe_payment.frais_livraison_centimes.to_f / 100) %> livr.)
            </span>
          <% else %>
            <span class="fw-bold"><%= custom_currency_format(stripe_payment.amount.to_f / 100) %> <%= stripe_payment.currency&.upcase %></span>
          <% end %>
        </div>
        <span class="badge <%= stripe_payment.status == "paid" ? "bg-success" : "bg-secondary" %>"><%= stripe_payment.status %></span>
        <% if stripe_payment.payment_method.present? %>
          <span class="small text-muted text-nowrap"><i class="bi bi-credit-card me-1"></i><%= stripe_payment.payment_method.titleize %></span>
        <% end %>
        <span class="small text-muted ms-md-auto"><%= l(stripe_payment.created_at, format: :short) %></span>
      </div>

      <%# Client / livraison / Stripe : trois mini-cartes dans le collapse %>
      <div class="mt-2 pt-2 border-top">
        <a class="small text-muted text-decoration-none d-inline-flex align-items-center"
           data-bs-toggle="collapse"
           href="#<%= collapse_id %>"
           role="button"
           aria-expanded="false"
           aria-controls="<%= collapse_id %>">
          <i class="bi bi-chevron-down me-1" style="font-size: 0.7rem;"></i>
          Détails client, livraison, Stripe &amp; expédition
        </a>
        <div class="collapse mt-2" id="<%= collapse_id %>">
          <div class="row g-2 align-items-stretch">
            <%# Infos client (checkout Stripe) %>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
              <div class="small text-muted border rounded bg-white bg-opacity-50 p-2 flex-grow-1 w-100">
                <div class="text-muted fw-semibold mb-1" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.02em;">Client</div>
                <div class="small text-dark lh-sm text-break">
                  <div><span class="text-muted">Nom</span> <%= stripe_payment.shipping_name.presence || "—" %></div>
                  <div class="mt-1"><span class="text-muted">E-mail</span> <%= stripe_payment.customer_email.presence || "—" %></div>
                  <div class="mt-1"><span class="text-muted">Tél.</span> <%= stripe_payment.customer_phone.presence || "—" %></div>
                </div>
              </div>
            </div>

            <%# Livraison (Stripe) %>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
              <div class="small text-muted border rounded bg-white bg-opacity-50 p-2 flex-grow-1 w-100">
                <div class="text-muted fw-semibold mb-1" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.02em;">Livraison</div>
                <% if shipping_snapshot %>
                  <div class="small text-dark lh-sm text-break">
                    <% if stripe_payment.shipping_name.present? %>
                      <div> <%= stripe_payment.shipping_name %></div>
                    <% end %>
                    <% [stripe_payment.shipping_address_line1, stripe_payment.shipping_address_line2].each do |line| %>
                      <% if line.present? %>
                        <div class="mt-1"><%= line %></div>
                      <% end %>
                    <% end %>
                    <% if city_line.present? %>
                      <div class="mt-1"><%= city_line %></div>
                    <% end %>
                    <% if stripe_payment.shipping_country.present? %>
                      <div class="mt-1"><%= stripe_payment.shipping_country %></div>
                    <% end %>
                  </div>
                <% else %>
                  <p class="small text-muted mb-0 lh-sm">Adresse non enregistrée (paiement antérieur ou session incomplète).</p>
                <% end %>
              </div>
            </div>

            <%# Identifiants Stripe %>
            <div class="col-12 col-md-12 col-lg-4 d-flex">
              <div class="small text-muted border rounded bg-white bg-opacity-50 p-2 flex-grow-1 w-100">
                <div class="text-muted fw-semibold mb-1" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.02em;">Identifiants Stripe</div>
                <% if stripe_payment.stripe_payment_id.present? || stripe_payment.stripe_checkout_session_id.present? %>
                  <div class="font-monospace small text-dark lh-sm">
                    <% if stripe_payment.stripe_payment_id.present? %>
                      <div class="text-break">PI&nbsp;: <%= stripe_payment.stripe_payment_id %></div>
                    <% end %>
                    <% if stripe_payment.stripe_checkout_session_id.present? %>
                      <div class="text-break">CS&nbsp;: <%= stripe_payment.stripe_checkout_session_id %></div>
                    <% end %>
                  </div>
                <% else %>
                  <div class="small text-dark">—</div>
                <% end %>
                <% if stripe_payment.confirmation_email_sent_at.present? %>
                  <div class="small text-muted mt-2 lh-sm">
                    <i class="bi bi-check-circle me-1"></i>Confirmation e-mail le <%= l(stripe_payment.confirmation_email_sent_at, format: :short) %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>

          <%# Expédition (N° suivi + marquer expédié) %>
          <div class="mt-3 pt-2 border-top">
            <div class="small text-muted fw-semibold mb-2" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.02em;">Expédition</div>
            <% if @commande.expedie_le.present? %>
              <div class="d-flex align-items-center gap-2 flex-wrap">
                <span class="badge bg-success"><i class="bi bi-truck me-1"></i>Expédié</span>
                <span class="small text-muted">le <%= l(@commande.expedie_le, format: :short) %></span>
                <% if @commande.numero_suivi.present? %>
                  <span class="small fw-semibold font-monospace"><%= @commande.numero_suivi %></span>
                  <a href="https://www.laposte.fr/outils/suivre-vos-envois?code=<%= @commande.numero_suivi %>"
                     target="_blank" rel="noopener"
                     class="small text-decoration-none">
                    <i class="bi bi-box-arrow-up-right me-1"></i>Suivre le colis
                  </a>
                <% end %>
              </div>
            <% else %>
              <div class="d-flex align-items-center gap-2 flex-wrap">
                <label class="small fw-semibold mb-0" for="numero_suivi_input_<%= @commande.id %>">N° de suivi</label>
                <input type="text"
                       id="numero_suivi_input_<%= @commande.id %>"
                       class="form-control form-control-sm"
                       style="max-width: 220px;"
                       placeholder="ex : 1A12345678901"
                       oninput="document.querySelectorAll('.suivi-hidden-<%= @commande.id %>').forEach(el => el.value = this.value)">
                <button type="button"
                        class="btn btn-sm btn-warning"
                        data-bs-toggle="modal"
                        data-bs-target="#modal-expedition-<%= @commande.id %>">
                  <i class="bi bi-truck me-1"></i>Marquer expédié
                </button>
              </div>

              <div class="modal fade" id="modal-expedition-<%= @commande.id %>" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                  <div class="modal-content">
                    <div class="modal-header">
                      <h5 class="modal-title">Marquer comme expédié</h5>
                      <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                      Envoyer un email au client pour l'informer que son colis est en route ?
                    </div>
                    <div class="modal-footer">
                      <%= form_with url: marquer_expedie_with_email_admin_commande_path(@commande), method: :post, class: "d-inline" do %>
                        <input type="hidden" name="numero_suivi" value="" class="suivi-hidden-<%= @commande.id %>">
                        <button type="submit" class="btn btn-success">
                          <i class="bi bi-envelope me-1"></i>Avec email
                        </button>
                      <% end %>
                      <%= form_with url: marquer_expedie_without_email_admin_commande_path(@commande), method: :post, class: "d-inline" do %>
                        <input type="hidden" name="numero_suivi" value="" class="suivi-hidden-<%= @commande.id %>">
                        <button type="submit" class="btn btn-outline-secondary">
                          <i class="bi bi-truck me-1"></i>Sans email
                        </button>
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Synthèse : même format que badges_paiements_synthese — compte inclut Stripe ; Prix = total encaissé (articles + livraison) %>
  <% nb_paiements = @commande.paiement_recus.count + 1 %>
  <div class="card mx-2 rounded bg-secondary mb-3">
    <div class="container-fluid text-center py-1">
      <span class="badge fs-6 bg-secondary mx-1">
        Paiements: <span><%= nb_paiements %></span>
      </span>
      <span class="badge fs-6 bg-secondary mx-1">
        Prix: <span><%= custom_currency_format(stripe_payment.amount.to_f / 100) %></span>
      </span>
      <span class="badge fs-6 bg-secondary mx-1">
        Caution: <span><%= custom_currency_no_decimals_format(0) %></span>
      </span>
    </div>
  </div>
<% end %>
