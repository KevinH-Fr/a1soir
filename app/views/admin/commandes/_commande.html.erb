<div id="<%= dom_id commande %>">

  <div class="card mx-2 p-1 light-beige-colored shadow-sm">

    <div class="row">
      <div data-turbo="false" class="col">
        <%= link_to admin_commande_path(commande), class: "text-decoration-none text-dark" do %>

          <%#= custom_badge("", "", "", commande.ref_commande) %>
          <%= custom_badge("", "", "", "fw-bold", commande.full_name) %>
          <%= commande_eshop_badge(commande) %>
          <% if commande.eshop? && commande.expedie_le.present? %>
            <span class="badge border border-success text-success fw-semibold m-1 shadow-sm" title="Expédié le <%= l(commande.expedie_le, format: :short) %>">
              <i class="bi bi-truck me-1"></i>Expédié
            </span>
          <% end %>
          <%= custom_badge("", "", "", "", commande.client.full_name) %>
          <%= custom_badge("", "", "", "", commande.type_locvente) if commande.type_locvente %>
          <%= custom_badge("fa-calendar", "", "", "", commande.full_event) %>

          <%= custom_badge("", "", "", "", commande.profile&.prenom) %>
          <%= custom_badge("fa-hourglass-half", "devis", "", "", "") if commande.devis?  %>

        <% end %>

        <div class="my-2 p-1">
          <%= render partial: 'admin/commandes/toggles_statut', locals: { commande: commande } %>
        </div>

        <% if commande.eshop? %>
        <div class="mx-1 mb-2 px-2 py-1 rounded border border-warning border-opacity-25 bg-warning bg-opacity-10">
          <div class="d-flex align-items-start gap-1">
            <i class="bi bi-cart-check text-warning small"></i>
            <div class="small">
              <span class="fw-semibold">Vente e-shop</span>
              <span class="d-block text-muted mb-0">Cette commande provient d’un achat en ligne (paiement Stripe).</span>
            </div>
          </div>
        </div>
      <% end %>

        <% collapse_id = "collapseCommande#{dom_id(commande)}" %>
        <div class="d-flex flex-wrap align-items-center gap-2 mt-1 ms-1">
          <a class="small text-muted text-decoration-none d-inline-flex align-items-center"
             data-bs-toggle="collapse"
             href="#<%= collapse_id %>"
             role="button"
             aria-expanded="false"
             aria-controls="<%= collapse_id %>">
            <%= admin_collapse_details_button_content %>
          </a>
        </div>

      </div>
      <div class="col-auto text-end">
        <%= links_record(commande, turbo_delete: true, show_destroy: false) %>
      </div>

      <div class="">
        <div class="collapse" id="<%= collapse_id %>">
          <hr class="mt-2 mb-2 border-0 border-top border-secondary opacity-25">
          <div class="px-2">
            <div class="d-flex flex-wrap align-items-start gap-2">
              <%= image_tag(commande.qr_code, class: "rounded-start") if commande.qr_code.attached? %>

              <%= field_with_label("nom: ", commande.nom) %>
              <%= field_with_label("description: ", commande.description) %>
              <%= field_with_label("debut location: ", commande.debutloc) %>
              <%= field_with_label("fin location: ", commande.finloc) %>
              <%#= field_with_label("dateevent: ", commande.dateevent) %>
              <%# E-shop : commentaires = récap Stripe (livraison, PI…) — déjà sur la section Paiement Stripe, pas dans ce collapse %>
              <% unless commande.eshop? %>
                <%= field_with_label("commentaires: ", commande.commentaires) %>
              <% end %>
            </div>

            <div class="d-flex flex-wrap justify-content-end align-items-center gap-2 mt-2 pt-2 border-top border-secondary border-opacity-25">
              <% if commande.hard_destroy_allowed? %>
                <%= button_to admin_commande_path(commande),
                      method: :delete,
                      class: "btn btn-sm btn-danger d-inline-flex align-items-center",
                      form: { data: { turbo_confirm: "Êtes-vous certain de vouloir supprimer cette commande et les éléments liés ?" } } do %>
                  <i class="bi bi-trash me-1"></i>
                  <span>Supprimer</span>
                <% end %>
              <% else %>
                <span class="small text-muted">Suppression impossible (données liées, ex. paiements historiques).</span>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>