<div id="<%= dom_id avoir_remb %>">

  <div class="card mx-2 light-beige-colored shadow-sm">
    <div class="card-body p-2 d-flex flex-column">

      <div class="d-flex flex-wrap gap-2">
        <%= field_with_label("type", avoir_remb.type_avoir_remb, icon_class: "bi-tag") %>
        <%= field_with_label("montant", custom_currency_no_decimals_format(avoir_remb.montant), icon_class: "bi-cash-stack") %>
        <%= field_with_label("nature", avoir_remb.nature, icon_class: "bi-card-text") if avoir_remb.nature.present? %>
        <% if avoir_remb.custom_date.present? %>
          <%= field_with_label("date", avoir_remb.custom_date.strftime("%d/%m/%Y"), icon_class: "bi-calendar3") %>
        <% end %>
      </div>

      <% collapse_id = "collapseAvoirRemb#{dom_id(avoir_remb)}" %>
      <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mt-2">
        <button type="button"
                class="btn btn-link btn-sm small text-muted p-0 text-decoration-none d-inline-flex align-items-center shadow-none border-0"
                data-bs-toggle="collapse"
                data-bs-target="#<%= collapse_id %>"
                aria-expanded="false"
                aria-controls="<%= collapse_id %>">
          <%= admin_collapse_details_button_content %>
        </button>
        <div class="ms-auto">
          <%= links_record(avoir_remb) %>
        </div>
      </div>

      <div class="w-100 flex-shrink-0">
        <div class="collapse" id="<%= collapse_id %>">
          <hr class="mt-2 mb-2 border-0 border-top border-secondary opacity-25">
          <div class="d-flex flex-wrap gap-2 px-2">
            <%= field_with_label("enregistré le ", l(avoir_remb.created_at, format: :short), icon_class: "bi-clock") %>
          </div>
        </div>
      </div>

    </div>
  </div>

</div>
