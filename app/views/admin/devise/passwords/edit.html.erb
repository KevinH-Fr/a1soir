<div class="container admin-centered-page d-flex align-items-center py-1">
  <div class="row justify-content-center w-100">
    <div class="col-12 col-md-9 col-lg-6">
      <div class="card light-beige-colored shadow-sm border-0">
        <div class="card-header bg-dark text-light py-2 px-3">
          <i class="bi bi-shield-lock me-2" aria-hidden="true"></i>
          <strong>Nouveau mot de passe</strong>
        </div>
        <div class="card-body p-4 p-md-5">
          <div class="text-center mb-4">
            <p class="text-muted mb-0">Choisissez un nouveau mot de passe pour votre compte.</p>
          </div>

          <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
            <%= render "admin/devise/shared/error_messages", resource: resource %>
            <%= f.hidden_field :reset_password_token %>

            <div class="mb-3 text-start">
              <%= f.label :password, "Mot de passe", class: "form-label fw-semibold" %>
              <% if @minimum_password_length %>
                <div class="small text-muted mb-1">
                  <%= @minimum_password_length %> caractères minimum
                </div>
              <% end %>
              <%= f.password_field :password,
                    autofocus: true,
                    autocomplete: "new-password",
                    placeholder: "nouveau mot de passe...",
                    class: "form-control" %>
            </div>

            <div class="mb-4 text-start">
              <%= f.label :password_confirmation, "Confirmation", class: "form-label fw-semibold" %>
              <%= f.password_field :password_confirmation,
                    autocomplete: "new-password",
                    placeholder: "confirmation...",
                    class: "form-control" %>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2">
              <i class="fa-solid fa-square-check me-2"></i>
              <span class="fw-bold">Enregistrer le mot de passe</span>
            </button>
          <% end %>

          <div class="mt-4 text-center">
            <%= render "admin/devise/shared/links" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
