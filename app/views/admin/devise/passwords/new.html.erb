<div class="container admin-centered-page d-flex align-items-center py-1">
  <div class="row justify-content-center w-100">
    <div class="col-12 col-md-9 col-lg-6">
      <div class="card light-beige-colored shadow-sm border-0">
        <div class="card-header bg-dark text-light py-2 px-3">
          <i class="bi bi-key me-2" aria-hidden="true"></i>
          <strong>Mot de passe oublié</strong>
        </div>
        <div class="card-body p-4 p-md-5">
          <div class="text-center mb-4">
            <p class="text-muted mb-0">Indiquez votre adresse e-mail pour recevoir un lien et choisir un nouveau mot de passe.</p>
          </div>

          <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
            <%= render "admin/devise/shared/error_messages", resource: resource %>

            <div class="mb-4 text-start">
              <%= f.label :email, "Email", class: "form-label fw-semibold" %>
              <%= f.email_field :email,
                    autofocus: true,
                    autocomplete: "email",
                    placeholder: "email...",
                    class: "form-control" %>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2">
              <i class="fa-solid fa-paper-plane me-2"></i>
              <span class="fw-bold">Envoyer les instructions</span>
            </button>
          <% end %>

          <div class="mt-4 text-center">
            <%= render "admin/devise/shared/links" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
