
<div class="container admin-centered-page d-flex align-items-center py-1">
  <div class="row justify-content-center w-100">
    <div class="col-12 col-md-9 col-lg-6">
      <div class="card light-beige-colored shadow-sm border-0">
        <div class="card-header bg-dark text-light py-2 px-3">
          <i class="bi bi-person-lock me-2" aria-hidden="true"></i>
          <strong>Connexion Admin</strong>
        </div>
        <div class="card-body p-4 p-md-5">
          <div class="text-center mb-4">
            <p class="text-muted mb-0">Accèdez à votre espace d'administration</p>
          </div>

          <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
            <div class="mb-3 text-start">
              <%= f.label :email, "Email", class: "form-label fw-semibold" %>
              <%= f.email_field :email,
                    autofocus: true,
                    autocomplete: "email",
                    placeholder: "email...",
                    class: "form-control" %>
            </div>

            <div class="mb-3 text-start">
              <%= f.label :password, "Mot de passe", class: "form-label fw-semibold" %>
              <%= f.password_field :password,
                    autocomplete: "current-password",
                    placeholder: "mot de passe...",
                    class: "form-control" %>
            </div>

            <% if devise_mapping.rememberable? %>
              <div class="form-check form-switch d-flex justify-content-center align-items-center mb-4">
                <%= f.check_box :remember_me, class: "form-check-input fs-5 me-2" %>
                <%= f.label :remember_me, "Se souvenir de moi", class: "form-check-label" %>
              </div>
            <% end %>

            <button type="submit" class="btn btn-primary w-100 py-2">
              <i class="fa-solid fa-square-check me-2"></i>
              <span class="fw-bold">Connexion</span>
            </button>
          <% end %>

          <div class="mt-4 text-center">
            <%= render "admin/devise/shared/links" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>