<div id="<%= dom_id client %>" class="my-2">
  <div class="card mx-2 mb-3 light-beige-colored shadow-sm">
    <div class="card-body p-2 d-flex flex-column">

      <div class="card-title d-flex align-items-center flex-wrap gap-1">
        <div data-turbo="false">
          <%= link_to admin_client_path(client), class: "text-decoration-none text-dark" do %>
            <%= custom_badge("", "", "", "fw-bold", client.full_name) %>
          <% end %>
        </div>
        <%= custom_badge("", "", "", "", client.propart) if client.propart.present? %>
      </div>

      <% collapse_id = "collapseClient#{dom_id(client)}" %>
      <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mt-1">
        <a class="small text-muted text-decoration-none d-inline-flex align-items-center"
           data-bs-toggle="collapse"
           href="#<%= collapse_id %>"
           role="button"
           aria-expanded="false"
           aria-controls="<%= collapse_id %>">
          <%= admin_collapse_details_button_content %>
        </a>
        <div class="ms-auto">
          <%= links_record(client) %>
        </div>
      </div>

      <div class="">
        <div class="collapse" id="<%= collapse_id %>">
          <hr class="mt-2 mb-2 border-0 border-top border-secondary opacity-25">
          <div class="d-flex flex-wrap gap-2 px-2">
            <%= field_with_label("type: ", client.propart, icon_class: "bi-tag") %>
            <%= field_with_label("commentaires: ", client.commentaires, icon_class: "bi-chat-left-text") %>
            <%= field_with_label("intitule: ", client.intitule, icon_class: "bi-card-heading") %>
            <%= field_with_label("tel: ", client.tel, icon_class: "bi-telephone") %>
            <%= field_with_label("tel2: ", client.tel2, icon_class: "bi-telephone-fill") %>
            <%= field_with_label("mail: ", client.mail, icon_class: "bi-envelope") %>
            <%= field_with_label("mail2: ", client.mail2, icon_class: "bi-envelope-fill") %>
            <%= field_with_label("adresse: ", client.adresse, icon_class: "bi-geo-alt") %>
            <%= field_with_label("cp: ", client.cp, icon_class: "bi-mailbox") %>
            <%= field_with_label("ville: ", client.ville, icon_class: "bi-building") %>
            <%= field_with_label("pays: ", client.pays, icon_class: "bi-globe2") %>
            <%= field_with_label("contact: ", client.contact, icon_class: "bi-person") %>
            <%= field_with_label("langue: ", client.language_label, icon_class: "bi-translate") %>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
