<%= bandeau_entete("Stock", "boxes", "", "", "",
                    card_class: "card mt-2 mx-2 mb-0 shadow-sm rounded-bottom-0 border-bottom-0") %>

<div class="card mx-2 mb-3 mt-0 shadow-sm rounded-top-0 border-top-0 light-beige-colored">
  <div class="card-body p-0">

    <section class="border-bottom border-secondary-subtle px-3 py-4">
      <h2 class="h6 text-body-secondary text-uppercase small fw-semibold pb-2 mb-4 border-bottom border-secondary-subtle">
        Vue générale
      </h2>
      <div class="d-flex flex-wrap gap-3 gap-lg-4">
        <span class="badge rounded-3 border border-secondary-subtle text-bg-white text-dark fw-normal text-start text-wrap p-3 lh-sm d-inline-flex flex-column align-items-start gap-1 shadow-sm">
          <span class="small text-secondary text-uppercase fw-semibold">Total produits</span>
          <span class="fs-5 fw-bold text-body"><%= total_produits(@produits) %></span>
        </span>
        <span class="badge rounded-3 border border-secondary-subtle text-bg-white text-dark fw-normal text-start text-wrap p-3 lh-sm d-inline-flex flex-column align-items-start gap-1 shadow-sm">
          <span class="small text-secondary text-uppercase fw-semibold">Total loués</span>
          <span class="fs-5 fw-bold text-body"><%= total_loues(@produits) %></span>
        </span>
        <span class="badge rounded-3 border border-secondary-subtle text-bg-white text-dark fw-normal text-start text-wrap p-3 lh-sm d-inline-flex flex-column align-items-start gap-1 shadow-sm">
          <span class="small text-secondary text-uppercase fw-semibold">Total vendus</span>
          <span class="fs-5 fw-bold text-body"><%= total_vendus_boutique(@produits) + total_vendus_eshop(@produits) %></span>
        </span>
        <span class="badge rounded-3 border border-secondary-subtle text-bg-white text-dark fw-normal text-start text-wrap p-3 lh-sm d-inline-flex flex-column align-items-start gap-1 shadow-sm">
          <span class="small text-secondary text-uppercase fw-semibold">Dont e-shop</span>
          <span class="fs-5 fw-bold text-body"><%= total_vendus_eshop(@produits) %></span>
        </span>
        <span class="badge rounded-3 border border-secondary-subtle text-bg-white text-dark fw-normal text-start text-wrap p-3 lh-sm d-inline-flex flex-column align-items-start gap-1 shadow-sm">
          <span class="small text-secondary text-uppercase fw-semibold">Total services</span>
          <span class="fs-5 fw-bold text-body"><%= total_services(@produits) %></span>
        </span>
        <span class="badge rounded-3 border border-secondary-subtle text-bg-white text-dark fw-normal text-start text-wrap p-3 lh-sm d-inline-flex flex-column align-items-start gap-1 shadow-sm">
          <span class="small text-secondary text-uppercase fw-semibold">Services vendus</span>
          <span class="fs-5 fw-bold text-body"><%= articles_services_in_commandes %></span>
        </span>
      </div>

      <div class="mt-4 pt-4 border-top border-secondary-subtle">
        <% current_year = Date.today.year %>

        <div class="mb-3">
          <h3 class="h6 mb-2">Inventaires</h3>
          <div class="d-flex flex-wrap gap-2">
            <% [0, 1, 2].each do |offset| %>
              <% year = current_year - offset %>
              <%= link_to "Charger inventaire — fin #{year}",
                          admin_export_products_csv_path(year: year),
                          class: "btn btn-sm btn-primary" %>
            <% end %>
          </div>
        </div>

        <div>
          <h3 class="h6 mb-2">Reportings</h3>
          <div class="d-flex flex-wrap gap-2">
            <% [0, 1, 2].each do |offset| %>
              <% year = current_year - offset %>
              <%= link_to "Reporting annuel #{year}",
                          admin_stock_report_path(year: year),
                          class: "btn btn-sm btn-outline-primary" %>
            <% end %>
          </div>
        </div>
      </div>
    </section>

    <section class="px-3 py-4">
      <h2 class="h6 text-body-secondary text-uppercase small fw-semibold pb-2 mb-4 border-bottom border-secondary-subtle">
        Statut des produits loués
      </h2>
      <div class="d-flex flex-wrap gap-3 gap-lg-4">
        <span class="badge rounded-3 border border-secondary-subtle text-bg-white text-dark fw-normal text-start text-wrap p-3 lh-sm d-inline-flex flex-column align-items-start gap-1 shadow-sm">
          <span class="small text-secondary text-uppercase fw-semibold">Non retirés</span>
          <span class="fs-5 fw-bold text-body"><%= articles_loues_in_commandes_non_retires %></span>
        </span>
        <span class="badge rounded-3 border border-secondary-subtle text-bg-white text-dark fw-normal text-start text-wrap p-3 lh-sm d-inline-flex flex-column align-items-start gap-1 shadow-sm">
          <span class="small text-secondary text-uppercase fw-semibold">Retirés</span>
          <span class="fs-5 fw-bold text-body"><%= articles_loues_in_commandes_retires %></span>
        </span>
        <span class="badge rounded-3 border border-secondary-subtle text-bg-white text-dark fw-normal text-start text-wrap p-3 lh-sm d-inline-flex flex-column align-items-start gap-1 shadow-sm">
          <span class="small text-secondary text-uppercase fw-semibold">Rendus</span>
          <span class="fs-5 fw-bold text-body"><%= articles_loues_in_commandes_rendus %></span>
        </span>
      </div>
    </section>

  </div>
</div>
