<%= turbo_stream.append :produits do %>
  <%= render "produits" %>
<% end %>

<% if @pagy.next.present? %>
  <%= turbo_stream.replace :pagination do %>
    <%= turbo_frame_tag :pagination, loading: :lazy,
                        src: admin_type_produit_path(@type_produit, format: :turbo_stream, page: @pagy.next) %>
  <% end %>
<% else %>
  <%= turbo_stream.remove :pagination %>
<% end %>
