<% type_produit_compact_collapse = local_assigns[:index_collapse] && !type_produit.persisted? %>
<%= render layout: "admin/shared/form_card_shell",
           locals: {
             compact: type_produit_compact_collapse,
             embedded: local_assigns.fetch(:admin_form_row_embedded, false)
           } do %>
  <%= form_with(model: type_produit, url: type_produit.persisted? ? admin_type_produit_path(type_produit) : admin_type_produits_path, method: type_produit.persisted? ? :patch : :post, data: { turbo: true }) do |form| %>
    <% if type_produit.errors.any? %>
      <div style="color: red">
        <h2><%= pluralize(type_produit.errors.count, "error") %> prohibited this type_produit from being saved:</h2>

        <ul>
          <% type_produit.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= custom_form_elements(form,
      [:nom, :text_field]) %>

    <%= custom_submit_button(form) %>

  <% end %>
<% end %>
