<%# locals: nom, couleur_code, variant (:active | :alt) %>
<% badge_class = variant == :alt ? "etiquette-badge--couleur-alt" : "etiquette-badge--couleur-active" %>
<span class="etiquette-badge <%= badge_class %>">
  <table cellpadding="0" cellspacing="0" border="0" class="etiquette-badge__align" role="presentation">
    <tr>
      <td class="etiquette-badge__label" style="vertical-align:middle;line-height:1;padding:0;border:0;"><%= nom %></td>
      <td class="etiquette-badge__swatch-cell" style="vertical-align:middle;line-height:1;padding:0 0 2px 4px;border:0;">
        <span class="etiquette-badge__swatch" style="background-color:<%= couleur_code %>"></span>
      </td>
    </tr>
  </table>
</span>
