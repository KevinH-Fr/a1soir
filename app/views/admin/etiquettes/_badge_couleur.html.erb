<%# locals: nom, couleur_code, variant (:active | :alt) %>
<% border_class = variant == :alt ? "border-secondary text-muted" : "border-dark" %>
<span class="d-inline-flex align-items-center gap-1 border rounded px-1 small <%= border_class %>">
  <%= nom %>
  <span class="etiquette-swatch" style="background-color:<%= couleur_code %>;"></span>
</span>
