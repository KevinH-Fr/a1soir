<%# locals: produit %>
<div class="d-flex flex-column h-100">

  <%# Image produit (prend tout l'espace restant) %>
  <div class="etiquette-image-area p-2 d-flex align-items-center justify-content-center">
    <%= pdf_image_tag(produit.default_image, style: "width:100%;height:100%;object-fit:contain;") %>
  </div>

  <%# QR + nom + prix %>
  <div class="flex-shrink-0 px-2 pb-1">
    <div class="d-flex align-items-center gap-2">
      <% if produit.qr_code.attached? %>
        <div class="flex-shrink-0">
          <%= pdf_image_tag(produit.qr_code, style: "width:100px;height:100px;object-fit:contain;") %>
        </div>
      <% end %>
      <div class="flex-grow-1 overflow-hidden">
        <div class="fw-semibold lh-sm" style="font-size:10pt;"><%= produit.nom %></div>
        <div class="mt-1" style="font-size:10pt;line-height:1.3;">
          <% if produit.prixvente %>
            <% if produit.en_promotion? %>
              <span class="text-decoration-line-through text-muted">Vente : <%= number_to_currency(produit.ancien_prixvente, locale: :fr, precision: 0) %></span>
              <span class="ms-1 fw-bold">Vente : <%= number_to_currency(produit.prixvente, locale: :fr, precision: 0) %></span>
            <% else %>
              <span>Vente : <%= number_to_currency(produit.prixvente, locale: :fr, precision: 0) %></span>
            <% end %>
          <% end %>
          <% if produit.prixvente.present? && produit.prixlocation.present? %> &nbsp;·&nbsp; <% end %>
          <% if produit.prixlocation %>
            <span>Location : <%= number_to_currency(produit.prixlocation, locale: :fr, precision: 0) %></span>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# Tailles + couleurs %>
  <div class="flex-shrink-0 px-2 pb-2" style="font-size:10pt;line-height:1.5;">
    <% if produit.taille.present? %>
      <div class="mb-1">
        <span class="text-muted">Taille(s) :</span>
        <span class="border border-dark rounded px-1 text-uppercase small"><%= produit.taille.nom %></span>
        <% same_produit_same_couleur_others_tailles_with_statut_disponibilite(produit).sort_by { |p| p.taille&.nom.to_s }.each do |prod| %>
          <span class="border rounded px-1 text-uppercase small text-muted"><%= prod.taille.nom %></span>
        <% end %>
      </div>
    <% end %>
    <% if produit.couleur.present? %>
      <div>
        <span class="text-muted">Couleur(s) :</span>
        <%= render "admin/etiquettes/badge_couleur", nom: produit.couleur.nom, couleur_code: produit.couleur.couleur_code, variant: :active %>
        <% same_produit_same_taille_others_couleurs_with_statut_disponibilite(produit).each do |prod| %>
          <% if prod.couleur.present? %>
            <%= render "admin/etiquettes/badge_couleur", nom: prod.couleur.nom, couleur_code: prod.couleur.couleur_code, variant: :alt %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

</div>
