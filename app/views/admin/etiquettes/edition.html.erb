
<table>
  <% @produits.each_slice(2).with_index do |produits_pair| %>
    <tr>
      <% produits_pair.each do |produit| %>
        <% if produit.present? %>
          <td class="etiquette-cell">
            <%= render 'admin/etiquettes/produit_document', produit: produit %>
          </td>
        <% end %>
      <% end %>
    </tr>
  <% end %>
</table>

<div class="page-break"></div>

<!-- Back Side Section -->
<table>
  <% 2.times do %>
    <tr>
      <% 2.times do %>
        <td class="etiquette-cell">
          <% 12.times do %>
            <hr class="hr-doted">
          <% end %>
        </td>
      <% end %>
    </tr>
  <% end %>
</table>
