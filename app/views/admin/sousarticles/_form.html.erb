<div class="card mb-0 rounded-2 shadow-sm">
  <div class="card-body p-2 d-flex flex-column">

  <%= form_with(model: sousarticle, url: sousarticle.persisted? ? admin_sousarticle_path(sousarticle) : admin_sousarticles_path, method: sousarticle.persisted? ? :patch : :post, data: { turbo: true }) do |form| %>
    <% if sousarticle.errors.any? %>
      <div style="color: red">
        <h2><%= pluralize(sousarticle.errors.count, "error") %> prohibited this sousarticle from being saved:</h2>

        <ul>
          <% sousarticle.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% article_for_hidden = local_assigns[:article] %>
    <% article_record = article_for_hidden.is_a?(Article) ? article_for_hidden : (Article.find_by(id: article_for_hidden) if article_for_hidden.present?) %>
    <% article_record ||= @article %>
    <%= form.hidden_field :article_id, value: article_record.id if article_record %>

    <% produit_hidden_id = local_assigns[:produit_id].presence || @produit&.id %>
    <%= form.hidden_field :produit_id, value: produit_hidden_id if produit_hidden_id.present? %>

    <div class="d-flex flex-column gap-1 w-100">
      <%= custom_form_elements(form,
        [:nature, :text_field],
        [:description, :text_area],
        [:prix, :number_field, nil, { step: 0.01 }],
        [:caution, :number_field],
        [:commentaires, :text_area])
      %>

      <%= custom_submit_button(form) %>
    </div>

  <% end %>

  </div>
</div>
