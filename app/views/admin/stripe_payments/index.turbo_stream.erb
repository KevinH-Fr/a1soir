<%# stripe_payments infinite scroll (pagy countless) %>

<%= turbo_stream.append :stripe_payments do %>
  <%= render @stripe_payments %>
<% end %>

<% if @pagy.next.present? %>
  <%= turbo_stream.replace :pagination do %>
    <%= turbo_frame_tag :pagination, loading: :lazy,
                        src: admin_stripe_payments_path(format: :turbo_stream, page: @pagy.next) %>
  <% end %>
<% end %>
