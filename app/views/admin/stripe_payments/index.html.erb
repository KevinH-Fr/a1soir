<div class="container-fluid">
  <h1 class="h3 mb-4">Paiements e-shop (Stripe)</h1>

  <% if @stripe_payments.any? %>
    <div class="table-responsive">
      <table class="table table-striped table-bordered table-hover align-middle">
        <thead class="table-light">
          <tr>
            <th>Date</th>
            <th>Montant</th>
            <th>Statut</th>
            <th>Email client</th>
            <th>Commande</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @stripe_payments.each do |p| %>
            <tr>
              <td><%= l(p.created_at, format: :short) %></td>
              <td><%= number_to_currency(p.amount.to_f / 100, unit: "€", format: "%n %u", delimiter: " ") %></td>
              <td><%= p.status %></td>
              <td><%= p.customer_email.presence || "—" %></td>
              <td>
                <% if p.commande %>
                  <%= link_to p.commande.ref_commande, admin_commande_path(p.commande), class: "text-decoration-none" %>
                <% else %>
                  —
                <% end %>
              </td>
              <td><%= link_to "Détail", admin_stripe_payment_path(p), class: "btn btn-sm btn-outline-primary" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
  <% else %>
    <p class="text-muted">Aucun paiement Stripe enregistré.</p>
  <% end %>
</div>
