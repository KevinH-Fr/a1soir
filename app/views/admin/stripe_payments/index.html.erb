<%= bandeau_entete("Paiements e-shop (Stripe)", "credit-card", @stripe_payments_count.to_s, "", "",
                    card_class: "card mt-2 mx-2 mb-0 shadow-sm rounded-bottom-0 border-bottom-0",
                    show_new_record_button: false) %>

<div class="card mx-2 mb-3 mt-0 shadow-sm rounded-top-0 border-top-0 light-beige-colored">
  <div class="card-header py-2 px-3 bg-transparent border-bottom border-secondary-subtle">
    <span class="fw-semibold text-body">Historique</span>
    <span class="small text-body-secondary ms-1">— transactions Stripe, les plus récentes en premier</span>
  </div>
  <div class="card-body p-0">
    <% if @stripe_payments_count.zero? %>
      <div class="text-center text-muted py-5 px-3 m-3 rounded-3 border border-dashed border-secondary-subtle bg-body-secondary bg-opacity-10">
        <i class="bi bi-credit-card-2-front d-block fs-2 mb-2 opacity-50" aria-hidden="true"></i>
        <p class="mb-0 small">Aucun paiement Stripe enregistré.</p>
      </div>
    <% else %>
      <section class="px-3 py-3">
        <%= turbo_frame_tag :results, data: { turbo_action: "advance" } do %>
          <div class="table-responsive rounded-2 border border-secondary-subtle">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr class="small text-secondary">
                  <th scope="col" class="text-nowrap py-3 px-3">
                    <span class="d-inline-flex align-items-center gap-2">
                      <i class="bi bi-calendar3" aria-hidden="true"></i>
                      Date
                    </span>
                  </th>
                  <th scope="col" class="text-nowrap text-end py-3 px-3">
                    <span class="d-inline-flex align-items-center gap-2 justify-content-end w-100">
                      <i class="bi bi-cash-stack" aria-hidden="true"></i>
                      Montant
                    </span>
                  </th>
                  <th scope="col" class="text-nowrap py-3 px-3">
                    <span class="d-inline-flex align-items-center gap-2">
                      <i class="bi bi-flag" aria-hidden="true"></i>
                      Statut
                    </span>
                  </th>
                  <th scope="col" class="py-3 px-3">
                    <span class="d-inline-flex align-items-center gap-2">
                      <i class="bi bi-envelope" aria-hidden="true"></i>
                      E-mail client
                    </span>
                  </th>
                  <th scope="col" class="text-nowrap py-3 px-3">
                    <span class="d-inline-flex align-items-center gap-2">
                      <i class="bi bi-truck" aria-hidden="true"></i>
                      Expédition
                    </span>
                  </th>
                  <th scope="col" class="text-nowrap py-3 px-3">
                    <span class="d-inline-flex align-items-center gap-2">
                      <i class="bi bi-bag-check" aria-hidden="true"></i>
                      Commande
                    </span>
                  </th>
                </tr>
              </thead>
              <tbody id="stripe_payments"></tbody>
            </table>
          </div>

          <%= turbo_frame_tag :pagination, loading: :lazy,
                              src: admin_stripe_payments_path(format: :turbo_stream) %>
        <% end %>
      </section>
    <% end %>
  </div>
</div>
