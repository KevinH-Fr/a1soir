<%= I18n.t("stripe_payment_mailer.expedition.body.greeting") %>

<%= I18n.t("stripe_payment_mailer.expedition.body.intro") %>

<% if @payment.present? %>
<%= I18n.t("stripe_payment_mailer.confirmation.body.order_ref") %> : <%= @payment.commande&.ref_commande || "##{@payment.id}" %>
<% end %>

<% if @numero_suivi.present? %>
<%= I18n.t("stripe_payment_mailer.expedition.body.tracking_label") %> : <%= @numero_suivi %>
<% if @tracking_url.present? %>
<%= I18n.t("stripe_payment_mailer.expedition.body.tracking_link_label") %> <%= @tracking_url %>
<% end %>
<% else %>
<%= I18n.t("stripe_payment_mailer.expedition.body.no_tracking") %>
<% end %>

<%= I18n.t("stripe_payment_mailer.expedition.body.produits_title") %>

<% @items.each do |item| %>
<% produit = item.produit %>
<% if produit.present? %>
- <%= produit.nom %> — <%= I18n.t("stripe_payment_mailer.confirmation.body.quantity", n: item.quantity || 1) %>
<% end %>
<% end %>

<% if @payment.present? %>
<% subtotal_cents = @payment.amount.to_i - @payment.frais_livraison_centimes.to_i %>
<%= I18n.t("stripe_payment_mailer.expedition.body.subtotal_label") %> : <%= number_to_currency(subtotal_cents.to_f / 100, unit: "€", format: "%n %u", delimiter: " ") %>
<%= I18n.t("stripe_payment_mailer.expedition.body.shipping_label") %> : <%= @payment.frais_livraison_centimes.to_i == 0 ? I18n.t("stripe_payment_mailer.expedition.body.shipping_free") : number_to_currency(@payment.frais_livraison_centimes.to_f / 100, unit: "€", format: "%n %u", delimiter: " ") %>
<%= I18n.t("stripe_payment_mailer.expedition.body.total_label") %> : <%= number_to_currency(@payment.amount.to_f / 100, unit: "€", format: "%n %u", delimiter: " ") %> (<%= @payment.currency&.upcase %>)
<% end %>

<%= I18n.t("stripe_payment_mailer.expedition.body.thanks") %>
