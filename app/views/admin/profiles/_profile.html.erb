<div id="<%= dom_id profile %>" class="my-2">
  <div class="card mx-2 my-3 light-beige-colored shadow-sm">
    <div class="card-body p-2 d-flex flex-column gap-2">
      <div class="row g-0 gx-2 gy-1 align-items-center">
        <div class="col-auto">
          <%= image_tag(profile.default_image, class: "img-fluid rounded", style: "max-width: 4.5rem") %>
        </div>
        <div class="col min-w-0">
          <div class="d-flex flex-wrap gap-1">
            <%= field_with_label("Prenom:", profile.prenom) %>
            <%= field_with_label("Nom:", profile.nom) %>
          </div>
        </div>
      </div>

      <%= links_record(profile) %>
    </div>
  </div>
</div>
