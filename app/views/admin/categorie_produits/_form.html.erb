<div class="card mx-2 my-3 p-2 light-beige-colored shadow-sm">

  <%= form_with(model: categorie_produit, url: categorie_produit.persisted? ? admin_categorie_produit_path(categorie_produit) : admin_categorie_produits_path, method: categorie_produit.persisted? ? :patch : :post, data: { turbo: true }) do |form| %>
    <% if categorie_produit.errors.any? %>
      <div style="color: red">
        <h2><%= pluralize(categorie_produit.errors.count, "error") %> prohibited this categorie_produit from being saved:</h2>

        <ul>
          <% categorie_produit.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= custom_form_elements(form, 
      [:nom, :text_field], [:texte_annonce, :text_area], [:label, :text_field],  [:service, :check_box]) %>

    <div class="p-2">
      <div class="row g-2">
        <div class="col-12">
          <%= form.label :image1, "Image principale", class: "form-label mb-1" %>
          <%= form.file_field :image1,
                class: "form-control form-control-sm",
                accept: "image/jpeg,image/png,image/gif,image/jpg,image/webp,.jpg,.jpeg,.png,.webp,.gif" %>
          <div class="form-text">Formats : JPG/JPEG, PNG, WEBP, GIF</div>
        </div>
      </div>
    </div>
    
    <%= custom_submit_button(form) %>

  <% end %>

</div>