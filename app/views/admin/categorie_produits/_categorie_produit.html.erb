<div id="<%= dom_id categorie_produit %>">
  <div class="card mx-2 light-beige-colored shadow-sm">
    <div class="card-body p-2">
      <div class="row g-0 flex-grow-1 align-items-center">

        <div class="col-sm-2 text-center">
          <div data-turbo="false">
            <%= link_to image_tag(categorie_produit.default_image, class: "img-fluid"),
                  admin_categorie_produit_path(categorie_produit) %>
          </div>
        </div>

        <div class="col-sm-10 d-flex flex-column ps-sm-2">

          <div class="d-flex flex-wrap gap-1 text-truncate">
            <%= field_with_label("Nom:", categorie_produit.nom) %>
            <%= icon_true_field_with_label("service", categorie_produit.service) %>
            <%= field_with_label("Texte:", categorie_produit.texte_annonce) %>
            <%= field_with_label("Label:", categorie_produit.label) %>
          </div>

          <div class="mt-auto pt-1">
            <%= links_record(categorie_produit) %>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>
