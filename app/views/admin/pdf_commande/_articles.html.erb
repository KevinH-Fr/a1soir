<% eshop = @doc_edition.commande.eshop? %>

<div class="pdf-section-header mt-4 mb-2">Articles</div>

<table class="table table-sm table-bordered mb-0">
  <thead class="table-secondary">
    <tr>
      <th class="text-center" style="width:32px">#</th>
      <th style="width:80px"></th>
      <th>Désignation</th>
      <th class="text-center" style="width:60px">Qté</th>
      <th class="text-end" style="width:90px">P.U.</th>
      <th class="text-end" style="width:90px">Prix</th>
      <% unless eshop %>
        <th class="text-end" style="width:90px">Caution</th>
      <% end %>
    </tr>
  </thead>
  <tbody>
    <% @doc_edition.commande.articles.each_with_index do |article, i| %>
      <tr>
        <td class="text-center align-middle text-muted small"><%= i + 1 %></td>
        <td class="text-center align-middle">
          <%= pdf_product_thumb_tag(article.produit.default_image, width: 80, class: "img-fluid rounded pdf-thumb") %>
        </td>
        <td class="align-middle">
          <div class="fw-bold small"><%= article.produit.nom %></div>
          <div class="text-muted" style="font-size:11px;">
            <%= "Couleur : #{article.produit.couleur.nom}" if article.produit.couleur.present? %>
            <%= "&nbsp;·&nbsp; Taille : #{article.produit.taille.nom}".html_safe if article.produit.taille.present? %>
            <%= "&nbsp;·&nbsp; #{article.commentaires}".html_safe if article.commentaires.present? %>
            <%= "&nbsp;·&nbsp; location longue durée".html_safe if article.longueduree %>
          </div>
        </td>
        <td class="text-center align-middle"><%= article.quantite %></td>
        <td class="text-end align-middle"><%= custom_currency_format(article.prix) %></td>
        <td class="text-end align-middle"><%= custom_currency_format(article.total) %></td>
        <% unless eshop %>
          <td class="text-end align-middle"><%= custom_currency_format(article.caution) %></td>
        <% end %>
      </tr>

      <% article.sousarticles.each do |sousarticle| %>
        <tr>
          <td colspan="2"></td>
          <td class="align-middle">
            <div class="d-flex align-items-center gap-2">
              <div class="flex-shrink-0">
                <%= pdf_product_thumb_tag(sousarticle.produit.default_image, width: 40, class: "img-fluid rounded pdf-thumb-sm") %>
              </div>
              <div class="flex-grow-1 small">
                <div class="fw-bold"><%= sousarticle.produit.nom %></div>
                <div class="text-muted">
                  <%= sousarticle.produit&.couleur&.nom %>
                  <%= sousarticle.produit&.taille&.nom %>
                </div>
                <div class="text-muted"><%= sousarticle.nature %> <%= sousarticle.description %> <%= sousarticle.commentaires %></div>
              </div>
            </div>
          </td>
          <td></td>
          <td class="text-end align-middle"><%= custom_currency_format(sousarticle.prix) %></td>
          <td class="text-end align-middle"><%= custom_currency_format(sousarticle.prix) %></td>
          <% unless eshop %>
            <td class="text-end align-middle"><%= custom_currency_format(sousarticle.caution) %></td>
          <% end %>
        </tr>
      <% end %>
    <% end %>

    <% if pdf_afficher_livraison?(@doc_edition.commande) %>
      <% livraison_euros = frais_livraison_stripe_euros(@doc_edition.commande) %>
      <tr>
        <td class="text-center align-middle text-muted small"><%= @doc_edition.commande.articles.size + 1 %></td>
        <td></td>
        <td class="align-middle fw-bold small"><%= t("pdf_commande.livraison.label") %></td>
        <td class="text-center align-middle">1</td>
        <td class="text-end align-middle" colspan="2">
          <% if livraison_euros.positive? %>
            <%= custom_currency_format(livraison_euros) %>
          <% else %>
            <span class="badge bg-success"><%= t("pdf_commande.livraison.offert") %></span>
          <% end %>
        </td>
        <% unless eshop %>
          <td class="text-end align-middle"></td>
        <% end %>
      </tr>
    <% end %>
  </tbody>

  <tfoot class="table-light">
    <tr class="fw-bold">
      <td colspan="3" class="text-end text-muted small">Total</td>
      <td class="text-center"><%= compte_articles(@doc_edition.commande) %></td>
      <td></td>
      <td class="text-end"><%= custom_currency_format(du_prix(@doc_edition.commande)) %></td>
      <% unless eshop %>
        <td class="text-end"><%= custom_currency_format(du_caution(@doc_edition.commande)) %></td>
      <% end %>
    </tr>

    <% if @doc_edition.doc_type == "facture" %>
      <tr>
        <td colspan="6" class="text-end small">
          <div><span class="text-muted">Total HT :</span> <%= number_to_currency(du_prix_ht(@doc_edition.commande), unit: "€", separator: ",", delimiter: " ", format: "%n %u") %></div>
          <div><span class="text-muted">TVA :</span> <%= number_to_currency(tva_sur_prix(@doc_edition.commande), unit: "€", separator: ",", delimiter: " ", format: "%n %u") %></div>
          <div class="fw-bold"><span class="text-muted">Total TTC :</span> <%= number_to_currency(du_prix(@doc_edition.commande), unit: "€", separator: ",", delimiter: " ", format: "%n %u") %></div>
        </td>
        <% unless eshop %>
          <td></td>
        <% end %>
      </tr>
    <% end %>
  </tfoot>
</table>
