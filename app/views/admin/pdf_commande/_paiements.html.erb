<% commande = @doc_edition.commande %>
<% stripe_payment = commande.stripe_payment %>
<% afficher_stripe = commande.eshop? && stripe_payment&.status == "paid" %>

<% if pdf_afficher_paiements?(commande) %>
  <div class="pdf-no-break mt-4">

    <div class="pdf-section-header mb-2">Paiements reçus</div>

    <table class="table table-sm table-bordered mb-0">
      <thead class="table-secondary">
        <tr>
          <th class="text-center" style="width:32px">#</th>
          <th>Mode</th>
          <th class="text-center">Date</th>
          <th class="text-end">Prix</th>
          <th class="text-end">Caution</th>
        </tr>
      </thead>
      <tbody>
        <% row_index = 0 %>
        <% commande.paiement_recus.each_with_index do |paiement, i| %>
          <% row_index = i + 1 %>
          <tr>
            <td class="text-center align-middle text-muted small"><%= row_index %></td>
            <td class="align-middle small"><%= paiement.moyen %></td>
            <td class="text-center align-middle small"><%= paiement.custom_date.strftime("%d/%m/%y") if paiement.custom_date.present? %></td>
            <td class="text-end align-middle"><%= custom_currency_format(paiement.montant) if paiement.typepaiement == "prix" %></td>
            <td class="text-end align-middle"><%= custom_currency_format(paiement.montant) if paiement.typepaiement == "caution" %></td>
          </tr>
        <% end %>

        <% if afficher_stripe %>
          <% row_index += 1 %>
          <% stripe_label = t("pdf_commande.paiement_stripe.moyen") %>
          <% stripe_label = "#{stripe_label} (#{stripe_payment.payment_method.titleize})" if stripe_payment.payment_method.present? %>
          <tr>
            <td class="text-center align-middle text-muted small"><%= row_index %></td>
            <td class="align-middle small"><%= stripe_label %></td>
            <td class="text-center align-middle small"><%= stripe_payment.created_at.strftime("%d/%m/%y") %></td>
            <td class="text-end align-middle"><%= custom_currency_format(recu_prix_stripe_euros(commande)) %></td>
            <td class="text-end align-middle"></td>
          </tr>
        <% end %>
      </tbody>
      <tfoot class="table-light fw-bold">
        <tr>
          <td colspan="3" class="text-end text-muted small">Total reçu</td>
          <td class="text-end"><%= custom_currency_format(recu_prix(commande)) %></td>
          <td class="text-end"><%= custom_currency_format(recu_caution(commande)) %></td>
        </tr>
      </tfoot>
    </table>

  </div>
<% end %>
