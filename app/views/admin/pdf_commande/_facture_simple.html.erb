<div class="pdf-section-header mt-4 mb-2">Désignation</div>

<table class="table table-sm table-bordered mb-0">
  <thead class="table-secondary">
    <tr>
      <th class="w-75">Article</th>
      <th class="text-end">Montants</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td class="align-middle p-2"><%= @doc_edition.label_facture_simple %></td>
      <td class="align-top text-end p-2 small">
        <div><span class="text-muted">Total HT :</span> <%= number_to_currency(du_prix_ht(@doc_edition.commande), unit: "€", separator: ",", delimiter: " ", format: "%n %u") %></div>
        <div><span class="text-muted">TVA :</span> <%= number_to_currency(tva_sur_prix(@doc_edition.commande), unit: "€", separator: ",", delimiter: " ", format: "%n %u") %></div>
        <div class="fw-bold"><span class="text-muted">Total TTC :</span> <%= number_to_currency(du_prix(@doc_edition.commande), unit: "€", separator: ",", delimiter: " ", format: "%n %u") %></div>
      </td>
    </tr>
  </tbody>
</table>

<%= render "admin/pdf_commande/paiements" %>
<%= render "admin/pdf_commande/mentions" %>
