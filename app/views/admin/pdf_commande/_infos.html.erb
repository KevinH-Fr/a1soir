<div class="row g-3 mb-2">

  <%# Bloc client : 2/3 gauche %>
  <div class="col-8">
    <div class="mb-3">
      <div class="text-muted text-uppercase pdf-label">Client</div>
      <div class="fw-bold fs-5"><%= @doc_edition.commande.client.full_name %></div>
    </div>

    <% if @doc_edition.commande.eshop? %>
      <div class="mb-2">
        <span class="badge bg-dark me-1">e-shop</span>
        <span class="small text-muted">Commande issue du site, paiement en ligne</span>
      </div>
    <% end %>

    <div class="small mb-1">
      Langue : <strong><%= @doc_edition.commande.client.language_label %></strong>
      <% if @doc_edition.commande.client.contact.present? %>
        &nbsp;·&nbsp; Contact : <strong><%= @doc_edition.commande.client.contact %></strong>
      <% end %>
    </div>

    <% if @doc_edition.commande.typeevent.present? %>
      <div class="small mb-1">
        Événement : <strong><%= @doc_edition.commande.full_event %></strong>
      </div>
    <% end %>

    <% if @doc_edition.commande.debutloc %>
      <div class="fw-bold small mb-1"><%= @doc_edition.commande.label_dates_location %></div>
    <% end %>

    <div class="small mt-2">
      <div>Mail : <strong><%= @doc_edition.commande.client.mail %></strong></div>
      <div>Tél : <strong><%= @doc_edition.commande.client.tel %></strong></div>
      <% if @doc_edition.commande.client.adresse.present? %>
        <div class="mt-1">
          Adresse : <%= @doc_edition.commande.client.adresse %><br>
          <%= @doc_edition.commande.client.cp %> <%= @doc_edition.commande.client.ville %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Bloc document : 1/3 droit %>
  <div class="col-4">
    <div class="border rounded p-2 bg-light text-center h-100">
      <div class="fw-bold text-uppercase fs-5 mb-1"><%= pdf_titre_document(@doc_edition.commande, @doc_edition) %></div>

      <% if pdf_afficher_annulation_eshop?(@doc_edition.commande, @doc_edition) %>
        <span class="badge bg-danger mb-1"><%= t("pdf_commande.annulee.stamp") %></span>
      <% end %>

      <hr class="my-1">

      <div class="small">
        <div><span class="text-muted">Réf.</span> <strong><%= @doc_edition.commande.ref_commande %></strong></div>
        <div><span class="text-muted">Date</span> <strong><%= @doc_edition.commande.created_at.strftime("%d/%m/%Y") %></strong></div>
      </div>

      <% if @doc_edition.commande.qr_code.present? %>
        <div class="mt-1">
          <%= pdf_image_tag(@doc_edition.commande.qr_code, class: "pdf-qr") %>
        </div>
      <% end %>

      <% unless @doc_edition.commande.eshop? %>
        <hr class="my-1">
        <div class="small">
          <div><span class="text-muted">Servi par</span> <span class="fw-bold"><%= @doc_edition.commande.profile.full_name %></span></div>
          <div><span class="text-muted">Statut</span> <span class="fw-bold"><%= @doc_edition.commande.statutarticles %></span></div>
        </div>
      <% end %>
    </div>
  </div>

</div>

<hr class="border-secondary mb-0">
