<table width="100%" style="border-style: hidden;">
  <tr>
    <!-- Left Side: Existing Content -->
    <td style="vertical-align: top; width: 80%; border-style: hidden;">
      <span>Client </span> 
      <span class="doc-important"> <%= @doc_edition.commande.client.full_name %> </span> <br>

      <% if @doc_edition.commande.eshop? %>
        <br>
        <span class="doc-important">Vente e-shop</span> <span>(commande issue du site, paiement en ligne)</span><br>
      <% end %>

      <% if pdf_afficher_annulation_eshop?(@doc_edition.commande, @doc_edition) %>
        <br>
        <div style="border: 2px solid #333; padding: 8px; margin: 8px 0;">
          <div class="doc-important" style="font-size: 14px;"><%= t("pdf_commande.annulee.title") %></div>
          <div style="margin-top: 4px;"><%= t("pdf_commande.annulee.body") %></div>
          <% if @doc_edition.commande.date_remboursement_eshop.present? %>
            <div style="margin-top: 4px;">
              <%= t("pdf_commande.annulee.date_label", date: @doc_edition.commande.date_remboursement_eshop.strftime("%d/%m/%Y")) %>
            </div>
          <% end %>
        </div>
      <% end %>

      <br>

      <span>Langue : <%= @doc_edition.commande.client.language_label %>  </span> 

      <% if @doc_edition.commande.client.contact.present? %>
        <div>Contact : <%= @doc_edition.commande.client.contact %>  </div> 
      <% end %>
      <br>
      
      <% if @doc_edition.commande.typeevent.present? %>
          <br>
          <span>Evénement</span>
          <span> <%= @doc_edition.commande.full_event %> </span> <br>
      <% end %>

      <% if @doc_edition.commande.debutloc %>
          <span class="doc-important"> <%= @doc_edition.commande.label_dates_location %> </span> <br>
      <% end %>

      <br>
      Mail : <span class="doc-important"> <%= @doc_edition.commande.client.mail %> </span> <br>
      Téléphone : <span class="doc-important"> <%= @doc_edition.commande.client.tel %> </span> <br>

      <% if @doc_edition.commande.client.adresse.present? %>
        Adresse :
        <%= @doc_edition.commande.client.adresse %> <br>
        <%= @doc_edition.commande.client.cp %> 
        <%= @doc_edition.commande.client.ville %>          
      <% end %>

    </td>

    <td style="vertical-align: top; text-align: center; width: 20%; border-style: hidden;">

      <div class="doc-important"><%= pdf_titre_document(@doc_edition.commande, @doc_edition) %></div>

      <% if pdf_afficher_annulation_eshop?(@doc_edition.commande, @doc_edition) %>
        <div class="doc-important" style="font-size: 13px; margin-top: 4px;"><%= t("pdf_commande.annulee.stamp") %></div>
      <% end %>

      <div class="doc-important"><%= @doc_edition.commande.ref_commande %></div>
      <div class="doc-important"><%= @doc_edition.commande.created_at.strftime("%d/%m/%Y") %></div>

      <% if @doc_edition.commande.qr_code.present? %>
        <div>
          <%= image_tag(@doc_edition.commande.qr_code, class: "img-qr-etiquette") %>
        </div>
      <% end %>

      <% unless @doc_edition.commande.eshop? %>
        <div>
          Servi par
          <span class="doc-important"> <%= @doc_edition.commande.profile.full_name %> </span>
        </div>

        <div>Statut
          <span class="doc-important"> <%= @doc_edition.commande.statutarticles %> </span>
        </div>
      <% end %>

    </td>

  </tr>
</table>
