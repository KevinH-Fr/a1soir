<% if @doc_edition.commentaires.present? %>
  <div class="border-start border-3 border-secondary bg-light rounded-end p-3 mt-4 small">
    <div class="fw-bold text-secondary mb-1 text-uppercase pdf-label">Commentaires</div>
    <%= @doc_edition.commentaires %>
  </div>
<% end %>

<% if @doc_edition.commande.meetings.where('datedebut > ?', DateTime.now).exists? %>
  <div class="border-start border-3 border-secondary bg-light rounded-end p-3 mt-2 small">
    <div class="fw-bold text-secondary mb-1 text-uppercase pdf-label">Prochain rendez-vous</div>
    <%= @doc_edition.commande.meetings.first.start_time.strftime("%d/%m/%Y à %H:%M") %>
  </div>
<% end %>

<div class="border rounded p-3 mt-4 small fst-italic text-muted text-center">
  <% locale = @doc_edition.commande.client&.language.presence || :fr %>
  <% I18n.with_locale(locale) do %>
    <% if @doc_edition.commande.eshop? %>
      <span class="fw-bold d-block mb-1"><%= t("pdf_commande.mentions.eshop_returns.title") %></span>
      <%= t("pdf_commande.mentions.eshop_returns.body") %>
    <% else %>
      <%= t("pdf_commande.mentions.reservation") %><br>
      <%= t("pdf_commande.mentions.rental_late") %>
    <% end %>
  <% end %>
</div>
