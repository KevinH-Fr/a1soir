<% if @doc_edition.commentaires.present? %>
    <div class="cadre my-2">
    <span class="bolded">Commentaires </span> 
    <span class=""> <%= @doc_edition.commentaires %> </span> <br>
    <br>
    </div>
<% end %>

<% if @doc_edition.commande.meetings.where('datedebut > ?', DateTime.now).exists? %>
<br>
    <div class="cadre my-2">
        <span class="bolded">Prochain rendez-vous : </span> 
        <span class=""> 
            <%= @doc_edition.commande.meetings.first.start_time.strftime("%d/%m/%y" " à %H:%M") %> 
        </span> <br>
    </div>
<% end %>

<br>
<div class="cadre my-2 bloc-mention mt-2">
  <% locale = @doc_edition.commande.client&.language.presence || :fr %>
  <% I18n.with_locale(locale) do %>
    <% if @doc_edition.commande.eshop? %>
      <span class="bolded"><%= t("pdf_commande.mentions.eshop_returns.title") %></span><br>
      <%= t("pdf_commande.mentions.eshop_returns.body") %>
    <% else %>
      <%= t("pdf_commande.mentions.reservation") %><br>
      <%= t("pdf_commande.mentions.rental_late") %>
    <% end %>
  <% end %>
</div>