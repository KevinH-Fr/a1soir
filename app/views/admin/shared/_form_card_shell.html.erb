<%#
  Enveloppe carte unique pour les formulaires admin (Rails : render layout + bloc).

  locals :
  - compact  : true = formulaire « Nouveau » dans le collapse index (bloc_nouveau)
  - embedded : true = turbo_stream.update(dom_id) sur fiche commande / liste admin ;
               même gabarit que admin/paiement_recus/_form : card my-0 + card-body p-2
               (admin_list_stack_classes apporte déjà gap-2 entre les lignes — pas de my-3).

  Page new/edit : compact et embedded false → carte pleine page p-3 my-2 (sous h1).
%>
<% card_base = "card mx-2 light-beige-colored shadow-sm" %>
<% if compact %>
<div class="<%= card_base %> p-3 my-0">
  <%= yield %>
</div>
<% elsif embedded %>
<div class="<%= card_base %> my-0">
  <div class="card-body p-2 d-flex flex-column">
    <%= yield %>
  </div>
</div>
<% else %>
<div class="<%= card_base %> p-3 my-2">
  <%= yield %>
</div>
<% end %>
