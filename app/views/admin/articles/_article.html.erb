
<div id="<%= dom_id article %>">

  <div class="card mx-2 light-beige-colored shadow-sm">
    <div class="card-body p-2 d-flex flex-column">

      <div class="row align-items-center">
        <div class="col-sm-3 text-center">
          <%= image_tag(article.produit.default_image, class: "img-produit rounded") %>
        </div>

        <div class="col-sm-9 ps-2">
          <h5 class="fw-bold m-1 mb-2"><%= article.produit.nom %></h5>
          <div class="d-flex flex-wrap gap-2">
            <%= field_with_label("", article.locvente) %>
            <%= field_with_label("couleur", article.produit&.couleur&.nom) %>
            <%= field_with_label("taille", article.produit&.taille&.nom) %>
            <%= field_with_label("qté", article.quantite) %>
            <%= field_with_label("prix", custom_currency_format(article.prix)) %>
            <%= field_with_label("total", custom_currency_format(article.total)) %>

            <% if article.caution %>
              <%= field_with_label("caution", custom_currency_no_decimals_format(article.caution)) %>
            <% end %>

            <% if article.longueduree %>
              <%= field_with_label("longue durée", article.longueduree) %>
            <% end %>
          </div>
        </div>
      </div>

      <% collapse_id = "collapseArticle#{dom_id(article)}" %>
      <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mt-2">
        <button type="button"
                class="btn btn-link btn-sm small text-muted p-0 text-decoration-none d-inline-flex align-items-center shadow-none border-0"
                data-bs-toggle="collapse"
                data-bs-target="#<%= collapse_id %>"
                aria-expanded="false"
                aria-controls="<%= collapse_id %>">
          <%= admin_collapse_details_button_content %>
        </button>
        <div class="ms-auto">
          <%= links_record(article) %>
        </div>
      </div>

      <div class="w-100 flex-shrink-0">
        <div class="collapse" id="<%= collapse_id %>">
          <hr class="mt-2 mb-2 border-0 border-top border-secondary opacity-25">
          <div class="d-flex flex-wrap gap-2 px-2">
            <% if article.commentaires.present? %>
              <%= field_with_label("commentaires: ", article.commentaires, icon_class: "bi-chat-left-text") %>
            <% else %>
              <p class="small text-muted mb-0">Aucun commentaire.</p>
            <% end %>
          </div>
        </div>
      </div>

      <div class="mt-2">
        <%= link_to admin_selection_produit_path(commande: @commande, article: article),
                    class: "btn btn-sm btn-warning fw-bold" do %>
          <i class="bi bi-plus-lg"></i>
          <span>Sous-article</span>
        <% end %>
      </div>

      <% if article.sousarticles.present? %>
        <div class="container-fluid card my-2 p-3">
          <h6 class="fw-bold mb-2">Sous-articles:</h6>
          <div class="d-flex flex-column gap-2">
            <% article.sousarticles.each do |sousarticle| %>
              <%= render partial: "admin/sousarticles/sousarticle", locals: { sousarticle: sousarticle } %>
            <% end %>
          </div>
        </div>
      <% end %>

    </div>
  </div>

</div>
