<div id="<%= dom_id(type_rdv) %>" class="card border border-secondary-subtle shadow-sm rounded-3 mb-0">
  <div class="card-body p-3">
    <div class="row g-3">
      <div class="col-md-6">
        <div class="small text-muted mb-0">Nom</div>
        <div class="fw-semibold text-break"><%= type_rdv.code %></div>
      </div>
      <div class="col-md-6">
        <div class="small text-muted mb-0">Durée de base (minutes)</div>
        <div class="fw-semibold"><%= type_rdv.duree_base_minutes %></div>
      </div>
    </div>

    <div class="d-flex justify-content-end pt-3 mt-2 mt-md-3 border-top border-secondary-subtle">
      <%= links_record(type_rdv) %>
    </div>
  </div>
</div>
