<% type_rdv_local = local_assigns[:type_rdv] || @type_rdv %>
<div<% if type_rdv_local.persisted? %> id="<%= dom_id(type_rdv_local) %>"<% end %> class="card border border-secondary-subtle shadow-sm rounded-3 mb-0">
  <% if type_rdv_local.new_record? %>
    <div class="card-header py-2 px-3 bg-transparent border-bottom border-secondary-subtle small fw-semibold text-secondary d-flex align-items-center gap-2">
      <i class="bi bi-ui-checks-grid" aria-hidden="true"></i>
      Nouveau type de RDV
    </div>
  <% end %>
  <%= form_with model: [:admin, type_rdv_local],
                url: type_rdv_local.persisted? ? admin_type_rdv_path(type_rdv_local) : admin_type_rdvs_path,
                class: "d-flex flex-column" do |f| %>
    <div class="card-body p-3">
      <% if type_rdv_local.errors.any? %>
        <div class="alert alert-danger py-2 px-3 mb-3">
          <ul class="mb-0 small">
            <% type_rdv_local.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="row g-3">
        <div class="col-md-6">
          <div class="form-floating">
            <%= f.text_field :code, class: "form-control", placeholder: "Nom" %>
            <%= f.label :code, "Nom" %>
          </div>
        </div>
        <div class="col-md-6">
          <div class="form-floating">
            <%= f.number_field :duree_base_minutes, class: "form-control", min: 1, placeholder: "Durée de base (minutes)" %>
            <%= f.label :duree_base_minutes, "Durée de base (minutes)" %>
          </div>
        </div>
      </div>

      <div class="d-flex justify-content-end pt-3 mt-2 mt-md-3 border-top border-secondary-subtle">
        <%= f.submit class: "btn btn-primary btn-sm" %>
      </div>
    </div>
  <% end %>
</div>
