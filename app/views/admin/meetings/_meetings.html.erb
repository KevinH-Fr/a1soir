<%= card_main_model(
  "Rendez-vous",
  "calendar-date",
  link_to("", "#collapseNewMeeting",
          class: "bi bi-plus-lg btn btn-sm btn-warning fw-bold",
          data: { bs_toggle: "collapse" },
          role: "button",
          aria: { expanded: "false", controls: "collapseNewMeeting" })) %>

<% if @commande %>
<%= admin_collapse_nouveau collapse_id: "collapseNewMeeting",
      target_id: "new_meeting",
      inner_partial: "admin/meetings/form",
      commande_id: @commande.id,
      client_id: nil,
      meeting: Meeting.new,
      admin_form_row_embedded: true %>

<div id="meetings" class="<%= admin_list_stack_classes %>">
  <% @commande.meetings.each do |meeting| %>
    <%= render partial: "admin/meetings/meeting", locals: { meeting: meeting } %>
  <% end %>
</div>

<% elsif @client %>
<%= admin_collapse_nouveau collapse_id: "collapseNewMeeting",
      target_id: "new_meeting",
      inner_partial: "admin/meetings/form",
      client_id: @client.id,
      commande_id: nil,
      meeting: Meeting.new,
      admin_form_row_embedded: true %>

<div id="meetings" class="<%= admin_list_stack_classes %>">
  <% (@client.meetings + @client.commandes.map(&:meetings).flatten).uniq.each do |meeting| %>
    <%= render partial: "admin/meetings/meeting", locals: { meeting: meeting } %>
  <% end %>
</div>
<% end %>
