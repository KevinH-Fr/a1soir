<div id="<%= dom_id meeting %>">

  <div class="card mx-2 light-beige-colored shadow-sm">
    <div class="card-body p-2">
      <div class="row text-start align-items-center g-2">
        <div class="col">
          <%= custom_badge("", "", "", "", meeting.nom) %>
          <%= custom_badge("fa-calendar", "", "", "", meeting.full_date) %>

          <% if meeting.lieu.present? %>
            <%= custom_badge("fa-map", "", "", "", meeting.lieu) %>
          <% end %>

          <% if meeting.commande %>
            <% unless controller_name == "commandes" && action_name == "show" %>
              <%= custom_badge("", "", "", "", meeting.commande.full_name) %>
            <% end %>
          <% end %>

          <% if meeting.client %>
            <% unless controller_name == "clients" && action_name == "show" %>
              <%= custom_badge("", "", "", "", meeting.client.full_name) %>
            <% end %>
          <% end %>
        </div>
        <div class="col-auto ms-auto">
          <%= links_record(meeting) %>
        </div>
      </div>
    </div>
  </div>

</div>
