<% meeting_index_collapse = local_assigns[:index_collapse] && !meeting.persisted? %>
<div class="card mx-2 <%= meeting_index_collapse ? 'mb-0' : 'my-3' %> light-beige-colored shadow-sm">
  <div class="card-body p-2 d-flex flex-column">

  <%= form_with(model: [:admin, meeting], data: { turbo: true }) do |form| %>
    <% if meeting.errors.any? %>
      <div style="color: red">
        <h2><%= pluralize(meeting.errors.count, "error") %> prohibited this meeting from being saved:</h2>

        <ul>
          <% meeting.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="d-flex flex-column gap-1 w-100">
      <%= custom_form_elements(form, [:nom, :text_field]) %>

      <div data-controller="date-fields" class="d-flex flex-column gap-1 w-100">
        <%= form.hidden_field :duree_rdv, value: AdminParameter.first&.duree_rdv,
            data: { date_fields_target: "dureerdv" } %>

        <div class="input-group input-group-sm w-100">
          <%= form.label :datedebut, "date début", class: "input-group-text label-with-format" %>
          <%= form.datetime_field :datedebut, class: "form-control",
                data: { action: "change->date-fields#updateDateFin", date_fields_target: "datedebut" } %>
        </div>

        <div class="input-group input-group-sm w-100">
          <%= form.label :datefin, "date fin", class: "input-group-text label-with-format" %>
          <%= form.datetime_field :datefin, class: "form-control",
                data: { date_fields_target: "datefin" } %>
        </div>
      </div>

      <% if local_assigns.key?(:client_id) || local_assigns.key?(:commande_id) %>
        <%= form.hidden_field :client_id, value: local_assigns[:client_id] %>
        <%= form.hidden_field :commande_id, value: local_assigns[:commande_id] %>
      <% else %>
        <div class="input-group input-group-sm w-100">
          <%= form.label :commande_id, class: "input-group-text" %>
          <%= form.select :commande_id,
                options_for_select(Commande.select(:id).order(:id).map { |c| [c.ref_commande, c.id] }, meeting.commande_id),
                { include_blank: "Sélectionner" },
                { class: "form-select" } %>
        </div>

        <div class="input-group input-group-sm w-100">
          <%= form.label :client_id, class: "input-group-text" %>
          <%= form.select :client_id,
                options_for_select(Client.all.order(:nom).pluck(:nom, :id), meeting.client_id),
                { include_blank: "Sélectionner" },
                { class: "form-select" } %>
        </div>
      <% end %>

      <div class="input-group input-group-sm w-100">
        <%= form.label :lieu, class: "input-group-text" %>
        <%= form.select :lieu, Meeting::LIEU_OPTIONS, { include_blank: "Sélectionner" }, class: "form-select" %>
      </div>

      <%= custom_submit_button(form) %>
    </div>

  <% end %>

  </div>
</div>
