<% if current_admin_user %>
  <% if current_admin_user.admin? %>

    <%= bandeau_entete("Comptes", "person-circle", "", "", "",
                        card_class: "card mt-2 mx-2 mb-0 shadow-sm rounded-bottom-0 border-bottom-0") %>

    <div class="card mx-2 mb-3 mt-0 shadow-sm rounded-top-0 border-top-0 light-beige-colored">
      <div class="card-header py-2 px-3 bg-transparent border-bottom">
        <span class="fw-semibold text-body">Répartition des comptes</span>
        <span class="small text-body-secondary ms-1">— attribuer un rôle par e-mail</span>
      </div>
      <div class="card-body p-0">

        <section class="border-bottom border-secondary-subtle px-3 py-4">
          <h2 class="h6 mb-2 d-flex flex-wrap align-items-center gap-2 text-body-secondary text-uppercase small fw-semibold">
            Utilisateurs
            <span class="badge rounded-pill text-bg-secondary"><%= @users.count %></span>
          </h2>
          <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
              <thead class="table-light">
                <tr class="small">
                  <th scope="col" class="text-center text-secondary" style="width: 4rem;">#</th>
                  <th scope="col" class="text-secondary">E-mail</th>
                  <th scope="col" class="text-end text-secondary text-nowrap">Actions</th>
                </tr>
              </thead>
              <tbody class="small">
                <% @users.each do |user| %>
                  <tr>
                    <td class="text-center text-muted"><%= user.id %></td>
                    <td class="font-monospace"><%= user.email %></td>
                    <td class="text-end">
                      <div class="btn-group btn-group-sm" role="group" aria-label="Changer le rôle">
                        <%= link_to "Vendeur", toggle_status_vendeur_admin_user_path(user),
                                    class: "btn btn-outline-primary",
                                    onclick: "return confirm('Etes-vous certain de vouloir passer cet utilisateur en Vendeur ?')" %>
                        <%= link_to "Admin", toggle_status_admin_admin_user_path(user),
                                    class: "btn btn-outline-dark",
                                    onclick: "return confirm('Etes-vous certain de vouloir passer cet utilisateur en Admin ?')" %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </section>

        <section class="border-bottom border-secondary-subtle px-3 py-4">
          <h2 class="h6 mb-2 d-flex flex-wrap align-items-center gap-2 text-body-secondary text-uppercase small fw-semibold">
            Vendeurs
            <span class="badge rounded-pill text-bg-secondary"><%= @vendeurs.count %></span>
          </h2>
          <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
              <thead class="table-light">
                <tr class="small">
                  <th scope="col" class="text-center text-secondary" style="width: 4rem;">#</th>
                  <th scope="col" class="text-secondary">E-mail</th>
                  <th scope="col" class="text-end text-secondary text-nowrap">Actions</th>
                </tr>
              </thead>
              <tbody class="small">
                <% @vendeurs.each do |user| %>
                  <tr>
                    <td class="text-center text-muted"><%= user.id %></td>
                    <td class="font-monospace"><%= user.email %></td>
                    <td class="text-end">
                      <div class="btn-group btn-group-sm" role="group" aria-label="Changer le rôle">
                        <%= link_to "User", toggle_status_user_admin_user_path(user),
                                    class: "btn btn-outline-secondary",
                                    onclick: "return confirm('Etes-vous certain de vouloir passer cet utilisateur en User ?')" %>
                        <%= link_to "Admin", toggle_status_admin_admin_user_path(user),
                                    class: "btn btn-outline-dark",
                                    onclick: "return confirm('Etes-vous certain de vouloir passer cet utilisateur en Admin ?')" %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </section>

        <section class="px-3 pt-4 pb-3">
          <h2 class="h6 mb-2 d-flex flex-wrap align-items-center gap-2 text-body-secondary text-uppercase small fw-semibold">
            Admins
            <span class="badge rounded-pill text-bg-secondary"><%= @admins.count %></span>
          </h2>
          <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
              <thead class="table-light">
                <tr class="small">
                  <th scope="col" class="text-center text-secondary" style="width: 4rem;">#</th>
                  <th scope="col" class="text-secondary">E-mail</th>
                  <th scope="col" class="text-end text-secondary text-nowrap">Actions</th>
                </tr>
              </thead>
              <tbody class="small">
                <% @admins.each do |user| %>
                  <tr>
                    <td class="text-center text-muted"><%= user.id %></td>
                    <td class="font-monospace"><%= user.email %></td>
                    <td class="text-end">
                      <div class="btn-group btn-group-sm" role="group" aria-label="Changer le rôle">
                        <%= link_to "User", toggle_status_user_admin_user_path(user),
                                    class: "btn btn-outline-secondary",
                                    onclick: "return confirm('Etes-vous certain de vouloir passer cet Admin en User ?')" %>
                        <%= link_to "Vendeur", toggle_status_vendeur_admin_user_path(user),
                                    class: "btn btn-outline-primary",
                                    onclick: "return confirm('Etes-vous certain de vouloir passer cet Admin en Vendeur ?')" %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </section>

      </div>
    </div>

  <% else %>
    Vous devez être connecté(e) à un compte Admin
    <%#= render "admin/home_admin/demande_connexion" %>
  <% end %>

<% end %>
