<div id="<%= dom_id ensemble %>">
  <div class="card mx-2 light-beige-colored shadow-sm">
    <div class="card-body p-2 d-flex flex-column gap-2">
      <% enfants = [
           ensemble.type_produit1, ensemble.type_produit2, ensemble.type_produit3,
           ensemble.type_produit4, ensemble.type_produit5, ensemble.type_produit6
         ].compact %>

      <div class="d-flex flex-wrap align-items-center gap-1">
        <div data-turbo="false">
          <%= link_to admin_ensemble_path(ensemble), class: "text-decoration-none text-dark" do %>
            <%= custom_badge("fa-sitemap", "Parent :", "", "fw-bold", ensemble.produit.nom) %>
          <% end %>
        </div>
        <% enfants.each_with_index do |tp, idx| %>
          <%= custom_badge("fa-cube", "Enfant #{idx + 1} :", "", "", tp.nom) %>
        <% end %>
      </div>

      <div class="d-flex flex-wrap justify-content-end align-items-center gap-1 pt-1">
        <%= links_record(ensemble) %>
      </div>
    </div>
  </div>
</div>
