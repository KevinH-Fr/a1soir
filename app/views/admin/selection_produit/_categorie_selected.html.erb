<%= selection_filter_section(title: "Tailles", icon: "bi-arrows-angle-expand", heading_id: "selection-filter-sizes", compact: true) do %>
  <%= form_with url: display_taille_selected_admin_selection_produit_index_path, method: :post, class: "m-0 w-100", data: { turbo: true } do %>
    <%= selection_hidden_categorie_produit_ids(@categorie_produits) %>
    <%= select_tag :taille,
          options_for_select(
            [["Toutes les tailles", "all"]] + @tailles.map { |t| [t.nom, t.id] }
          ),
          include_blank: "…",
          class: "form-select form-select-sm w-100",
          aria: { labelledby: "selection-filter-sizes" },
          onchange: "if (this.value !== '') this.form.requestSubmit()" %>
  <% end %>
<% end %>

<div id="partial-taille-selected" class="">
  <%# recoit le turbo stream avec elements cliqués %>
</div>
