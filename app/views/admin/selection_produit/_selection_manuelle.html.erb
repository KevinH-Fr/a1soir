<%= selection_filter_section(title: "Catégories", icon: "bi-grid-3x3-gap", heading_id: "selection-filter-categories", compact: true) do %>
  <%= form_with url: display_categorie_selected_admin_selection_produit_index_path, method: :post, class: "m-0 w-100", data: { turbo: true } do %>
    <%= select_tag :categorie_produit,
          options_for_select(
            [["Toutes les catégories", "all"]] + @categorie_produits.map { |c| [c.nom, c.id] }
          ),
          include_blank: "…",
          class: "form-select form-select-sm w-100",
          aria: { labelledby: "selection-filter-categories" },
          onchange: "if (this.value !== '') this.form.requestSubmit()" %>
  <% end %>
<% end %>

<div id="partial-categorie-selected" class="">
  <%# recoit le turbo stream avec elements cliqués %>
</div>
