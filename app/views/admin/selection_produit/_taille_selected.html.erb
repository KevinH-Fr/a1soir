<%= selection_filter_section(title: "Couleurs", icon: "bi-palette", heading_id: "selection-filter-colors", compact: true) do %>
  <%= form_with url: display_couleur_selected_admin_selection_produit_index_path, method: :post, class: "m-0 w-100", data: { turbo: true } do %>
    <%= selection_hidden_categorie_produit_ids(@categorie_produits) %>
    <%= selection_hidden_taille_ids(@tailles) %>
    <%= select_tag :couleur,
          options_for_select(
            [["Toutes les couleurs", "all"]] + @couleurs.map { |c| [c.nom, c.id] }
          ),
          include_blank: "…",
          class: "form-select form-select-sm w-100",
          aria: { labelledby: "selection-filter-colors" },
          onchange: "if (this.value !== '') this.form.requestSubmit()" %>
  <% end %>
<% end %>

<div id="partial-couleur-selected" class="">
  <%# recoit le turbo stream avec elements cliqués %>
</div>
