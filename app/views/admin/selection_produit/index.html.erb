<div class="pb-5">
  <div class="card mx-2 mb-3 light-beige-colored shadow-sm rounded-3 overflow-hidden border border-secondary-subtle">

    <div class="card-header lighter-beige-colored border-bottom border-secondary-subtle py-3 px-3 px-md-4 rounded-0">
      <h1 class="h5 mb-0 fw-semibold text-body text-center text-md-start"><%= @titre_complet %></h1>
    </div>

    <div class="card-body p-0">

      <div class="px-3 px-md-4 py-3 border-bottom border-secondary-subtle">
        <%= search_form_for @q, url: admin_selection_produit_path, method: :get, class: "w-100", html: { role: "search" } do |f| %>
          <%= hidden_field_tag "article", params[:article] if params[:article].present? %>
          <div class="input-group shadow-sm w-100">
            <%= f.search_field :nom_or_reffrs_or_couleur_nom_or_taille_nom_or_fournisseur_nom_cont,
                  class: "form-control border-secondary-subtle",
                  placeholder: "Chercher…",
                  autocomplete: "off" %>
            <%= link_to admin_selection_produit_path(article: params[:article]),
                  class: "btn btn-outline-danger border-secondary-subtle d-inline-flex align-items-center",
                  title: "Réinitialiser la recherche",
                  aria: { label: "Réinitialiser la recherche" } do %>
              <i class="bi bi-xl bi-x-circle" aria-hidden="true"></i>
            <% end %>
            <%= f.button class: "btn btn-outline-success border-secondary-subtle d-inline-flex align-items-center", type: "submit", aria: { label: "Rechercher" } do %>
              <i class="bi bi-xl bi-search mx-1" aria-hidden="true"></i>
            <% end %>
          </div>
        <% end %>
      </div>

      <% if params[:q] %>
        <div class="px-3 px-md-4 pb-2">
          <%= render "admin/selection_produit/produits_filtres" %>
        </div>
      <% end %>

      <% unless @produit.present? || params[:q] %>
        <% button_configs = [
          { path: display_qr_admin_selection_produit_index_path, icon: "bi-qr-code-scan", text: "QR code", color: "text-secondary" },
          { path: display_manuelle_admin_selection_produit_index_path(article: @article), icon: "bi-hand-index", text: "Manuelle", color: "text-secondary" }
        ] %>

        <div class="selection-produit-mode-panel px-3 px-md-4 py-3 border-top border-secondary-subtle bg-body-tertiary bg-opacity-50">
          <p class="text-center small fw-semibold text-body-secondary text-uppercase mb-3 mb-md-2">Mode de sélection</p>
          <%# .d-flex requis : button-color Stimulus utilise closest(".d-flex") %>
          <div class="d-flex flex-wrap justify-content-center align-items-center gap-2 gap-md-3">
            <% button_configs.each do |config| %>
              <%= button_to config[:path],
                    class: "btn btn-outline-secondary border-secondary-subtle btn-topic rounded-pill px-4 py-2 d-inline-flex align-items-center justify-content-center gap-2 shadow-sm fw-semibold text-body",
                    data: { controller: "button-color", action: "click->button-color#handleClick" },
                    "data-original-color": config[:color] do %>
                <i class="bi bi-xl <%= config[:icon] %> <%= config[:color] %> <%= config[:text].downcase.parameterize %> <%= config[:color] %>" data-target="button-color.icon" aria-hidden="true"></i>
                <span><%= config[:text] %></span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <div id="partial-container" class="partial-topic px-3 px-md-4 pb-3">
        <%# recoit le turbo stream avec elements cliqués %>

        <% if @produit.present? %>
          <%= render @produit %>

          <% if @article %>
            <div class="mx-2 my-2">
              <%= render partial: "admin/sousarticles/form",
                  locals: { commande_id: @commande.id, produit_id: @produit.id, article: @article.id, sousarticle: Sousarticle.new } %>
            </div>
          <% else %>
            <div class="mx-2 my-2">
              <%= render partial: "admin/articles/form",
                  locals: { commande_id: @commande.id, produit_id: @produit.id, article: Article.new } %>
            </div>
          <% end %>

        <% else %>

          <% if session[:display_qr_activated] == true %>
            <%= render "admin/selection_produit/selection_qr", display_qr_activated: nil %>
          <% end %>

        <% end %>
      </div>

    </div>
  </div>

  <%= render "ensemble_applicable" %>
</div>

<div class="fixed-bottom bg-body border-top border-secondary-subtle shadow-sm py-2 px-3">
  <%= return_model_index_button("Retour vers commande", admin_commande_path(@commande)) %>
</div>
