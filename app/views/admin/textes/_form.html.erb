<%= form_with(model: [:admin, texte]) do |form| %>
  <% if texte.errors.any? %>
    <div class="alert alert-danger">
      <h5><%= pluralize(texte.errors.count, "erreur") %> empêche l'enregistrement:</h5>
      <ul class="mb-0">
        <% texte.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= form.label :titre, "Titre", class:"form-label fw-bold" %>
    <%= form.text_field :titre, class:"form-control", placeholder:"Ex: Informations de la boutique" %>
  </div>

  <div class="mb-4">
    <%= form.label :boutique, "Boutique", class:"form-label fw-bold" %>
    <%= form.rich_text_area :boutique, class:"form-control" %>
  </div>

  <div class="mb-4">
    <%= form.label :equipe, "Équipe", class:"form-label fw-bold" %>
    <%= form.rich_text_area :equipe, class:"form-control" %>
  </div>

  <div class="mb-4">
    <%= form.label :contact, "Contact", class:"form-label fw-bold" %>
    <%= form.rich_text_area :contact, class:"form-control" %>
  </div>

  <div class="mb-4">
    <%= form.label :horaire, "Horaire (mode normal)", class:"form-label fw-bold" %>
    <%= form.rich_text_area :horaire, class:"form-control" %>
  </div>

  <div class="mb-4 border rounded p-3 bg-light">
    <div class="form-check form-switch mb-3">
      <%= form.check_box :mode_periode_speciale,
            class: "form-check-input",
            data: { bs_toggle: "collapse", bs_target: "#periode_speciale_fields" },
            aria: { expanded: texte.mode_periode_speciale?, controls: "periode_speciale_fields" } %>
      <%= form.label :mode_periode_speciale, "Activer le mode période spéciale (festival...)", class: "form-check-label fw-bold" %>
      <div class="form-text">Si activé, les horaires spéciaux s'affichent sur le site et un encart s'affiche sur les pages de réservation.</div>
    </div>

    <div id="periode_speciale_fields" class="collapse <%= 'show' if texte.mode_periode_speciale? %>">
      <div class="mb-3">
        <%= form.label :horaire_periode_speciale, "Horaires période spéciale", class:"form-label fw-bold" %>
        <%= form.rich_text_area :horaire_periode_speciale, class:"form-control" %>
      </div>

      <div class="mb-3">
        <%= form.label :encart_periode_speciale_fr, "Encart réservation — Français", class:"form-label fw-bold" %>
        <%= form.text_area :encart_periode_speciale_fr, class:"form-control", rows: 3,
            placeholder: "Ex : Pendant le festival, aucun rendez-vous n'est nécessaire. Venez directement !" %>
      </div>

      <div class="mb-3">
        <%= form.label :encart_periode_speciale_en, "Encart réservation — English", class:"form-label fw-bold" %>
        <%= form.text_area :encart_periode_speciale_en, class:"form-control", rows: 3,
            placeholder: "Ex: During the festival, no appointment is needed. Just come in!" %>
      </div>
    </div>
  </div>

  <div class="mb-4">
    <%= form.label :adresse, "Adresse", class:"form-label fw-bold" %>
    <%= form.rich_text_area :adresse, class:"form-control" %>
  </div>

  <div class="mb-4">
    <%= form.label :carousel_images, "Images du carousel", class:"form-label fw-bold" %>
    <%= form.file_field :carousel_images, multiple: true, class:"form-control" %>
    <div class="form-text">Formats acceptés: JPG, PNG, GIF, WEBP (max 5MB par image)</div>
  </div>

  <% if texte.persisted? && texte.carousel_images.any? %>
    <div class="mb-4">
      <label class="form-label fw-bold">Images actuelles</label>
      <div class="d-flex flex-wrap gap-3">
        <% texte.carousel_images.each do |image| %>
          <% if image.present? %>
            <div class="position-relative">
              <%= image_tag image, class: "rounded shadow-sm admin-image-preview" %>
              <%= link_to delete_image_attachment_admin_texte_path(texte, image_id: image.id),
                  method: :delete,
                  data: { turbo_confirm: "Êtes-vous sûr de vouloir supprimer cette image ?" },
                  class: "btn btn-sm btn-danger position-absolute top-0 end-0 m-1" do %>
                <i class="bi bi-trash"></i>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="d-flex justify-content-end gap-2 mt-4">
    <%= link_to "Annuler", admin_textes_path, class:"btn btn-secondary" %>
    <%= form.submit "Enregistrer", class: "btn btn-primary" %>
  </div>
  
<% end %>
