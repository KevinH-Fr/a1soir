<% cdc_list_expanded = local_assigns.key?(:coups_de_coeur_list_open) ? coups_de_coeur_list_open : params[:cdc_list].present? %>
<% collapse_show = @coups_de_coeur.blank? || cdc_list_expanded %>

<div id="coups_de_coeur_section" class="card mx-2 my-3 light-beige-colored shadow-sm">
  <div class="card-header bg-secondary text-white py-2 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <span class="d-flex align-items-center fw-bold mb-0">
      <i class="bi bi-heart-fill me-2" aria-hidden="true"></i>
      Produits coups de cœur
    </span>
    <span class="badge bg-white text-danger">
      <%= @coups_de_coeur.count %> produit(s)
    </span>
  </div>
  <div class="card-body py-3">
    <p class="small text-muted mb-2">
      <i class="bi bi-info-circle me-1" aria-hidden="true"></i>
      Ces produits s'affichent sur le site public. Gérez-les depuis la liste des produits ou ci-dessous.
    </p>

    <% if @coups_de_coeur.any? %>
      <p class="mb-2">
        <button class="btn btn-sm btn-outline-secondary <%= "collapsed" unless collapse_show %>"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#coupsDeCoeurCollapse"
                aria-expanded="<%= collapse_show %>"
                aria-controls="coupsDeCoeurCollapse">
          <i class="bi bi-chevron-down me-1" aria-hidden="true"></i>
          Afficher la liste (<%= @coups_de_coeur.count %>)
        </button>
      </p>
    <% end %>

    <div id="coupsDeCoeurCollapse" class="collapse <%= "show" if collapse_show %>">
      <% if @coups_de_coeur.any? %>
        <% @coups_de_coeur.each_with_index do |produit, index| %>
          <div class="mb-3">
            <div class="card border bg-white">
              <div class="card-body p-3">
                <div class="row align-items-center g-2">
                  <div class="col-auto">
                    <div class="btn-group-vertical" role="group">
                      <%= button_to move_up_coup_de_coeur_admin_produit_path(produit),
                          method: :post,
                          class: "btn btn-sm btn-outline-secondary #{"disabled" if index == 0}",
                          disabled: index == 0,
                          title: "Monter" do %>
                        <i class="bi bi-arrow-up"></i>
                      <% end %>
                      <%= button_to move_down_coup_de_coeur_admin_produit_path(produit),
                          method: :post,
                          class: "btn btn-sm btn-outline-secondary #{"disabled" if index == @coups_de_coeur.size - 1}",
                          disabled: index == @coups_de_coeur.size - 1,
                          title: "Descendre" do %>
                        <i class="bi bi-arrow-down"></i>
                      <% end %>
                    </div>
                  </div>

                  <div class="col-auto">
                    <% if produit.image1.attached? %>
                      <%= image_tag produit.default_image, class: "rounded object-fit-cover", style: "width: 80px; height: 80px;" %>
                    <% else %>
                      <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                        <i class="bi bi-image text-muted"></i>
                      </div>
                    <% end %>
                  </div>

                  <div class="col min-w-0">
                    <h6 class="mb-1 text-truncate"><%= produit.nom %></h6>
                    <small class="text-muted">Position&nbsp;: <%= produit.coup_de_coeur_position || 0 %></small>
                  </div>

                  <div class="col-auto">
                    <div class="d-flex gap-2 align-items-center flex-wrap">
                      <%= button_to toggle_coup_de_coeur_admin_produit_path(produit),
                          method: :post,
                          class: "btn btn-sm btn-outline-danger",
                          data: {
                            turbo_confirm: "Retirer ce produit des coups de cœur ?",
                            turbo_frame: "_top"
                          },
                          title: "Retirer des coups de cœur" do %>
                        <i class="bi bi-heart"></i>
                      <% end %>
                      <%= link_to admin_produit_path(produit), class: "btn btn-sm btn-outline-primary", target: "_blank", rel: "noopener", title: "Voir le produit" do %>
                        <i class="bi bi-box-arrow-up-right"></i>
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="alert alert-info mb-0">
          <i class="bi bi-info-circle me-2" aria-hidden="true"></i>
          Aucun produit coup de cœur pour le moment.
          <%= link_to "Ajoutez-en depuis la liste des produits", admin_produits_path, class: "alert-link" %>.
        </div>
      <% end %>
    </div>
  </div>
</div>
