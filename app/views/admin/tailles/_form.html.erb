<% taille_compact_collapse = local_assigns[:index_collapse] && !taille.persisted? %>
<%= render layout: "admin/shared/form_card_shell",
           locals: {
             compact: taille_compact_collapse,
             embedded: local_assigns.fetch(:admin_form_row_embedded, false)
           } do %>
    <%= form_with(model: taille, url: taille.persisted? ? admin_taille_path(taille) : admin_tailles_path, method: taille.persisted? ? :patch : :post, data: { turbo: true }) do |form| %>
      <% if taille.errors.any? %>
        <div style="color: red">
          <h2><%= pluralize(taille.errors.count, "error") %> prohibited this taille from being saved:</h2>

          <ul>
            <% taille.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= custom_form_elements(form, [:nom, :text_field]) %>

      <%= custom_submit_button(form) %>

    <% end %>
<% end %>
