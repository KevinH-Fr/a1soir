<div id="<%= dom_id produit %>">

  <% if @analysis_mode %>
        <div class="card small mx-2 px-1 mb-1">
          <%= produit.nom_ref_couleur_taille %>

          <% statut = produit.statut_disponibilite(Date.today.to_date, Date.today.to_date) %>
          stock: <%= statut[:disponibles] %>
        </div>

  <% else %>

    <div class="card mx-2 my-0 light-beige-colored shadow-sm">
      <div class="row g-0">
        <!-- Image Column -->
        <div class="col-sm-4 p-1 text-center">
          <div data-turbo="false">
            <%= link_to image_tag(produit.default_image, class: "img-fluid img-produit"), admin_produit_path(produit)  %>
          </div>
        </div>
        <!-- Text Column -->
        <div class="col-sm-8">
          <div class="card-body p-1 px-2">
            <h5 class="card-title ms-1">
              <%= produit.nom %>
            </h5>
            
            <div class="card-text">
              <div>
                <% if produit.categorie_produits.any? %>
                  <% produit.categorie_produits.each do |categorie| %>
                    <%= custom_badge("", "", "", "", categorie.nom ) %>
                  <% end %>
                <% end %>
              </div>

              <div class="px-2 small my-1">
                <%= produit.description %>
              </div>

              <div class="container-fluid mt-2 p-1 d-flex flex-wrap align-items-center gap-2">

                <div class="d-inline-flex flex-wrap align-items-center gap-1"> 
                  <%= badge_prixlocation_produit(produit) %>
                  <%= badge_prixvente_produit(produit) %>
                </div>

                <div class="d-inline-flex flex-wrap align-items-center gap-1">
                  <%= badge_couleur_produit(produit) %>
                  <%= badge_taille_produit(produit) %>
                </div>
  
                <div class="d-inline-flex flex-wrap align-items-center gap-1">
                  <%= is_archived(produit) %>
                  <%= badge_eshop(produit) %>
                </div>

                <% unless controller_name == "selection_produit" %>
                  <div class="d-inline-flex flex-wrap align-items-center gap-1">
                    <% statut = produit.statut_disponibilite(Date.today.to_date, Date.today.to_date) %>
                      <% disponibles = statut[:disponibles] %>
                      <span class="badge border fs-6 fw-normal p-1 me-1 mb-1 <%= disponibles > 0 ? ' border-success text-success' : 'border-danger text-danger' %>">
                        Disponibles: <%= disponibles %>
                      </span>
                    </div>
                <% end %>

              </div>

              <div class="mt-auto m-1">

                  <% collapse_id = "collapseProduit#{dom_id(produit)}" %>
                  <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mt-2">
                    <a class="small text-muted text-decoration-none d-inline-flex align-items-center"
                       data-bs-toggle="collapse"
                       href="#<%= collapse_id %>"
                       role="button"
                       aria-expanded="false"
                       aria-controls="<%= collapse_id %>">
                      <%= admin_collapse_details_button_content %>
                    </a>
                    <% if current_admin_user.admin? %>
                      <div class="ms-auto">
                        <%= links_record(produit, show_destroy: false) %>
                      </div>
                    <% end %>

                  </div>

              </div>
            </div>
          </div>

        </div>
      </div>

      <div class="collapse" id="<%= collapse_id %>">
        <hr class="mx-2 mt-2 mb-3">

        <div class="row g-3 px-2 pb-3">

          <!-- QR Code -->
          <% if produit.qr_code.attached? %>
            <div class="col-auto text-center" data-turbo="false">
              <%= image_tag(produit.qr_code, class: "img-fluid rounded", style: "max-width: 130px;") %>
            </div>
            <div class="col">
          <% else %>
            <div class="col-12">
          <% end %>

              <!-- Variantes -->
              <% autres_couleurs = same_produit_same_taille_others_couleurs(produit).select { |p| p.couleur } %>
              <% autres_tailles  = same_produit_same_couleur_others_tailles(produit).select { |p| p.taille } %>
              <% if autres_couleurs.any? || autres_tailles.any? %>
                <div class="d-flex flex-wrap gap-1 align-items-center mb-2">
                  <% if autres_couleurs.any? %>
                    <span class="text-muted small me-1">Couleurs :</span>
                    <% autres_couleurs.each do |p| %>
                      <%= custom_badge("", "", "", "", p.couleur.nom) %>
                    <% end %>
                  <% end %>
                  <% if autres_tailles.any? %>
                    <span class="text-muted small ms-2 me-1">Tailles :</span>
                    <% autres_tailles.each do |p| %>
                      <%= custom_badge("", "", "", "", p.taille.nom) %>
                    <% end %>
                  <% end %>
                </div>
              <% end %>

              <!-- Badges infos -->
              <div class="d-flex flex-wrap gap-1 align-items-center">
                <%= custom_badge("", "caution", "", "", custom_currency_no_decimals_format(produit.caution)) if produit.caution %>
                <%= custom_badge("", "handle:", "", "", produit.handle) if produit.handle %>
                <%= custom_badge("", "ref. fournisseur:", "", "", produit.reffrs) if produit.reffrs %>
                <%= custom_badge("", "poids (g):", "", "", produit.poids) %>
                <% if current_admin_user.admin? %>
                  <%= custom_badge("", "prix achat", "", "", produit.prixachat) if produit.prixachat %>
                  <%= custom_badge("", "fournisseur:", "", "", produit.fournisseur&.nom) if produit.fournisseur&.nom %>
                  <%= custom_badge("", "date achat:", "", "", produit.dateachat) if produit.dateachat %>
                <% end %>
              </div>

              <!-- Actions admin -->
              <% if current_admin_user.admin? %>
                <div class="mt-3 d-flex flex-wrap align-items-center gap-2">

                  <% if controller_name == "produits" && action_name == "show" %>
                    <%= link_to dupliquer_admin_produit_path(produitbase: produit.id),
                          class: "btn btn-sm btn-dark",
                          onclick: "return confirm('Etes-vous certain de vouloir dupliquer ce produit ?')",
                          title: "Dupliquer" do %>
                      <i class="bi-copy me-1"></i>Dupliquer
                    <% end %>
                  <% end %>

                  <%= button_to toggle_active_admin_produit_path(produit),
                        method: :patch,
                        class: "btn btn-sm #{produit.actif? ? 'btn-warning text-dark' : 'btn-success'}",
                        form: { data: { turbo_confirm: (produit.actif? ? "Archiver ce produit ? Il sera retiré des sélections actives et de l'e-shop." : nil) } } do %>
                    <i class="bi <%= produit.actif? ? 'bi-archive' : 'bi-arrow-clockwise' %> me-1"></i>
                    <%= produit.actif? ? "Archiver" : "Réactiver" %>
                  <% end %>

                  <%= button_to admin_produit_path(produit),
                        method: :delete,
                        class: "btn btn-sm btn-danger",
                        form: { data: { turbo_confirm: "Êtes-vous certain de vouloir supprimer ce produit définitivement ?" } } do %>
                    <i class="bi bi-trash me-1"></i>Supprimer
                  <% end %>
                </div>

                <div class="mt-2 d-flex flex-wrap align-items-center gap-2">
                  <div id="produit_<%= produit.id %>_coup_de_coeur">
                    <%= render "admin/produits/coup_de_coeur_toggle", produit: produit %>
                  </div>
                  <div>
                    <%= render "admin/produits/promotion_buttons", produit: produit %>
                  </div>
                </div>
              <% end %>

            </div>

          <!-- Médias -->
          <% if produit.images.any? || produit.video1.attached? %>
            <div class="col-12">
              <div class="d-flex flex-wrap gap-2">
                <% produit.images.each do |image| %>
                  <%= image_tag(image, class: "rounded border", style: "object-fit: cover; width: 120px; height: 120px;") %>
                <% end %>
                <% if produit.video1.attached? %>
                  <div class="d-flex align-items-center justify-content-center rounded border bg-light"
                       style="width: 120px; height: 120px;">
                    <i class="bi bi-file-earmark-play text-secondary" style="font-size: 2.5rem;"></i>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>

        </div>
      </div>
    </div>
  <% end %>
</div>
