<% id_suffix = local_assigns[:id_suffix] %>
<% always_show_label = local_assigns.fetch(:always_show_label, false) %>

<div class="min-w-0">
  <%= filter_dropdown(
        label: "Catégorie",
        icon: "bi bi-layers",
        param_key: :filter_categorie,
        collection: @categorie_produits,
        model: CategorieProduit,
        current_params: listing_params_with_search(params.permit(:filter_taille, :filter_couleur, :filter_type_produit, :filter_statut, :filter_fournisseur, :filter_mode, :filter_prix)),
        all_label: "Toutes les catégories",
        columns: 2,
        id_suffix: id_suffix,
        always_show_label: always_show_label
      ) %>
</div>

<div class="min-w-0">
  <%= filter_dropdown(
        label: "Type",
        icon: "bi bi-tag",
        param_key: :filter_type_produit,
