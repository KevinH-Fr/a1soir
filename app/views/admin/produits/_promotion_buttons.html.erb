<% if produit.prixvente.present? && produit.prixvente > 0 %>
  <% if produit.en_promotion? %>
    <div class="d-flex align-items-center gap-2 flex-wrap">
      <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle fw-normal px-2 py-1 rounded-pill small">
        <i class="bi bi-tag-fill me-1"></i>
        <span class="text-decoration-line-through text-muted me-1"><%= custom_currency_no_decimals_format(produit.ancien_prixvente) %></span>
        <i class="bi bi-arrow-right me-1"></i>
        <span class="fw-semibold"><%= custom_currency_no_decimals_format(produit.prixvente) %></span>
      </span>
      <%= form_with url: remove_promotion_admin_produit_path(produit), method: :post, data: { turbo: true }, class: "d-inline" do |form| %>
        <button type="submit" class="btn btn-sm btn-outline-secondary"
                onclick="return confirm('Êtes-vous sûr de vouloir retirer la promotion ? Le prix sera restauré à <%= custom_currency_no_decimals_format(produit.ancien_prixvente) %>')">
          <i class="bi bi-x-circle me-1"></i>Retirer la promotion
        </button>
      <% end %>
    </div>
  <% else %>
    <button type="button" class="btn btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#promotionModal<%= produit.id %>">
      <i class="bi bi-tag me-1"></i>Appliquer une promotion
    </button>
  <% end %>

  <!-- Modal pour appliquer une promotion -->
  <div class="modal fade" id="promotionModal<%= produit.id %>" tabindex="-1" aria-labelledby="promotionModalLabel<%= produit.id %>" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="promotionModalLabel<%= produit.id %>">Appliquer une promotion</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <%= form_with url: apply_promotion_admin_produit_path(produit), method: :post, data: { turbo: true } do |form| %>
          <div class="modal-body">
            <% if produit.prixlocation.to_f > 0 %>
              <div class="alert alert-warning d-flex align-items-start gap-2 mb-3">
                <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1"></i>
                <div>
                  <strong>Attention :</strong> ce produit est disponible à la location
                  (<%= custom_currency_no_decimals_format(produit.prixlocation) %>).
                  En appliquant cette promotion, il sera <strong>retiré de la location</strong>.
                </div>
              </div>
            <% end %>
            <div class="mb-3">
              <label class="form-label">Prix actuel</label>
              <input type="text" class="form-control" value="<%= custom_currency_no_decimals_format(produit.prixvente) %>" disabled>
            </div>
            <div class="mb-3">
              <label for="nouveau_prix<%= produit.id %>" class="form-label">Nouveau prix de vente</label>
              <%= form.number_field :nouveau_prix, id: "nouveau_prix#{produit.id}", class: "form-control", step: "any", min: "0.01", required: true, value: produit.prixvente %>
              <small class="form-text text-muted">Le prix actuel sera sauvegardé comme ancien prix.</small>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
            <%= form.submit "Appliquer la promotion", class: "btn btn-success", data: { bs_dismiss: "modal" } %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
