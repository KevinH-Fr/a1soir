
<%= bandeau_entete("Analyses", "graph-up-arrow", "", "", "", card_class: "card mt-2 mx-2 mb-0 shadow-sm rounded-bottom-0 border-bottom-0") %>

<% q_params = params[:q].respond_to?(:to_unsafe_h) ? params[:q].to_unsafe_h : params[:q] %>
<% base_params = params.permit(:sort, :filter_mode, :filter_taille, :filter_couleur, :filter_categorie, :filter_type_produit, :filter_statut).to_h.merge(q: q_params) %>
<% today = Date.today %>

<div class="card mx-2 mb-2 mt-0 shadow-sm rounded-top-0 border-top-0">
  <div class="card-body text-dark light-beige-colored p-2 px-3">

    <div class="d-flex flex-column gap-1">
      <div class="d-flex flex-wrap align-items-center column-gap-2 row-gap-2">
        <span class="small text-secondary text-uppercase fw-semibold lh-sm text-nowrap">
          <i class="bi bi-calendar3 me-1 opacity-75" aria-hidden="true"></i>
          Période
        </span>
        <div class="btn-group shadow-none" role="group" aria-label="Aujourd'hui">
          <%= date_range_filter_today_button(base_params: base_params) %>
        </div>
        <div class="vr d-none d-sm-block align-self-stretch opacity-50" role="presentation" aria-hidden="true"></div>
        <div class="btn-group shadow-none" role="group" aria-label="Périodes prédéfinies">
          <%= date_range_filter_range_presets_buttons(base_params: base_params) %>
        </div>
        <button type="button"
                class="btn btn-sm text-nowrap <%= custom_period_filter_open? ? "btn-primary" : "btn-outline-secondary" %>"
                data-bs-toggle="collapse"
                data-bs-target="#customDateFilter"
                aria-expanded="<%= custom_period_filter_open? %>"
                aria-controls="customDateFilter"
                title="Saisir une plage de dates précise">
          <i class="bi bi-sliders" aria-hidden="true"></i>
          <span class="ms-1">Personnaliser</span>
        </button>
      </div>

      <div id="customDateFilter" class="collapse <%= "show" if custom_period_filter_open? %>">
        <div class="p-2 border rounded-1 bg-white bg-opacity-50">
          <%= form_tag url_for, method: :get, class: "d-flex flex-wrap align-items-center gap-2" do %>
            <%= date_field_tag :debut, params[:debut],
                               class: "form-control form-control-sm w-auto flex-shrink-0",
                               aria: { label: "Date de début" } %>
            <span class="text-body-secondary small user-select-none d-none d-sm-inline" aria-hidden="true">→</span>
            <%= date_field_tag :fin, params[:fin],
                               class: "form-control form-control-sm w-auto flex-shrink-0",
                               aria: { label: "Date de fin" } %>
            <% base_params.each do |key, value| %>
              <% if key.to_s == "q" && value.is_a?(Hash) %>
                <% value.each do |sub_key, sub_val| %>
                  <%= hidden_field_tag "q[#{sub_key}]", sub_val %>
                <% end %>
              <% else %>
                <%= hidden_field_tag key, value %>
              <% end %>
            <% end %>
            <%= submit_tag "Valider", class: "btn btn-primary btn-sm" %>
          <% end %>
        </div>
      </div>

      <% if @datedebut.present? && @datefin.present? %>
        <div class="small border-top border-secondary-subtle pt-2 mt-1 d-flex flex-wrap align-items-center justify-content-between gap-2">
          <div class="d-flex flex-wrap align-items-center gap-2">
            <span class="text-body-secondary">Affichage</span>
            <span class="px-2 py-1 fw-medium rounded-pill border bg-white bg-opacity-75 text-body">
              <%= @datedebut.strftime("%d/%m/%Y") %>
              <span class="text-body-secondary mx-1">·</span>
              <%= @datefin.strftime("%d/%m/%Y") %>
            </span>
          </div>
          <%= link_to url_for(debut: Date.today, fin: Date.today),
                      class: "btn btn-sm btn-outline-danger",
                      title: "Réinitialiser la période sur aujourd'hui" do %>
            <i class="bi bi-arrow-counterclockwise me-1" aria-hidden="true"></i>
            Réinitialiser
          <% end %>
        </div>
      <% end %>
    </div>

  </div>
</div>

<%= render_dashboard_section("Profiles", "bi bi-people-fill", ["chartPieCommandesProfiles", "chartBarDevisProfiles", "chartBarCaProfiles"]) %>
<%= render_dashboard_section("Commandes", "bi bi-file-earmark-fill", ["chartPieCommandes", "chartBarCommandes", "chartLineCommandes"]) %>
<%= render_dashboard_section("Articles", "bi bi-person-standing-dress", ["chartPieArticles", "chartBarArticles", "chartLineArticles"]) %>
<%= render_dashboard_section("Transactions", "bi bi-arrow-left-right", ["chartPieTransactions", "chartBarTransactions", "chartLineTransactions"]) %>
<%= render_dashboard_section("Chiffre d'affaires", "bi bi-cash", ["chartPieCa", "chartBarCa", "chartLineCa"]) %>

