
  <div class="chartBox mx-auto">
    <canvas id="myChartPieTransactions"></canvas>
  </div>

  <% @data = [@totalTransactionsLoc, @totalTransactionsVente] %>

<script>
  var couleur1 = 'rgb(116, 159, 130)';
  var couleur2 = 'rgb(66, 95, 87)';

  var nbTotalCa = <%= @totalTransactions %>;

  var centerTextDoghnutTransactions = {
    id: 'centerTextDoghnutTransactions',
    afterDatasetsDraw(chart, args, pluginOptions){
      const { ctx } = chart;
      ctx.textAlign = "center";
      ctx.textBaseline = "middle";
      ctx.font = "bold 12px sans-serif";
      const text = "TTC: " + nbTotalCa + " - HT: " +  Math.round(nbTotalCa / 1.2);
      const x = chart.getDatasetMeta(0).data[0].x;
      const y = chart.getDatasetMeta(0).data[0].y;
      ctx.fillText(text, x, y);
    }
  }

   var dataPieTransactions = {
      labels: ['location', 'vente'],
      datasets: [{
        data: <%= @data.to_json.html_safe %>,
        fill: true,
        backgroundColor: [ couleur1, couleur2 ],
        borderWidth: 1
      }]
    };

    var configPieTransactions = {
      type: 'doughnut',
          data: {
            labels: ['location', 'vente'],
            datasets: [{
              data: <%= @data.to_json.html_safe %>,
              backgroundColor: [ couleur1, couleur2 ],
              hoverOffset: 40,
              borderWidth: 1,
              cutout: '50%'
            }]
          },
          options: {
            animation: {
              animateRotate: true,
              duration: 5000
            },
            plugins: {
              legend: {
                display: true,
                position: 'top',
              },
            },

          },
          plugins: [centerTextDoghnutTransactions]
        };

  var myChartPieTransactions = new Chart(
    document.getElementById('myChartPieTransactions'),
    configPieTransactions
  );

</script>
