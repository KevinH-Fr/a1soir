
  <div class="chartBox mx-auto">
    <canvas id="myChartLineTransactions"></canvas>
  </div>


<script>

  var couleur1 = 'rgb(116, 159, 130)';
  var couleur2 = 'rgb(66, 95, 87)';

    var dataLineTransactions = {
      datasets: [{
        data: <%= @groupedByDateTransactions.to_json.html_safe %>,
        fill: true,
        backgroundColor: [couleur2, couleur1 ],
        borderWidth: 1,
        borderColor: 'rgb(0, 0, 0)',
        tension: 0.4
      }]
    };

    var delayedLineTransactions;

    var configLineTransactions = {
      type: 'line',
      data: dataLineTransactions,
      options: {

        plugins: {
            legend: {
                display: false
            },
        },
        aspectRatio: 1,

        elements: {
          point: {
            radius: 2,
            hoverRadius: 4,
            borderWidth: 1,
            hoverBorderWidth: 2
          }
        },

         animation: {
                onComplete: () => {
                    delayed = true;
                },
                delay: (context) => {
                    let delay = 0;
                    if (context.type === 'data' && context.mode === 'default' && !delayedLineTransactions) {
                    delay = context.dataIndex * 2000  + context.datasetIndex * 10;
                    }
                    return delay;
                },
            },

          }
      };

    var myChartLineTransactions = new Chart(
      document.getElementById('myChartLineTransactions'),
      configLineTransactions
    );

</script>
