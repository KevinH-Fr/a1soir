<%= card_main_model(
  "Paiements",
  "cash",
  admin_bandeau_nouveau_cta("#collapseNewPaiement",
          data: { bs_toggle: "collapse" },
          role: "button", aria: { expanded: "false", controls: "collapseNewPaiement" }),
  totals_inline: render("admin/paiement_recus/synthese")) %>

<%= admin_collapse_nouveau collapse_id: "collapseNewPaiement",
      target_id: "new_paiement",
      inner_partial: "admin/paiement_recus/form",
      commande_id: @commande.id,
      paiement_recu: PaiementRecu.new %>

<div id="paiement_recus" class="<%= admin_list_stack_classes %>">
  <% @commande.paiement_recus.each do |paiement_recu| %>
    <%= render partial: 'admin/paiement_recus/paiement_recu', locals: { paiement_recu: paiement_recu } %>
  <% end %>
</div>