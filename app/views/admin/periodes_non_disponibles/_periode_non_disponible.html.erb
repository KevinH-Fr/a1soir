<div id="<%= dom_id(periode_non_disponible) %>" class="card border border-secondary-subtle shadow-sm rounded-3 mb-0">
  <div class="card-body p-3">
    <div class="row g-3">
      <div class="col-md-4">
        <div class="small text-muted mb-0">Date de début</div>
        <div class="fw-semibold">
          <%= periode_non_disponible.date_debut&.strftime("%d/%m/%Y") || "—" %>
        </div>
      </div>
      <div class="col-md-4">
        <div class="small text-muted mb-0">Date de fin</div>
        <div class="fw-semibold">
          <%= periode_non_disponible.date_fin&.strftime("%d/%m/%Y") || "—" %>
        </div>
      </div>
      <div class="col-md-4">
        <div class="small text-muted mb-0">Récurrent (chaque année)</div>
        <div class="fw-semibold">
          <%= periode_non_disponible.recurrence? ? "Oui" : "Non" %>
        </div>
      </div>
    </div>

    <div class="d-flex justify-content-end pt-3 mt-2 mt-md-3 border-top border-secondary-subtle">
      <%= links_record(periode_non_disponible) %>
    </div>
  </div>
</div>
