<h1 class="text-center"> resultats</h1>

<%= render 'search/form' %>

<div class="container">
    <table> 
      <thead> 
        <tr>    
            <th> <%= sort_link(@q, :nom, "nom", default_order: :asc) %> </th>
        </tr>
      </thead>
      <tbody>  
        <% @produits.each do | produit | %> 
          <tr>
            <td>  <%= link_to produit.nom, produit %> </td>
           </tr>
        <% end %>
      </tbody>
    </table>
    
</div>

