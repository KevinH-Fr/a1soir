
<%= form_with(model: paiement) do |form| %>
  <% if paiement.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(paiement.errors.count, "error") %> prohibited this paiement from being saved:</h2>
      <ul>
        <% paiement.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div>
    <%= form.label :typepaiement, style: "display: block" %>
    <%= form.text_field :typepaiement %>
  </div>
  <div>
    <%= form.label :montant, style: "display: block" %>
    <%= form.text_field :montant %>
  </div>
  <div>
    <%= form.label :commande_id, style: "display: block" %>
    <%= form.select :commande_id, Commande.all.collect { |c| [ c.nom, c.id ] },  include_blank: true, selected: @commandeId %>
  </div>

  <div> <br>
    <%= form.submit "Créer", class: 'btn btn-success' %>
  </div>
<% end %>